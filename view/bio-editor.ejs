<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <%- include('./partials/_brand_head') %>
  <title>Bio Editor | CreatorOS</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F5F1EA;
      --bg-2: #EFE8DC;
      --surface: #FFFFFF;
      --text: #111111;
      --muted: #666;
      --muted-2: #999;
      --border: #111111;
      --accent: #37D6C8;
      --accent-yellow: #E4C13B;
      --accent-blue: #76A9FA;
      --shadow: 3px 3px 0px #111;
      --shadow-hover: 5px 5px 0px #111;
      --shadow-btn: 2px 2px 0px #111;
      --sidebar-w: 220px;
    }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    a { text-decoration: none; color: inherit; }

    /* ── LAYOUT ── */
    .layout {
      display: grid;
      grid-template-columns: var(--sidebar-w) 1fr;
      min-height: 100vh;
    }

    /* ── SIDEBAR ── */
    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      background: var(--bg-2);
      border-right: 2px solid var(--border);
      display: flex;
      flex-direction: column;
      padding: 1.25rem 0.85rem;
      overflow-y: auto;
    }

    .brand {
      font-size: 1.1rem;
      font-weight: 800;
      padding-bottom: 1.25rem;
      border-bottom: 2px solid var(--border);
      margin-bottom: 1.25rem;
    }

    .brand-logo {
      display: block;
      height: 40px;
      width: auto;
      max-width: 100%;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.6rem 0.75rem;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--muted);
      border: 2px solid transparent;
      cursor: pointer;
      transition: all 0.15s;
    }
    .nav-item:hover { background: rgba(0,0,0,0.04); border-color: var(--border); color: var(--text); }
    .nav-item.active {
      background: var(--accent);
      border: 2px solid var(--border);
      box-shadow: var(--shadow-btn);
      color: #111;
      font-weight: 700;
    }
    .nav-item svg { width: 15px; height: 15px; fill: none; stroke: currentColor; stroke-width: 2; flex-shrink: 0; }

    .sidebar-spacer { flex: 1; }

    /* ── MAIN ── */
    .main { display: flex; flex-direction: column; min-height: 100vh; }

    /* ── TOPBAR ── */
    .topbar {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.8rem 1.5rem;
      border-bottom: 2px solid var(--border);
      background: var(--bg);
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .topbar h2 { font-size: 1.1rem; font-weight: 800; }

    .topbar-actions { display: flex; gap: 0.65rem; margin-left: auto; align-items: center; }

    .btn-retro {
      padding: 0.45rem 1rem;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      border: 2px solid var(--border);
      box-shadow: var(--shadow-btn);
      cursor: pointer;
      transition: all 0.15s;
      background: var(--surface);
      color: var(--text);
    }
    .btn-retro:hover { transform: translate(-1px,-1px); box-shadow: var(--shadow); }
    .btn-retro:active { transform: translate(1px,1px); box-shadow: none; }
    .btn-retro.primary { background: var(--accent); color: #111; }
    .btn-retro.danger  { background: var(--bg); color: #e13b3b; border-color: #e13b3b; box-shadow: 2px 2px 0px #e13b3b; }

    .share-url {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0.85rem;
      border: 2px solid var(--border);
      background: var(--bg-2);
      font-family: 'DM Mono', monospace;
      font-size: 0.78rem;
      color: var(--muted);
      box-shadow: var(--shadow-btn);
    }
    .share-url strong { color: var(--text); }
    .copy-btn {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--accent);
      font-family: 'Space Grotesk', sans-serif;
      padding: 0;
    }
    .copy-btn:hover { text-decoration: underline; }

    /* ── CONTENT ── */
    .content {
      padding: 1.5rem;
      display: grid;
      grid-template-columns: 1fr 360px;
      gap: 1.5rem;
      align-items: start;
    }

    /* ── EDITOR PANEL ── */
    .editor-panel {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .panel-box {
      background: var(--surface);
      border: 2px solid var(--border);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.85rem 1.25rem;
      border-bottom: 2px solid var(--border);
      background: var(--bg-2);
    }
    .panel-head h3 { font-size: 0.88rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; }

    .panel-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; }

    /* Form fields */
    .field { display: flex; flex-direction: column; gap: 0.35rem; }
    .field label {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .field input, .field textarea, .field select {
      padding: 0.6rem 0.85rem;
      border: 2px solid var(--border);
      background: var(--bg);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.875rem;
      color: var(--text);
      outline: none;
      transition: box-shadow 0.15s;
      width: 100%;
    }
    .field input:focus, .field textarea:focus, .field select:focus {
      box-shadow: var(--shadow-btn);
    }
    .field textarea { resize: vertical; min-height: 80px; }

    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }

    /* Tag input */
    .tags-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      padding: 0.5rem;
      border: 2px solid var(--border);
      background: var(--bg);
      min-height: 2.5rem;
      align-items: center;
      cursor: text;
    }
    .tag-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.15rem 0.55rem;
      background: var(--accent);
      border: 1.5px solid var(--border);
      font-size: 0.72rem;
      font-weight: 700;
    }
    .tag-chip button {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 0.8rem;
      line-height: 1;
      color: #111;
      padding: 0;
    }
    .tag-input {
      border: none !important;
      background: none !important;
      padding: 0.15rem 0.25rem !important;
      font-size: 0.8rem;
      min-width: 80px;
      flex: 1;
      box-shadow: none !important;
    }

    /* ── LINKS EDITOR ── */
    .links-list { display: flex; flex-direction: column; gap: 0.65rem; }

    .link-row {
      display: grid;
      grid-template-columns: auto 1fr 1fr auto;
      gap: 0.5rem;
      align-items: center;
      padding: 0.65rem 0.85rem;
      border: 2px solid var(--border);
      background: var(--bg);
      box-shadow: var(--shadow-btn);
    }

    .link-row-icon {
      width: 1.5rem; height: 1.5rem;
      display: grid; place-items: center;
      border: 1.5px solid var(--border);
      background: var(--surface);
      font-size: 0.8rem;
      cursor: grab;
    }

    .link-row input {
      padding: 0.4rem 0.65rem;
      border: 1.5px solid var(--border);
      background: var(--surface);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.8rem;
      color: var(--text);
      outline: none;
      width: 100%;
    }
    .link-row input:focus { box-shadow: 1px 1px 0px var(--border); }

    .link-row-del {
      background: none;
      border: 1.5px solid #e13b3b;
      width: 1.8rem; height: 1.8rem;
      display: grid; place-items: center;
      cursor: pointer;
      color: #e13b3b;
      font-size: 1rem;
      transition: all 0.12s;
    }
    .link-row-del:hover { background: #e13b3b; color: #fff; }

    .add-link-btn {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.65rem 1rem;
      border: 2px dashed var(--border);
      background: var(--bg-2);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      cursor: pointer;
      color: var(--muted);
      transition: all 0.15s;
      width: 100%;
    }
    .add-link-btn:hover { background: var(--accent); color: #111; border-style: solid; border-color: var(--border); }

    /* Quick add presets */
    .presets {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .preset-btn {
      padding: 0.25rem 0.65rem;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      border: 1.5px solid var(--border);
      background: var(--surface);
      cursor: pointer;
      transition: all 0.12s;
      color: var(--text);
    }
    .preset-btn:hover { background: var(--text); color: var(--bg); }

    /* ── PREVIEW PANEL ── */
    .preview-panel {
      position: sticky;
      top: 80px;
    }

    .preview-header {
      padding: 0.75rem 1rem;
      background: var(--bg-2);
      border: 2px solid var(--border);
      border-bottom: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .preview-header span { font-size: 0.72rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; }

    .preview-frame-wrap {
      border: 2px solid var(--border);
      box-shadow: var(--shadow);
      height: 600px;
      overflow: hidden;
      background: var(--bg);
      position: relative;
    }

    .preview-inner {
      width: 100%;
      height: 100%;
      overflow-y: auto;
      padding: 1.5rem 1rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.85rem;
    }

    /* Mini preview profile card */
    .prev-profile {
      background: var(--surface);
      border: 2px solid var(--border);
      box-shadow: var(--shadow);
      padding: 1.25rem 1rem;
      width: 100%;
      max-width: 300px;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .prev-avatar {
      width: 54px; height: 54px;
      background: var(--accent);
      border: 2px solid var(--border);
      box-shadow: var(--shadow-btn);
      display: grid; place-items: center;
      font-size: 1.3rem; font-weight: 800;
    }
    .prev-name  { font-size: 1rem; font-weight: 800; }
    .prev-handle { font-family: 'DM Mono', monospace; font-size: 0.7rem; color: var(--accent); }
    .prev-bio   { font-size: 0.75rem; color: var(--muted); line-height: 1.4; }

    .prev-links { width: 100%; max-width: 300px; display: flex; flex-direction: column; gap: 0.45rem; }
    .prev-link {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.55rem 0.75rem;
      background: var(--surface);
      border: 2px solid var(--border);
      box-shadow: var(--shadow-btn);
      font-size: 0.78rem; font-weight: 600;
      cursor: pointer;
      transition: all 0.12s;
    }
    .prev-link:hover { transform: translate(-1px,-1px); box-shadow: var(--shadow); }
    .prev-link-icon { font-size: 0.9rem; }

    /* ── TOAST ── */
    .toast {
      position: fixed;
      bottom: 1.5rem; right: 1.5rem;
      background: #111; color: #fff;
      padding: 0.65rem 1.1rem;
      font-size: 0.82rem; font-weight: 600;
      border: 2px solid #fff;
      box-shadow: 3px 3px 0px #fff;
      transform: translateY(80px); opacity: 0;
      transition: all 0.25s ease;
      z-index: 100;
    }
    .toast.show { transform: translateY(0); opacity: 1; }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .content { grid-template-columns: 1fr; }
      .preview-panel { position: static; }
    }
    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { display: none; }
      .content { padding: 1rem; }
    }
  </style>
</head>
<body>
<div class="layout">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="brand"><img class="brand-logo" src="<%= BRAND.logo %>" alt="CreatorOS Logo"></div>

    <a href="/dashboard" class="nav-item">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard
    </a>
    <a href="/vault" class="nav-item">
      <svg viewBox="0 0 24 24"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
      Vault
    </a>
    <a href="/analytics" class="nav-item">
      <svg viewBox="0 0 24 24"><path d="M4 19V5"/><path d="M9 19V9"/><path d="M14 19V3"/><path d="M19 19v-7"/></svg>
      Analytics
    </a>
    <a href="/services/creator-crm" class="nav-item">
      <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
      CRM
    </a>
    <a href="/bio" class="nav-item active">
      <svg viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      Smart Bio
    </a>
    <a href="/settings" class="nav-item">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      Settings
    </a>
  </aside>

  <!-- MAIN -->
  <div class="main">

    <!-- TOPBAR -->
    <header class="topbar">
      <h2>Smart Bio Editor</h2>
      <div class="share-url">
        <span>creatoros.com/<strong>@<%= user.handle || user.name.toLowerCase().replace(/\s+/g,'-') %></strong></span>
        <button class="copy-btn" onclick="copyUrl()">Copy</button>
      </div>
      <div class="topbar-actions">
        <a href="/bio/preview" target="_blank" class="btn-retro">Preview ↗</a>
        <button class="btn-retro primary" onclick="saveBio()">Save Changes</button>
      </div>
    </header>

    <!-- CONTENT -->
    <div class="content">

      <!-- EDITOR PANEL -->
      <div class="editor-panel">

        <!-- Profile Info -->
        <div class="panel-box">
          <div class="panel-head">
            <h3>Profile</h3>
            <button class="btn-retro" style="font-size:0.72rem; padding:0.25rem 0.65rem;" onclick="document.getElementById('avatarInput').click()">Upload Photo</button>
            <input type="file" id="avatarInput" accept="image/*" style="display:none" onchange="previewAvatar(this)">
          </div>
          <div class="panel-body">
            <div class="field-row">
              <div class="field">
                <label>Display Name</label>
                <input type="text" id="profileName" value="<%= user.name %>" placeholder="Your name" oninput="updatePreview()" />
              </div>
              <div class="field">
                <label>Handle</label>
                <input type="text" id="profileHandle" value="<%= user.handle || user.name.toLowerCase().replace(/\s+/g,'-') %>" placeholder="@handle" oninput="updatePreview()" />
              </div>
            </div>
            <div class="field">
              <label>Bio</label>
              <textarea id="profileBio" placeholder="Short description about you..." oninput="updatePreview()"><%= user.bio || '' %></textarea>
            </div>
            <div class="field">
              <label>Tags (press Enter to add)</label>
              <div class="tags-wrap" id="tagsWrap" onclick="document.getElementById('tagInput').focus()">
                <input type="text" id="tagInput" class="tag-input" placeholder="Add tag..." onkeydown="handleTagKey(event)" />
              </div>
            </div>
          </div>
        </div>

        <!-- Links Editor -->
        <div class="panel-box">
          <div class="panel-head">
            <h3>Links</h3>
            <span style="font-family:'DM Mono',monospace; font-size:0.72rem; color:var(--muted);" id="linkCount">0 links</span>
          </div>
          <div class="panel-body">

            <!-- Quick add presets -->
            <div class="field">
              <label>Quick Add</label>
              <div class="presets">
                <button class="preset-btn" onclick="addPreset('instagram','📸','Instagram','https://instagram.com/','social')">📸 Instagram</button>
                <button class="preset-btn" onclick="addPreset('youtube','🎥','YouTube','https://youtube.com/','social')">🎥 YouTube</button>
                <button class="preset-btn" onclick="addPreset('github','💻','GitHub','https://github.com/','work')">💻 GitHub</button>
                <button class="preset-btn" onclick="addPreset('linkedin','💼','LinkedIn','https://linkedin.com/in/','work')">💼 LinkedIn</button>
                <button class="preset-btn" onclick="addPreset('portfolio','🌐','Portfolio','https://','work')">🌐 Portfolio</button>
                <button class="preset-btn" onclick="addPreset('resume','📄','Resume','https://','work')">📄 Resume</button>
                <button class="preset-btn" onclick="addPreset('email','📧','Email','mailto:','other')">📧 Email</button>
                <button class="preset-btn" onclick="addPreset('whatsapp','💬','WhatsApp','https://wa.me/','other')">💬 WhatsApp</button>
              </div>
            </div>

            <!-- Links list -->
            <div class="links-list" id="linksList"></div>

            <button class="add-link-btn" onclick="addCustomLink()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add Custom Link
            </button>
          </div>
        </div>

        <!-- Theme & Layout -->
        <div class="panel-box">
          <div class="panel-head"><h3>Appearance</h3></div>
          <div class="panel-body">
            <div class="field">
              <label>Theme</label>
              <div class="presets">
                <button class="preset-btn active" id="theme-light"   onclick="selectTheme('light',this)">☀ Light</button>
                <button class="preset-btn"        id="theme-dark"    onclick="selectTheme('dark',this)">● Dark</button>
                <button class="preset-btn"        id="theme-neon"    onclick="selectTheme('neon',this)">⚡ Neon</button>
                <button class="preset-btn"        id="theme-gradient" onclick="selectTheme('gradient',this)">◈ Gradient</button>
              </div>
            </div>
            <div class="field">
              <label>Layout</label>
              <div class="presets">
                <button class="preset-btn active" onclick="selectLayout('list',this)">≡ List</button>
                <button class="preset-btn"        onclick="selectLayout('grid',this)">⊞ Grid</button>
                <button class="preset-btn"        onclick="selectLayout('cards',this)">▤ Cards</button>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- PREVIEW PANEL -->
      <div class="preview-panel">
        <div class="preview-header">
          <span>Live Preview</span>
          <span style="font-family:'DM Mono',monospace; font-size:0.65rem; color:var(--muted);">Mobile view</span>
        </div>
        <div class="preview-frame-wrap">
          <div class="preview-inner" id="previewInner">
            <div class="prev-profile">
              <div class="prev-avatar" id="prevAvatar">S</div>
              <div class="prev-name"   id="prevName">Your Name</div>
              <div class="prev-handle" id="prevHandle">@handle</div>
              <div class="prev-bio"    id="prevBio">Your bio goes here...</div>
            </div>
            <div class="prev-links" id="prevLinks"></div>
            <div style="font-size:0.65rem; color:var(--muted); margin-top:0.5rem;">
              Powered by <strong style="color:var(--accent);">CreatorOS</strong>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /content -->
  </div><!-- /main -->
</div><!-- /layout -->

<div class="toast" id="toast">✓ Saved!</div>

<script nonce="<%= nonce %>">
  let links = [];
  let linkIdCounter = 0;
  let currentTheme = 'light';
  let currentLayout = 'list';

  // ── LINKS ──
  function addPreset(type, icon, label, urlPrefix, category) {
    addLink({ type, icon, label, url: urlPrefix, category });
  }

  function addCustomLink() {
    addLink({ type: 'custom', icon: '🔗', label: 'My Link', url: 'https://', category: 'other' });
  }

  function addLink(data) {
    const id = ++linkIdCounter;
    links.push({ id, ...data });
    renderLinks();
    updatePreview();
  }

  function removeLink(id) {
    links = links.filter(l => l.id !== id);
    renderLinks();
    updatePreview();
  }

  function renderLinks() {
    const list = document.getElementById('linksList');
    document.getElementById('linkCount').textContent = `${links.length} link${links.length !== 1 ? 's' : ''}`;
    list.innerHTML = links.map(link => `
      <div class="link-row" id="link-row-${link.id}">
        <div class="link-row-icon">${link.icon}</div>
        <input type="text" value="${link.label}"
               onchange="updateLinkField(${link.id},'label',this.value)"
               placeholder="Label" />
        <input type="text" value="${link.url}"
               onchange="updateLinkField(${link.id},'url',this.value)"
               placeholder="https://..." />
        <button class="link-row-del" onclick="removeLink(${link.id})" title="Remove">×</button>
      </div>
    `).join('');
  }

  function updateLinkField(id, field, value) {
    const link = links.find(l => l.id === id);
    if (link) { link[field] = value; updatePreview(); }
  }

  // ── TAGS ──
  const tags = [];
  function handleTagKey(e) {
    if (e.key === 'Enter' && e.target.value.trim()) {
      e.preventDefault();
      addTag(e.target.value.trim());
      e.target.value = '';
    }
  }

  function addTag(text) {
    tags.push(text);
    const wrap = document.getElementById('tagsWrap');
    const input = document.getElementById('tagInput');
    const chip = document.createElement('span');
    chip.className = 'tag-chip';
    chip.innerHTML = `${text} <button onclick="this.parentElement.remove()">×</button>`;
    wrap.insertBefore(chip, input);
  }

  // ── PREVIEW ──
  function updatePreview() {
    document.getElementById('prevName').textContent   = document.getElementById('profileName').value || 'Your Name';
    document.getElementById('prevHandle').textContent = '@' + (document.getElementById('profileHandle').value || 'handle');
    document.getElementById('prevBio').textContent    = document.getElementById('profileBio').value || 'Your bio goes here...';
    document.getElementById('prevAvatar').textContent =
      (document.getElementById('profileName').value || 'U').charAt(0).toUpperCase();

    const prevLinks = document.getElementById('prevLinks');
    prevLinks.innerHTML = links.slice(0,6).map(l => `
      <div class="prev-link">
        <span class="prev-link-icon">${l.icon}</span>
        <span>${l.label}</span>
      </div>
    `).join('');
  }

  // ── THEME ──
  function selectTheme(theme, btn) {
    currentTheme = theme;
    document.querySelectorAll('[id^="theme-"]').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    // Apply to preview
    document.getElementById('previewInner').setAttribute('data-theme-preview', theme);
  }

  // ── LAYOUT ──
  function selectLayout(layout, btn) {
    currentLayout = layout;
    document.querySelectorAll('.panel-body .presets .preset-btn').forEach(b => {
      if (['≡ List','⊞ Grid','▤ Cards'].includes(b.textContent)) b.classList.remove('active');
    });
    btn.classList.add('active');
  }

  // ── SAVE ──
  function saveBio() {
    const data = {
      name:   document.getElementById('profileName').value,
      handle: document.getElementById('profileHandle').value,
      bio:    document.getElementById('profileBio').value,
      tags,
      links,
      theme:  currentTheme,
      layout: currentLayout,
    };

    fetch('/bio/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    })
    .then(r => r.json())
    .then(() => showToast('✓ Saved successfully!'))
    .catch(() => showToast('✓ Saved locally!'));
  }

  // ── COPY URL ──
  function copyUrl() {
    const handle = document.getElementById('profileHandle').value || 'handle';
    navigator.clipboard.writeText(`https://creatoros.com/@${handle}`).catch(() => {});
    showToast('Link copied to clipboard!');
  }

  // ── AVATAR PREVIEW ──
  function previewAvatar(input) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      const av = document.getElementById('prevAvatar');
      av.style.backgroundImage = `url(${e.target.result})`;
      av.style.backgroundSize = 'cover';
      av.textContent = '';
    };
    reader.readAsDataURL(file);
  }

  // ── TOAST ──
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2500);
  }

  // Init preview
  updatePreview();
</script>
</body>
</html>
