  <!-- FIXED FOOTER ACTIONS (Visible only in Create/Edit View) -->
  <div class="fixed-footer-bar hidden" id="edit-footer-bar">
    <div class="footer-left-info">
      <span>Draft:</span>
      <strong id="footer-draft-label" style="text-decoration: underline;">Summer Drop v2</strong>
    </div>
    <div class="footer-actions">
      <button class="btn-retro-secondary" type="button" onclick="closeCreateView()">Discard Draft</button>
      <button class="btn-retro-secondary" type="button" onclick="triggerPhonePreviewPulse()">Preview Flow</button>
      <button class="btn-retro-primary" type="button" onclick="saveAutomationFromForm()">Launch Automation</button>
    </div>
  </div>

  <!-- Client-Side Automation Logic -->
  <script nonce="<%= nonce %>">
    // Global layout & sidebar toggles
    var layout = document.getElementById('dashboardLayout');
    var toggle = document.getElementById('sidebarToggle');
    if (localStorage.getItem('creatorosSidebarCollapsed') === 'true') {
      layout.classList.add('sidebar-collapsed');
      toggle.setAttribute('aria-expanded', 'false');
    }
    toggle.addEventListener('click', function() {
      var collapsed = layout.classList.toggle('sidebar-collapsed');
      toggle.setAttribute('aria-expanded', String(!collapsed));
      localStorage.setItem('creatorosSidebarCollapsed', String(collapsed));
    });

    // Default Seed Data
    const defaultTriggers = [
      { 
        id: '1', 
        name: 'Guide Delivery Bot',
        platform: 'instagram',
        triggerType: 'keyword',
        keyword: 'GUIDE', 
        matchType: 'exact',
        delay: 1.5,
        followerOnly: true,
        verifiedOnly: false,
        response: 'Thanks for reaching out! Here is the Creator Playbook guide: https://creatoros.com/guide.pdf 🚀', 
        ctaText: 'Download PDF',
        ctaUrl: 'https://creatoros.com/guide.pdf',
        count: 42, 
        active: true 
      },
      { 
        id: '2', 
        name: 'Creator CRM Lead Magnet',
        platform: 'instagram',
        triggerType: 'keyword',
        keyword: 'CRM', 
        matchType: 'contains',
        delay: 2.0,
        followerOnly: false,
        verifiedOnly: false,
        response: 'Hey! You can invite collaborators and track invitations using the Creator CRM tool here: /services/creator-crm 🤝', 
        ctaText: 'Access CRM Now',
        ctaUrl: '/services/creator-crm',
        count: 18, 
        active: true 
      },
      { 
        id: '3', 
        name: 'Support FAQ Bot',
        platform: 'twitter',
        triggerType: 'keyword',
        keyword: 'HELP', 
        matchType: 'exact',
        delay: 0.5,
        followerOnly: false,
        verifiedOnly: false,
        response: 'Active keywords available: [GUIDE], [CRM], [HELP]. Type any of them to trigger an automated flow.', 
        ctaText: 'Contact Support',
        ctaUrl: 'https://creatoros.com/support',
        count: 5, 
        active: true 
      }
    ];

    const defaultLogs = [
      { user: '@alex_creator', initials: 'AC', trigger: 'GUIDE', action: 'Sent PDF Link', time: '2 mins ago', status: 'success' },
      { user: '@sarah_mktg', initials: 'SM', trigger: 'Story Reply', action: 'Sent Welcome Emoji', time: '15 mins ago', status: 'success' },
      { user: '@jordan.builds', initials: 'JB', trigger: 'GUIDE', action: 'Capture Email Flow', time: '1 hr ago', status: 'pending' }
    ];

    // LocalStorage Operations
    function getTriggers() {
      const stored = localStorage.getItem('creatoros_dm_triggers');
      if (stored) {
        try {
          return JSON.parse(stored);
        } catch (e) {
          // ignore parsing error
        }
      }
      localStorage.setItem('creatoros_dm_triggers', JSON.stringify(defaultTriggers));
      return defaultTriggers;
    }

    function saveTriggers(triggers) {
      localStorage.setItem('creatoros_dm_triggers', JSON.stringify(triggers));
    }

    function getLogs() {
      const stored = localStorage.getItem('creatoros_dm_logs');
      if (stored) {
        try {
          return JSON.parse(stored);
        } catch(e) {}
      }
      localStorage.setItem('creatoros_dm_logs', JSON.stringify(defaultLogs));
      return defaultLogs;
    }

    function saveLogs(logs) {
      localStorage.setItem('creatoros_dm_logs', JSON.stringify(logs));
    }

    // Current State
    let activeKeywords = [];
    let selectedPlatform = 'instagram';
    let selectedMatchType = 'exact';
    let currentSimTab = 'dm';

    // Search Filtering
    const searchInput = document.getElementById('search-automations-input');
    searchInput.addEventListener('input', function(e) {
      const query = e.target.value.toLowerCase().trim();
      const cards = document.querySelectorAll('.workflow-card');
      cards.forEach(card => {
        const text = card.textContent.toLowerCase();
        if (text.includes(query)) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });

    // View Switching
    function openCreateView(id = null) {
      // Toggle views
      document.getElementById('view-dashboard').classList.add('hidden');
      document.getElementById('view-create-edit').classList.remove('hidden');
      document.getElementById('edit-footer-bar').classList.remove('hidden');
      
      // Reset form
      document.getElementById('automation-form').reset();
      activeKeywords = [];
      renderKeywordTags();
      
      if (id) {
        // Load details for Edit Mode
        const triggers = getTriggers();
        const trigger = triggers.find(t => t.id === String(id));
        if (trigger) {
          document.getElementById('create-view-title').textContent = 'Edit DM Automation';
          document.getElementById('create-view-tag-id').textContent = 'EDIT_WORKFLOW_ID_' + trigger.id;
          document.getElementById('footer-draft-label').textContent = 'Draft: ' + (trigger.name || 'Automation #' + trigger.id);
          
          document.getElementById('automation-id').value = trigger.id;
          document.getElementById('workflow-name-input').value = trigger.name || '';
          selectPlatform(trigger.platform || 'instagram');
          document.getElementById('trigger-type-select').value = trigger.triggerType || 'keyword';
          document.getElementById('automation-status-toggle').checked = trigger.active !== false;
          
          if (trigger.keyword) {
            activeKeywords = trigger.keyword.split(',').map(s => s.trim().toUpperCase()).filter(Boolean);
          }
          renderKeywordTags();
          selectMatchType(trigger.matchType || 'exact');
          document.getElementById('delay-slider').value = trigger.delay !== undefined ? trigger.delay : 1.5;
          updateDelayLabel(document.getElementById('delay-slider').value);
          document.getElementById('chk-followers').checked = !!trigger.followerOnly;
          document.getElementById('chk-verified').checked = !!trigger.verifiedOnly;
          
          document.getElementById('reply-message-textarea').value = trigger.response || '';
          document.getElementById('cta-text-input').value = trigger.ctaText || '';
          document.getElementById('cta-url-input').value = trigger.ctaUrl || '';
        }
      } else {
        // Create Mode
        document.getElementById('create-view-title').textContent = 'Create DM Automation';
        document.getElementById('create-view-tag-id').textContent = 'NEW_WORKFLOW_V4';
        document.getElementById('footer-draft-label').textContent = 'Draft: New Automation';
        document.getElementById('automation-id').value = '';
        selectPlatform('instagram');
        selectMatchType('exact');
        updateDelayLabel(1.5);
        document.getElementById('delay-slider').value = 1.5;
      }
      
      syncPhonePreview();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function closeCreateView() {
      document.getElementById('view-create-edit').classList.add('hidden');
      document.getElementById('edit-footer-bar').classList.add('hidden');
      document.getElementById('view-dashboard').classList.remove('hidden');
      updateDashboardUI();
    }

    // Segment selectors
    function selectPlatform(p) {
      selectedPlatform = p;
      if (p === 'instagram') {
        document.getElementById('platform-btn-instagram').classList.add('active');
        document.getElementById('platform-btn-twitter').classList.remove('active');
        // Preview sync
        document.getElementById('phone-avatar-char').textContent = 'IG';
        document.getElementById('phone-avatar-char').style.background = 'linear-gradient(135deg, #FFDD55, #E1306C)';
        document.getElementById('phone-avatar-char').style.color = '#FFFFFF';
        document.getElementById('phone-title-username').textContent = 'creator_account';
      } else {
        document.getElementById('platform-btn-instagram').classList.remove('active');
        document.getElementById('platform-btn-twitter').classList.add('active');
        // Preview sync
        document.getElementById('phone-avatar-char').textContent = '𝕏';
        document.getElementById('phone-avatar-char').style.backgroundColor = '#111111';
        document.getElementById('phone-avatar-char').style.backgroundImage = 'none';
        document.getElementById('phone-avatar-char').style.color = '#FFFFFF';
        document.getElementById('phone-title-username').textContent = 'creator_x';
      }
    }

    function selectMatchType(m) {
      selectedMatchType = m;
      const matchBtns = ['exact', 'contains', 'ai'];
      matchBtns.forEach(btn => {
        const el = document.getElementById('match-btn-' + btn);
        if (btn === m) {
          el.classList.add('active');
        } else {
          el.classList.remove('active');
        }
      });
    }

    function updateDelayLabel(v) {
      document.getElementById('delay-slider-label').textContent = v + ' SECONDS';
    }

    // Keywords Tags Builder
    function focusKeywordsInput() {
      document.getElementById('raw-keywords-input').focus();
    }

    function handleKeywordsKeydown(e) {
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        addKeywordFromInput();
      }
    }

    function addKeywordFromInput() {
      const input = document.getElementById('raw-keywords-input');
      const val = input.value.trim().toUpperCase();
      if (val) {
        const items = val.split(',').map(s => s.trim()).filter(Boolean);
        items.forEach(item => {
          if (!activeKeywords.includes(item)) {
            activeKeywords.push(item);
          }
        });
        input.value = '';
        renderKeywordTags();
        syncPhonePreview();
      }
    }

    function removeKeywordTag(kw) {
      activeKeywords = activeKeywords.filter(k => k !== kw);
      renderKeywordTags();
      syncPhonePreview();
    }

    function renderKeywordTags() {
      const box = document.getElementById('keywords-tag-box');
      const input = document.getElementById('raw-keywords-input');
      
      const oldTags = box.querySelectorAll('.keyword-tag-retro');
      oldTags.forEach(t => t.remove());
      
      activeKeywords.forEach(kw => {
        const tag = document.createElement('span');
        tag.className = 'keyword-tag-retro';
        tag.innerHTML = `${escapeHTML(kw)} <button type="button" onclick="event.stopPropagation(); removeKeywordTag('${kw}')">×</button>`;
        box.insertBefore(tag, input);
      });
    }

    // Phone Live Preview Sync
    function syncPhonePreview() {
      const keywordBubble = document.getElementById('phone-bubble-keyword');
      const responseBubble = document.getElementById('phone-bubble-response');
      const ctaCard = document.getElementById('phone-bubble-cta');
      const ctaCardMsg = document.getElementById('phone-cta-card-msg-text');
      const ctaBtnText = document.getElementById('phone-cta-btn-text');
      
      if (activeKeywords.length > 0) {
        keywordBubble.innerHTML = escapeHTML(activeKeywords[0]);
        keywordBubble.classList.remove('hidden');
      } else {
        keywordBubble.textContent = 'KEYWORD';
      }
      
      const responseText = document.getElementById('reply-message-textarea').value.trim();
      if (responseText) {
        responseBubble.innerHTML = escapeHTML(responseText).replace(/\n/g, '<br/>');
        responseBubble.classList.remove('hidden');
      } else {
        responseBubble.textContent = 'Reply message content will display here dynamically.';
      }
      
      const ctaText = document.getElementById('cta-text-input').value.trim();
      const ctaUrl = document.getElementById('cta-url-input').value.trim();
      if (ctaText || ctaUrl) {
        ctaCard.classList.remove('hidden');
        ctaCardMsg.textContent = ctaText ? 'Click to visit link' : 'Open Link';
        ctaBtnText.textContent = ctaText ? ctaText : 'Visit URL';
      } else {
        ctaCard.classList.add('hidden');
      }
    }

    function triggerPhonePreviewPulse() {
      const mockup = document.querySelector('.phone-mockup-wrapper');
      mockup.style.transition = 'transform 0.15s ease';
      mockup.style.transform = 'scale(1.03)';
      setTimeout(() => {
        mockup.style.transform = 'scale(1)';
      }, 150);
    }

    // Save Automation
    function saveAutomationFromForm() {
      const name = document.getElementById('workflow-name-input').value.trim();
      const reply = document.getElementById('reply-message-textarea').value.trim();
      
      if (!name) {
        alert('Please fill in the Automation Name.');
        document.getElementById('workflow-name-input').focus();
        return;
      }
      if (activeKeywords.length === 0) {
        alert('Please type at least one keyword and press Enter.');
        document.getElementById('raw-keywords-input').focus();
        return;
      }
      if (!reply) {
        alert('Please fill in the Reply Message.');
        document.getElementById('reply-message-textarea').focus();
        return;
      }

      const id = document.getElementById('automation-id').value;
      const triggers = getTriggers();
      
      const newTrigger = {
        id: id ? id : Date.now().toString(),
        name: name,
        platform: selectedPlatform,
        triggerType: document.getElementById('trigger-type-select').value,
        keyword: activeKeywords.join(','),
        matchType: selectedMatchType,
        delay: parseFloat(document.getElementById('delay-slider').value),
        followerOnly: document.getElementById('chk-followers').checked,
        verifiedOnly: document.getElementById('chk-verified').checked,
        response: reply,
        ctaText: document.getElementById('cta-text-input').value.trim(),
        ctaUrl: document.getElementById('cta-url-input').value.trim(),
        active: document.getElementById('automation-status-toggle').checked
      };

      if (id) {
        const idx = triggers.findIndex(t => t.id === id);
        if (idx !== -1) {
          newTrigger.count = triggers[idx].count || 0;
          triggers[idx] = newTrigger;
        }
      } else {
        newTrigger.count = 0;
        triggers.push(newTrigger);
      }

      saveTriggers(triggers);
      closeCreateView();
    }

    // Dashboard UI Render
    function updateDashboardUI() {
      const triggers = getTriggers();
      
      const activeCount = triggers.filter(t => t.active).length;
      const totalReplies = triggers.reduce((sum, t) => sum + (t.count || 0), 0);
      const leadsCount = Math.round(totalReplies * 0.45);

      document.getElementById('stat-active-workflows').textContent = activeCount;
      document.getElementById('stat-total-replies').textContent = formatMetricNumber(totalReplies);
      document.getElementById('stat-leads-captured').textContent = leadsCount;
      document.getElementById('lead-metric-emails').textContent = Math.round(leadsCount * 0.63);
      document.getElementById('lead-metric-phones').textContent = Math.round(leadsCount * 0.37);

      let topTriggerStr = '"GUIDE"';
      let maxCount = -1;
      let avgDelaySum = 0;
      
      triggers.forEach(t => {
        if ((t.count || 0) > maxCount) {
          maxCount = t.count || 0;
          topTriggerStr = `"${t.keyword.split(',')[0].trim().toUpperCase()}"`;
        }
        avgDelaySum += t.delay !== undefined ? t.delay : 1.5;
      });
      document.getElementById('quick-stat-top-trigger').textContent = topTriggerStr;
      
      if (triggers.length > 0) {
        const avgDelay = (avgDelaySum / triggers.length).toFixed(1) + 's';
        document.getElementById('quick-stat-avg-delay').textContent = avgDelay;
      }

      const container = document.getElementById('workflows-grid-container');
      container.innerHTML = '';

      triggers.forEach(trigger => {
        const card = document.createElement('div');
        card.className = 'workflow-card';
        
        let statusBadgeClass = 'disabled';
        let statusText = 'DISABLED';
        if (trigger.active) {
          statusBadgeClass = 'live';
          statusText = 'LIVE';
        } else {
          statusBadgeClass = 'paused';
          statusText = 'PAUSED';
        }

        const randSeed = parseInt(trigger.id) || 1;
        const clickRateVal = trigger.count > 0 
          ? (Math.min(Math.round(((randSeed * 17.3) % 40) + 20), 100) + '%') 
          : '0.0%';

        const firstKeyword = trigger.keyword.split(',')[0].trim().toUpperCase();
        
        card.innerHTML = `
          <div class="workflow-card-top">
            <span class="status-badge ${statusBadgeClass}">${statusText}</span>
            <div class="card-actions-wrapper">
              <button class="card-action-icon" onclick="openCreateView('${trigger.id}')" title="Edit automation" aria-label="Edit">
                <svg viewBox="0 0 24 24" style="width:0.95rem; height:0.95rem;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
              </button>
              <button class="card-action-icon" onclick="deleteTrigger('${trigger.id}')" title="Delete automation" aria-label="Delete">
                <svg viewBox="0 0 24 24" style="width:0.95rem; height:0.95rem;"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
              </button>
            </div>
          </div>
          <h3>${escapeHTML(trigger.name || 'Keyword: ' + firstKeyword)}</h3>
          <p class="description">${escapeHTML(trigger.response)}</p>
          <div class="workflow-card-performance">
            <div class="perf-metric">
              <span class="perf-label">SENT</span>
              <span class="perf-value">${trigger.count || 0}</span>
            </div>
            <div class="bar-container">
              <div class="bar-fill" style="width: ${Math.min((trigger.count / 100) * 100, 100)}%;"></div>
            </div>
            <div class="perf-metric" style="margin-top:2px;">
              <span class="perf-label">CLICK RATE</span>
              <span class="perf-value" style="color:var(--accent-blue)">${clickRateVal}</span>
            </div>
          </div>
        `;
        container.appendChild(card);
      });

      const dottedCard = document.createElement('div');
      dottedCard.className = 'create-card-dotted';
      dottedCard.onclick = () => openCreateView();
      dottedCard.innerHTML = `
        <div class="plus-circle">+</div>
        <span>Create New Workflow</span>
      `;
      container.appendChild(dottedCard);

      renderLogsTable();
      updateSimulatorDetails();
    }

    function deleteTrigger(id) {
      if (confirm('Are you sure you want to delete this automation?')) {
        let triggers = getTriggers();
        triggers = triggers.filter(t => t.id !== String(id));
        saveTriggers(triggers);
        updateDashboardUI();
      }
    }

    function formatMetricNumber(num) {
      if (num >= 1000) {
        return (num / 1000).toFixed(1) + 'k';
      }
      return num;
    }

    // Seed/Logs Management
    function seedLogs(append = false) {
      const logs = getLogs();
      const mockUsers = [
        { user: '@jessica_design', initials: 'JD', action: 'Sent Portfolio Link' },
        { user: '@sam.dev', initials: 'SD', action: 'Delivered CRM Link' },
        { user: '@nicole_os', initials: 'NO', action: 'Sent PDF Link' },
        { user: '@robert_cap', initials: 'RC', action: 'Sent Welcome Emoji' }
      ];
      
      const newItems = [];
      const triggers = getTriggers();
      
      for (let i = 0; i < 3; i++) {
        const u = mockUsers[Math.floor(Math.random() * mockUsers.length)];
        const t = triggers.length > 0 ? triggers[Math.floor(Math.random() * triggers.length)] : { keyword: 'GUIDE' };
        const keyword = t.keyword.split(',')[0].trim().toUpperCase();
        newItems.push({
          user: u.user,
          initials: u.initials,
          trigger: keyword,
          action: u.action,
          time: (i + 2) + ' hrs ago',
          status: 'success'
        });
      }

      if (append) {
        saveLogs([...logs, ...newItems]);
      } else {
        saveLogs(newItems);
      }
      renderLogsTable();
    }

    function clearLogs() {
      saveLogs([]);
      renderLogsTable();
    }

    function renderLogsTable() {
      const logs = getLogs();
      const tbody = document.getElementById('logs-tbody');
      tbody.innerHTML = '';
      
      if (logs.length === 0) {
        tbody.innerHTML = `<tr><td colspan="5" style="text-align:center; color:var(--gray-muted); padding:2rem 1rem;">No recent interactions. Type in the simulator to generate logs!</td></tr>`;
        return;
      }

      logs.forEach(log => {
        const tr = document.createElement('tr');
        const statusClass = log.status === 'success' ? 'success' : 'pending';
        const statusText = log.status.toUpperCase();
        
        tr.innerHTML = `
          <td>
            <div class="table-user-cell">
              <span class="table-avatar">${log.initials || 'U'}</span>
              <strong>${escapeHTML(log.user)}</strong>
            </div>
          </td>
          <td>
            <span class="table-trigger-badge">${escapeHTML(log.trigger)}</span>
          </td>
          <td style="color:var(--gray-muted); font-weight:500;">${escapeHTML(log.action)}</td>
          <td>${log.time}</td>
          <td>
            <span class="table-status-text ${statusClass}">● ${statusText}</span>
          </td>
        `;
        tbody.appendChild(tr);
      });
    }

    // Export Leads as CSV
    function exportLeadsCSV() {
      const logs = getLogs();
      if (logs.length === 0) {
        alert('No leads collected to export.');
        return;
      }
      
      let csvContent = "data:text/csv;charset=utf-8,";
      csvContent += "Username,Triggered Keyword,Action,Timestamp,Status\n";
      
      logs.forEach(log => {
        csvContent += `${log.user},${log.trigger},${log.action},${log.time},${log.status}\n`;
      });
      
      const encodedUri = encodeURI(csvContent);
      const link = document.createElement("a");
      link.setAttribute("href", encodedUri);
      link.setAttribute("download", "creatoros_leads.csv");
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }

    // Simulator Tab Switcher
    function switchSimTab(tab) {
      currentSimTab = tab;
      if (tab === 'dm') {
        document.getElementById('sim-tab-dm').classList.add('active');
        document.getElementById('sim-tab-comments').classList.remove('active');
        document.getElementById('sim-panel-dm').classList.remove('hidden');
        document.getElementById('sim-panel-comments').classList.add('hidden');
      } else {
        document.getElementById('sim-tab-comments').classList.add('active');
        document.getElementById('sim-tab-dm').classList.remove('active');
        document.getElementById('sim-panel-comments').classList.remove('hidden');
        document.getElementById('sim-panel-dm').classList.add('hidden');
      }
    }

    function updateSimulatorDetails() {
      const triggers = getTriggers();
      const lastTrigger = triggers.length > 0 ? triggers[triggers.length - 1] : null;
      if (lastTrigger && lastTrigger.platform === 'twitter') {
        document.getElementById('sim-bot-avatar-char').textContent = '𝕏';
        document.getElementById('sim-bot-avatar-char').style.backgroundColor = '#111111';
        document.getElementById('sim-bot-avatar-char').style.color = '#FFFFFF';
        document.getElementById('sim-bot-name').textContent = 'Mock Twitter Bot';
      } else {
        document.getElementById('sim-bot-avatar-char').textContent = 'IG';
        document.getElementById('sim-bot-avatar-char').style.background = 'linear-gradient(135deg, #FFDD55, #E1306C)';
        document.getElementById('sim-bot-avatar-char').style.color = '#FFFFFF';
        document.getElementById('sim-bot-name').textContent = 'Mock Instagram Bot';
      }
    }

    // DM Simulator send message
    function sendSimMessage() {
      const input = document.getElementById('sim-chat-input-field');
      const msgText = input.value.trim();
      if (!msgText) return;
      
      appendSimMessageBubble(escapeHTML(msgText), true, 'dm');
      input.value = '';
      
      const chatContainer = document.getElementById('sim-chat-messages-container');
      chatContainer.scrollTop = chatContainer.scrollHeight;
      
      const triggers = getTriggers();
      const matched = [...triggers].reverse().find(t => {
        if (!t.active) return false;
        
        const kwList = t.keyword.split(',').map(s => s.trim().toUpperCase()).filter(Boolean);
        const msg = msgText.trim().toUpperCase();
        
        if (t.matchType === 'contains') {
          return kwList.some(kw => msg.includes(kw));
        } else {
          return kwList.some(kw => msg === kw);
        }
      });
      
      const indicator = document.getElementById('sim-chat-typing-indicator');
      indicator.classList.remove('hidden');
      chatContainer.scrollTop = chatContainer.scrollHeight;
      
      const delayMs = matched && matched.delay !== undefined ? (matched.delay * 1000) : 1000;
      
      setTimeout(() => {
        indicator.classList.add('hidden');
        
        if (matched) {
          matched.count = (matched.count || 0) + 1;
          saveTriggers(triggers);
          updateDashboardUI();
          
          appendSimMessageBubble(escapeHTML(matched.response).replace(/\n/g, '<br/>'), false, 'dm');
          
          if (matched.ctaText || matched.ctaUrl) {
            appendSimCTABubble(escapeHTML(matched.ctaText), matched.ctaUrl);
          }
          
          logInteraction(msgText, matched.name || 'Keyword: ' + matched.keyword.split(',')[0], 'success');
        } else {
          appendSimMessageBubble(`Hey! I didn't quite catch that. Try typing one of your active triggers like <strong>GUIDE</strong> or <strong>CRM</strong>.`, false, 'dm');
          logInteraction(msgText, 'Fallback Reply', 'success');
        }
        chatContainer.scrollTop = chatContainer.scrollHeight;
      }, Math.max(delayMs, 600));
    }

    function appendSimMessageBubble(text, isUser, type = 'dm') {
      const containerId = type === 'dm' ? 'sim-chat-messages-container' : 'sim-comments-thread-container';
      const container = document.getElementById(containerId);
      
      const bubble = document.createElement('div');
      bubble.className = `sim-msg ${isUser ? 'sent' : 'received'}`;
      bubble.innerHTML = text;
      container.appendChild(bubble);
    }

    function appendSimCTABubble(text, url) {
      const container = document.getElementById('sim-chat-messages-container');
      const ctaBlock = document.createElement('div');
      ctaBlock.className = 'sim-msg-cta-block';
      ctaBlock.innerHTML = `
        <span style="font-size:0.75rem; color:var(--gray-muted); margin-bottom:2px;">Special Action Link:</span>
        <a href="${url}" target="_blank" class="sim-msg-cta-btn">${escapeHTML(text)}</a>
      `;
      container.appendChild(ctaBlock);
    }

    // Comment Simulator send comment
    function sendSimComment() {
      const input = document.getElementById('sim-comment-input-field');
      const commentText = input.value.trim();
      if (!commentText) return;
      
      const threadBox = document.getElementById('sim-comments-thread-container');
      const commentDiv = document.createElement('div');
      commentDiv.className = 'post-comment-item';
      commentDiv.innerHTML = `
        <div class="table-avatar" style="width:1.5rem; height:1.5rem; font-size:0.7rem;">U</div>
        <div>
          <strong style="font-size:0.78rem;">@mock_user</strong>
          <span style="font-size:0.78rem; margin-left:0.25rem;">${escapeHTML(commentText)}</span>
        </div>
      `;
      threadBox.appendChild(commentDiv);
      
      input.value = '';
      
      const messagesContainer = document.getElementById('sim-comment-messages-container');
      messagesContainer.scrollTop = messagesContainer.scrollHeight;

      const triggers = getTriggers();
      const matched = [...triggers].reverse().find(t => {
        if (!t.active) return false;
        
        const kwList = t.keyword.split(',').map(s => s.trim().toUpperCase()).filter(Boolean);
        const msg = commentText.trim().toUpperCase();
        return kwList.some(kw => msg === kw || msg.includes(kw));
      });

      const indicator = document.getElementById('sim-comment-typing-indicator');
      indicator.classList.remove('hidden');
      messagesContainer.scrollTop = messagesContainer.scrollHeight;

      const delayMs = matched && matched.delay !== undefined ? (matched.delay * 1000) : 1000;

      setTimeout(() => {
        indicator.classList.add('hidden');
        
        const replyDiv = document.createElement('div');
        replyDiv.className = 'post-comment-reply';
        
        if (matched) {
          matched.count = (matched.count || 0) + 1;
          saveTriggers(triggers);
          updateDashboardUI();
          
          replyDiv.innerHTML = `
            <div class="avatar" style="width:1.3rem; height:1.3rem; font-size:0.6rem; background:none; border:none;"><img src="<%= BRAND.icon %>" alt="CreatorOS Icon" style="display:block; width:100%; height:100%; object-fit:contain;"></div>
            <div>
              <strong style="font-size:0.75rem;">@creator_account</strong>
              <span style="font-size:0.75rem; margin-left:0.25rem;">@mock_user check your inbox! I've sent you a DM. 📩</span>
            </div>
          `;
          threadBox.appendChild(replyDiv);
          
          appendSimMessageBubble(`[Auto-Reply from Comments] ${escapeHTML(matched.response)}`, false, 'dm');
          if (matched.ctaText || matched.ctaUrl) {
            appendSimCTABubble(escapeHTML(matched.ctaText), matched.ctaUrl);
          }
          
          logInteraction(commentText, 'Comment DM Sent', 'success');
        } else {
          replyDiv.innerHTML = `
            <div class="avatar" style="width:1.3rem; height:1.3rem; font-size:0.6rem; background:none; border:none;"><img src="<%= BRAND.icon %>" alt="CreatorOS Icon" style="display:block; width:100%; height:100%; object-fit:contain;"></div>
            <div>
              <strong style="font-size:0.75rem;">@creator_account</strong>
              <span style="font-size:0.75rem; margin-left:0.25rem;">@mock_user Thanks for commenting! Try typing "GUIDE" or "CRM" to trigger.</span>
            </div>
          `;
          threadBox.appendChild(replyDiv);
          logInteraction(commentText, 'Comment Reply Fallback', 'success');
        }
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
      }, Math.max(delayMs, 700));
    }

    function logInteraction(triggerText, actionName, statusText) {
      const logs = getLogs();
      const newLog = {
        user: '@mock_user',
        initials: 'MU',
        trigger: triggerText.substring(0, 15).toUpperCase(),
        action: actionName,
        time: 'Just now',
        status: statusText
      };
      saveLogs([newLog, ...logs]);
      renderLogsTable();
    }

    function escapeHTML(str) {
      return str.replace(/[&<>'"]/g, 
        tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
      );
    }

    // Theme Toggle logic for DM Automation
    const toggleBtn = document.getElementById("theme-toggle");
    toggleBtn.addEventListener("click", () => {
      document.body.classList.toggle("dark-mode");
      if (document.body.classList.contains("dark-mode")) {
        localStorage.setItem("theme", "dark");
        toggleBtn.innerText = "☀️";
      } else {
        localStorage.setItem("theme", "light");
        toggleBtn.innerText = "🌙";
      }
    });

    window.addEventListener("DOMContentLoaded", () => {
      const savedTheme = localStorage.getItem("theme");
      if (savedTheme === "dark") {
        document.body.classList.add("dark-mode");
        toggleBtn.innerText = "☀️";
      } else {
        document.body.classList.remove("dark-mode");
        toggleBtn.innerText = "🌙";
      }
      
      // Init page state
      updateDashboardUI();
    });
  </script>
    <%- include('partials/layout/scripts') %>
</body>
</html>
