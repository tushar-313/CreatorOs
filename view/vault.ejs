<!DOCTYPE html>
<html lang="en">
<head>

  <!-- SEO meta tags -->
  <%- include('./partials/_seo', {
    title: 'Vault',
    description: 'CreatorOS vault.',
    canonical: 'https://creatoros.com/vault',
    robots: 'noindex,nofollow'
  }) %>
  
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <%- include('./partials/_brand_head') %>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F5F1EA;
      --bg-secondary: #EFE8DC;
      --card-bg: #FFFFFF;
      --text: #111111;
      --border: #111111;
      --accent-teal: #37D6C8;
      --accent-blue: #76A9FA;
      --accent-yellow: #E4C13B;
      --accent-red: #E13B3B;
      --muted: #666;
      --muted-2: #999;
      --sidebar-width: 220px;
      --border-thick: 2px solid #111;
      --shadow-retro: 3px 3px 0px #111;
      --shadow-retro-hover: 5px 5px 0px #111;
      --shadow-retro-btn: 2px 2px 0px #111;
    }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    a { text-decoration: none; color: inherit; }

    /* ── LAYOUT ── */
    .layout {
      display: grid;
      grid-template-columns: var(--sidebar-width) 1fr;
      min-height: 100vh;
    }

    /* ── SIDEBAR ── */
    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      background: var(--bg-secondary);
      border-right: var(--border-thick);
      display: flex;
      flex-direction: column;
      padding: 1.25rem 0.85rem;
      overflow-y: auto;
    }

    .brand {
      font-size: 1.2rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      padding-bottom: 1.25rem;
      border-bottom: var(--border-thick);
      margin-bottom: 1.25rem;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      padding: 0.6rem 0.75rem;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--muted);
      border: 2px solid transparent;
      cursor: pointer;
      transition: all 0.15s ease;
      border-radius: 0;
    }
    .nav-item:hover {
      background: rgba(0,0,0,0.04);
      border-color: var(--border);
      color: var(--text);
    }
    .nav-item.active {
      background: var(--accent-teal);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro-btn);
      color: #111;
      font-weight: 700;
    }
    .nav-item svg {
      width: 16px; height: 16px;
      flex-shrink: 0; fill: none;
      stroke: currentColor; stroke-width: 2;
    }

    .sidebar-spacer { flex: 1; }

    /* Storage bar */
    .storage-box {
      background: var(--accent-yellow);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro-btn);
      padding: 0.75rem;
      margin-bottom: 0.65rem;
    }
    .storage-label {
      font-size: 0.65rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #333;
      margin-bottom: 0.5rem;
    }
    .storage-bar-bg {
      height: 8px;
      background: rgba(0,0,0,0.15);
      border: 1px solid #111;
      margin-bottom: 0.4rem;
    }
    .storage-bar {
      height: 100%;
      background: #111;
      width: 75%;
    }
    .storage-text {
      font-size: 0.72rem;
      font-weight: 600;
      color: #333;
    }

    .support-link {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.75rem;
      font-size: 0.8rem;
      color: var(--muted);
      cursor: pointer;
    }
    .support-link svg { width: 15px; height: 15px; fill: none; stroke: currentColor; stroke-width: 2; }
    .support-link:hover { color: var(--text); }

    /* ── MAIN ── */
    .main { display: flex; flex-direction: column; min-height: 100vh; }

    /* ── TOPBAR ── */
    .topbar {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.8rem 1.5rem;
      border-bottom: var(--border-thick);
      background: var(--bg);
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .topbar-nav {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }
    .topbar-nav-link {
      padding: 0.3rem 0.75rem;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--muted);
      border: 2px solid transparent;
      transition: all 0.15s;
    }
    .topbar-nav-link:hover { color: var(--text); }
    .topbar-nav-link.active {
      color: var(--text);
      border-bottom: 2px solid var(--text);
    }

    .search-wrap {
      position: relative;
      flex: 1;
      max-width: 240px;
    }
    .search-wrap svg {
      position: absolute; left: 0.65rem; top: 50%;
      transform: translateY(-50%);
      width: 14px; height: 14px;
      stroke: #aaa; fill: none; stroke-width: 2;
    }
    .search-input {
      width: 100%;
      padding: 0.45rem 0.75rem 0.45rem 2rem;
      border: var(--border-thick);
      background: var(--card-bg);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.85rem;
      outline: none;
      color: var(--text);
    }
    .search-input::placeholder { color: #bbb; }
    .search-input:focus { box-shadow: var(--shadow-retro-btn); }

    .topbar-actions { display: flex; align-items: center; gap: 0.65rem; margin-left: auto; }

    .icon-btn {
      width: 2.1rem; height: 2.1rem;
      display: grid; place-items: center;
      border: var(--border-thick);
      background: var(--card-bg);
      cursor: pointer;
      box-shadow: var(--shadow-retro-btn);
      color: var(--text);
      transition: all 0.15s;
    }
    .icon-btn svg { width: 15px; height: 15px; fill: none; stroke: currentColor; stroke-width: 2; }
    .icon-btn:hover { transform: translate(-1px,-1px); box-shadow: var(--shadow-retro); }

    .new-project-btn {
      padding: 0.48rem 1rem;
      background: var(--accent-teal);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro-btn);
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 0.875rem;
      cursor: pointer;
      color: #111;
      transition: all 0.15s;
    }
    .new-project-btn:hover { transform: translate(-2px,-2px); box-shadow: var(--shadow-retro); }
    .new-project-btn:active { transform: translate(1px,1px); box-shadow: 1px 1px 0 #111; }

    /* ── CONTENT ── */
    .content { padding: 1.75rem 1.75rem; display: flex; flex-direction: column; gap: 1.5rem; }

    /* Page heading */
    .page-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .page-label {
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent-teal);
      margin-bottom: 0.35rem;
    }

    .page-title {
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.1;
    }

    .view-controls {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .view-btn {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 0.85rem;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      border: var(--border-thick);
      background: var(--card-bg);
      cursor: pointer;
      box-shadow: var(--shadow-retro-btn);
      transition: all 0.15s;
      color: var(--text);
    }
    .view-btn svg { width: 14px; height: 14px; fill: none; stroke: currentColor; stroke-width: 2; }
    .view-btn.active { background: var(--text); color: #fff; }
    .view-btn:hover:not(.active) { transform: translate(-1px,-1px); box-shadow: var(--shadow-retro); }

    .filter-btn {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 0.85rem;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      border: var(--border-thick);
      background: var(--accent-blue);
      cursor: pointer;
      box-shadow: var(--shadow-retro-btn);
      color: #111;
      transition: all 0.15s;
    }
    .filter-btn svg { width: 14px; height: 14px; fill: none; stroke: currentColor; stroke-width: 2; }
    .filter-btn:hover { transform: translate(-1px,-1px); box-shadow: var(--shadow-retro); }

    /* ── UPLOAD ZONE ── */
    .upload-zone {
      border: 2px dashed #111;
      background: var(--bg-secondary);
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      cursor: pointer;
      transition: background 0.15s;
      position: relative;
    }
    .upload-zone:hover { background: #e8e0d0; }
    .upload-zone.dragover { background: #dff5f3; border-color: var(--accent-teal); }

    .upload-icon {
      width: 4rem; height: 4rem;
      background: var(--accent-teal);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro);
      display: grid;
      place-items: center;
    }
    .upload-icon svg { width: 24px; height: 24px; fill: none; stroke: #111; stroke-width: 2.5; }

    .upload-zone h3 { font-size: 1.3rem; font-weight: 800; }
    .upload-zone p  { font-size: 0.85rem; color: var(--muted); text-align: center; line-height: 1.5; }

    .browse-btn {
      padding: 0.6rem 1.35rem;
      background: var(--card-bg);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro-btn);
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 0.875rem;
      cursor: pointer;
      color: var(--text);
      margin-top: 0.5rem;
      transition: all 0.15s;
    }
    .browse-btn:hover { transform: translate(-2px,-2px); box-shadow: var(--shadow-retro); }

    /* hidden file input */
    #fileInput { display: none; }

    /* ── FILE GRID ── */
    .files-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
    }

    .file-card {
      border: var(--border-thick);
      box-shadow: var(--shadow-retro);
      background: var(--card-bg);
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      position: relative;
      overflow: hidden;
    }
    .file-card:hover {
      transform: translate(-2px,-2px);
      box-shadow: var(--shadow-retro-hover);
    }

    .file-thumb {
      width: 100%;
      height: 150px;
      background: #222;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    .file-thumb img {
      width: 100%; height: 100%;
      object-fit: cover;
      opacity: 0.85;
    }
    .file-thumb.doc-thumb  { background: var(--accent-yellow); }
    .file-thumb.img-thumb  { background: #1a1a2e; }
    .file-thumb.vid-thumb  { background: #111; }
    .file-thumb.zip-thumb  { background: #2d3748; }

    .file-thumb svg {
      width: 2.5rem; height: 2.5rem;
      fill: none; stroke: rgba(255,255,255,0.6); stroke-width: 1.5;
    }
    .file-thumb.doc-thumb svg { stroke: #111; opacity: 0.7; }

    .file-type-tag {
      position: absolute;
      top: 0.5rem; right: 0.5rem;
      font-size: 0.6rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.15rem 0.45rem;
      border: 1px solid rgba(255,255,255,0.4);
    }
    .tag-image { background: #1a1a2e; color: #76A9FA; }
    .tag-video { background: var(--accent-teal); color: #111; }
    .tag-doc   { background: #111; color: #fff; }

    .file-info {
      padding: 0.75rem;
      border-top: var(--border-thick);
      background: var(--card-bg);
    }
    .file-name {
      font-size: 0.85rem;
      font-weight: 700;
      color: #111;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      margin-bottom: 0.2rem;
    }
    .file-meta {
      font-size: 0.72rem;
      color: var(--muted-2);
      font-weight: 500;
    }

    .file-actions {
      display: flex;
      gap: 0.4rem;
      padding: 0.5rem 0.75rem;
      border-top: 1px solid #e2ddd6;
      background: var(--bg-secondary);
    }
    .file-action-btn {
      flex: 1;
      padding: 0.3rem;
      font-size: 0.7rem;
      font-weight: 700;
      border: 1px solid #111;
      background: var(--card-bg);
      cursor: pointer;
      font-family: 'Space Grotesk', sans-serif;
      transition: all 0.12s;
      color: var(--text);
      text-align: center;
    }
    .file-action-btn:hover { background: #111; color: #fff; }

    /* ── TOAST ── */
    .toast {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      background: #111;
      color: #fff;
      padding: 0.75rem 1.25rem;
      font-size: 0.85rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      border: var(--border-thick);
      box-shadow: var(--shadow-retro);
      transform: translateY(100px);
      opacity: 0;
      transition: all 0.3s ease;
      z-index: 100;
    }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast svg { width: 16px; height: 16px; fill: none; stroke: var(--accent-teal); stroke-width: 2.5; }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .files-grid { grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); }
    }

    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { display: none; }
      .content { padding: 1rem; }
      .topbar { padding: 0.75rem 1rem; }
      .page-title { font-size: 1.5rem; }
      .files-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
    }

    @media (max-width: 480px) {
      .files-grid { grid-template-columns: 1fr 1fr; }
      .view-controls { flex-wrap: wrap; }
    }
  </style>
</head>
<body>
<div class="layout">

  <%- include('partials/layout/sidebar', { activeNav: 'vault' }) %>

  <!-- MAIN -->
  <div class="main">

    <%- include('partials/layout/topbar', { user: typeof user !== 'undefined' ? user : { initials: 'U', name: 'User' } }) %>

    <!-- CONTENT -->
    <section class="content">

      <!-- PAGE HEADING -->
      <div class="page-head">
        <div>
          <div class="page-label">Central Repository</div>
          <h1 class="page-title">File Upload Vault</h1>
        </div>
        <div class="view-controls">
          <button class="view-btn active" id="gridBtn" onclick="setView('grid')">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            Grid
          </button>
          <button class="view-btn" id="listBtn" onclick="setView('list')">
            <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            List
          </button>
          <button class="filter-btn">
            <svg viewBox="0 0 24 24"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
            Filters
          </button>
        </div>
      </div>

      <!-- UPLOAD ZONE -->
      <div class="upload-zone" id="uploadZone">
        <input type="file" id="fileInput" multiple accept="image/*,video/*,.pdf,.zip,.doc,.docx" />
        <div class="upload-icon">
          <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        </div>
        <h3>Drop your files here</h3>
        <p>Upload assets up to 500MB each. Support for JPG,<br>PNG, MP4, PDF, and ZIP archives.</p>
        <button class="browse-btn" onclick="document.getElementById('fileInput').click()">Browse Local Files</button>
      </div>

      <!-- FILES GRID -->
      <div class="files-grid" id="filesGrid">

        <!-- Card 1 - Image -->
        <div class="file-card">
          <div class="file-thumb img-thumb">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <span class="file-type-tag tag-image">IMAGE</span>
          </div>
          <div class="file-info">
            <div class="file-name">Hero_Concept_...</div>
            <div class="file-meta">2.4 MB · Updated 2h ago</div>
          </div>
          <div class="file-actions">
            <button class="file-action-btn" onclick="copyLink('Hero_Concept')">Copy Link</button>
            <button class="file-action-btn">Download</button>
          </div>
        </div>

        <!-- Card 2 - Video -->
        <div class="file-card">
          <div class="file-thumb vid-thumb">
            <svg viewBox="0 0 24 24"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
            <span class="file-type-tag tag-video">VIDEO</span>
          </div>
          <div class="file-info">
            <div class="file-name">Promo_Final_v...</div>
            <div class="file-meta">128.5 MB · Updated 5h ago</div>
          </div>
          <div class="file-actions">
            <button class="file-action-btn" onclick="copyLink('Promo_Final')">Copy Link</button>
            <button class="file-action-btn">Download</button>
          </div>
        </div>

        <!-- Card 3 - Doc -->
        <div class="file-card">
          <div class="file-thumb doc-thumb">
            <svg viewBox="0 0 24 24" style="stroke:#333;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            <span class="file-type-tag tag-doc">DOC</span>
          </div>
          <div class="file-info">
            <div class="file-name">Brand_Guidelin...</div>
            <div class="file-meta">12.2 MB · Updated yesterday</div>
          </div>
          <div class="file-actions">
            <button class="file-action-btn" onclick="copyLink('Brand_Guidelines')">Copy Link</button>
            <button class="file-action-btn">Download</button>
          </div>
        </div>

        <!-- Card 4 - Image -->
        <div class="file-card">
          <div class="file-thumb img-thumb" style="background:#1a1a1a;">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <span class="file-type-tag tag-image">IMAGE</span>
          </div>
          <div class="file-info">
            <div class="file-name">Studio_Interior...</div>
            <div class="file-meta">4.8 MB · Updated 1w ago</div>
          </div>
          <div class="file-actions">
            <button class="file-action-btn" onclick="copyLink('Studio_Interior')">Copy Link</button>
            <button class="file-action-btn">Download</button>
          </div>
        </div>

      </div><!-- /files-grid -->

    </section>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast">
  <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
  <span id="toastMsg">Link copied to clipboard!</span>
</div>

<script nonce="<%= nonce %>">
  // Drag & drop
  const uploadZone = document.getElementById('uploadZone');
  const fileInput  = document.getElementById('fileInput');

  uploadZone.addEventListener('dragover', e => {
    e.preventDefault();
    uploadZone.classList.add('dragover');
  });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
  uploadZone.addEventListener('drop', e => {
    e.preventDefault();
    uploadZone.classList.remove('dragover');
    const files = e.dataTransfer.files;
    if (files.length) handleFiles(files);
  });

  fileInput.addEventListener('change', () => handleFiles(fileInput.files));

  function handleFiles(files) {
    showToast(`${files.length} file(s) ready to upload`);
  }

  // View toggle
  function setView(mode) {
    const grid = document.getElementById('filesGrid');
    const gridBtn = document.getElementById('gridBtn');
    const listBtn = document.getElementById('listBtn');

    if (mode === 'list') {
      grid.style.gridTemplateColumns = '1fr';
      listBtn.classList.add('active');
      gridBtn.classList.remove('active');
    } else {
      grid.style.gridTemplateColumns = '';
      gridBtn.classList.add('active');
      listBtn.classList.remove('active');
    }
  }

  // Search filter
  document.getElementById('searchInput').addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('.file-card').forEach(card => {
      const name = card.querySelector('.file-name').textContent.toLowerCase();
      card.style.display = name.includes(q) ? '' : 'none';
    });
  });

  // Copy link toast
  function copyLink(filename) {
    navigator.clipboard.writeText(`https://creatoros.link/vault/${filename}`).catch(() => {});
    showToast('Link copied to clipboard!');
  }

  // Toast
  function showToast(msg) {
    const toast = document.getElementById('toast');
    document.getElementById('toastMsg').textContent = msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2500);
  }
</script>
    <%- include('partials/layout/scripts') %>
</body>
</html>