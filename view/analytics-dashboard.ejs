<%- include('partials/layout/header', {
    activeNav: 'analytics',
    title: 'Analytics Dashboard',
    
    
    extraHead: '<link rel="stylesheet" href="/css/analytics.css">'
}) %>

            <section class="content">
                <!-- Dashboard Head -->
                <div class="dashboard-head">
                    <div>
                        <h1>Analytics Overview</h1>
                        <p>Track your audience growth and content performance.</p>
                    </div>
                </div>

                <!-- Stats Grid -->
                <div class="stats-grid">
                    <% analytics.metrics.forEach((metric, index) => { %>
                        <article class="stat-card-retro <%= index === 0 ? 'accent-blue' : '' %>">
                            <span class="label"><%= metric.label %></span>
                            <span class="card-id">METRIC_0<%= index + 1 %></span>
                            <span class="value"><%= metric.value %></span>
                            <span class="subtext"><span class="trend"><%= metric.change %></span></span>
                        </article>
                    <% }) %>
                </div>

                <div class="analytics-grid" style="margin-top: 1.5rem;">
                    <!-- Analytics Graph -->
                    <section class="panel-retro">
                        <div class="panel-retro-title-row">
                            <h2>Audience Growth</h2>
                            <select class="badge-retro" style="cursor:pointer; border:2px solid var(--black); background:var(--white); padding:0.25rem; font-family:'Space Grotesk', monospace;">
                                <option>Last 7 Days</option>
                                <option>Last 30 Days</option>
                                <option>Last 90 Days</option>
                            </select>
                        </div>
                        <div class="chart-wrap" style="height:320px; position:relative;">
                            <canvas id="followersChart"></canvas>
                        </div>
                    </section>

                    <section class="panel-retro">
                        <div class="panel-retro-title-row">
                            <h2>Engagement Rate</h2>
                        </div>
                        <div class="chart-wrap" style="height:320px; position:relative;">
                            <canvas id="engagementChart"></canvas>
                        </div>
                    </section>
                </div>

                <!-- Top Posts -->
                <section class="panel-retro" style="margin-top: 1.5rem;">
                    <div class="panel-retro-title-row">
                        <h2>Top Performing Content</h2>
                        <span class="badge-retro">Recent</span>
                    </div>
                    <div class="table-panel-retro">
                        <div class="table-scroll">
                            <table class="recent-links-table">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Type</th>
                                        <th>Date</th>
                                        <th>Likes</th>
                                        <th>Comments</th>
                                        <th>Engagement</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% analytics.topPosts.forEach(post => { %>
                                        <tr>
                                            <td style="font-weight: 700;"><%= post.title %></td>
                                            <td><span class="badge-retro" style="background:var(--accent-yellow);"><%= post.type %></span></td>
                                            <td><%= post.date %></td>
                                            <td><%= post.likes %></td>
                                            <td><%= post.comments %></td>
                                            <td class="short-url"><%= post.engagement %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>
            </section>
        

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const sidebarToggle = document.getElementById('sidebarToggle');
        const dashboardLayout = document.getElementById('dashboardLayout');
        

        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                dashboardLayout.classList.toggle('sidebar-collapsed');
            });
        }

        const themeBtn = document.getElementById('theme-toggle');
        const root = document.documentElement;
        const iconLight = themeBtn ? themeBtn.querySelector('.icon-light') : null;
        const iconDark = themeBtn ? themeBtn.querySelector('.icon-dark') : null;
        
        function applyTheme(isDark) {
            if (isDark) {
                root.setAttribute('data-theme', 'dark');
                if (iconLight) iconLight.style.display = 'none';
                if (iconDark) iconDark.style.display = 'block';
            } else {
                root.removeAttribute('data-theme');
                if (iconLight) iconLight.style.display = 'block';
                if (iconDark) iconDark.style.display = 'none';
            }
        }

        if (themeBtn) {
            if (localStorage.getItem('theme') === 'dark') {
                applyTheme(true);
            } else {
                applyTheme(false);
            }

            themeBtn.addEventListener('click', () => {
                const isDark = root.getAttribute('data-theme') === 'dark';
                applyTheme(!isDark);
                localStorage.setItem('theme', !isDark ? 'dark' : 'light');
                window.dispatchEvent(new Event('themeChanged'));
            });
        }

        // Chart.js Setup
        const chartGrid = getComputedStyle(document.documentElement).getPropertyValue('--chart-grid-color') || 'rgba(0,0,0,0.1)';
        const textColor = getComputedStyle(document.documentElement).getPropertyValue('--text') || '#111';
        const accentTeal = '#37D6C8';
        const accentBlue = '#76A9FA';
        
        Chart.defaults.color = textColor;
        Chart.defaults.font.family = "'Space Grotesk', monospace";

        const followersCtx = document.getElementById('followersChart');
        if (followersCtx) {
            window.followersChart = new Chart(followersCtx, {
                type: 'line',
                data: {
                    labels: <%- JSON.stringify(analytics.charts.labels) %>,
                    datasets: [{
                        label: 'Followers',
                        data: <%- JSON.stringify(analytics.charts.followers) %>,
                        borderColor: accentTeal,
                        backgroundColor: 'rgba(55, 214, 200, 0.1)',
                        borderWidth: 3,
                        pointBackgroundColor: accentTeal,
                        pointBorderColor: getComputedStyle(document.documentElement).getPropertyValue('--text').trim() || '#111',
                        pointBorderWidth: 2,
                        pointRadius: 5,
                        fill: true,
                        tension: 0.1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { color: chartGrid, drawBorder: false } },
                        y: { grid: { color: chartGrid, drawBorder: false } }
                    }
                }
            });
        }

        const engagementCtx = document.getElementById('engagementChart');
        if (engagementCtx) {
            window.engagementChart = new Chart(engagementCtx, {
                type: 'line',
                data: {
                    labels: <%- JSON.stringify(analytics.charts.labels) %>,
                    datasets: [{
                        label: 'Engagement (%)',
                        data: <%- JSON.stringify(analytics.charts.engagement) %>,
                        borderColor: accentBlue,
                        backgroundColor: 'rgba(118, 169, 250, 0.1)',
                        borderWidth: 3,
                        pointBackgroundColor: accentBlue,
                        pointBorderColor: getComputedStyle(document.documentElement).getPropertyValue('--text').trim() || '#111',
                        pointBorderWidth: 2,
                        pointRadius: 5,
                        fill: true,
                        tension: 0.1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { color: chartGrid, drawBorder: false } },
                        y: { grid: { color: chartGrid, drawBorder: false } }
                    }
                }
            });
        }
    </script>
    <script>
        window.addEventListener('themeChanged', () => {
            const newGrid = getComputedStyle(document.documentElement).getPropertyValue('--chart-grid-color').trim() || 'rgba(0,0,0,0.1)';
            const newText = getComputedStyle(document.documentElement).getPropertyValue('--text').trim() || '#111';
            
            Chart.defaults.color = newText;
            
            const charts = [window.followersChart, window.engagementChart, window.perfChart].filter(Boolean);
            charts.forEach(chart => {
                if (chart.options.scales.x) chart.options.scales.x.grid.color = newGrid;
                if (chart.options.scales.y) chart.options.scales.y.grid.color = newGrid;
                
                chart.data.datasets.forEach(dataset => {
                    if (dataset.pointBorderColor) dataset.pointBorderColor = newText;
                });
                
                chart.update();
            });
        });
</script>

    


<%- include('partials/layout/footer') %>
