<!DOCTYPE html>
<html lang="en">
<head>

  <!-- SEO meta tags -->
  <%- include('./partials/_seo', {
    title: 'Analytics',
    description: 'Creator analytics dashboard.',
    canonical: 'https://creatoros.com/analytics',
    robots: 'noindex,nofollow'
  }) %>
  
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <%- include('./partials/_brand_head') %>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F5F1EA;
      --bg-secondary: #EFE8DC;
      --card-bg: #FFFFFF;
      --text: #111111;
      --border: #111111;
      --accent-teal: #37D6C8;
      --accent-blue: #76A9FA;
      --accent-yellow: #E4C13B;
      --accent-red: #E13B3B;
      --success: #2BB673;
      --muted: #555;
      --muted-2: #888;
      --sidebar-width: 260px;
      --border-thick: 2px solid #111;
      --shadow-retro: 3px 3px 0px #111;
      --shadow-retro-hover: 5px 5px 0px #111;
      --shadow-retro-btn: 2px 2px 0px #111;
    }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    a { text-decoration: none; color: inherit; }

    /* ── LAYOUT ── */
    .layout {
      display: grid;
      grid-template-columns: var(--sidebar-width) 1fr;
      min-height: 100vh;
    }

    /* ── SIDEBAR ── */
    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      background: var(--bg-secondary);
      border-right: var(--border-thick);
      display: flex;
      flex-direction: column;
      padding: 1.5rem 1rem;
      overflow-y: auto;
    }

    .brand {
      display: flex;
      flex-direction: column;
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: var(--border-thick);
    }
    .brand h1 { font-size: 1.2rem; font-weight: 800; letter-spacing: -0.02em; }
    .brand .beta { font-size: 0.7rem; color: var(--muted-2); }

    .sidebar-label {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted-2);
      padding: 0 0.5rem;
      margin-bottom: 0.4rem;
      margin-top: 1rem;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      padding: 0.65rem 0.75rem;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--muted);
      border: 2px solid transparent;
      cursor: pointer;
      transition: all 0.15s ease;
    }
    .nav-item:hover {
      background: rgba(0,0,0,0.04);
      border-color: var(--border);
      color: var(--text);
    }
    .nav-item.active {
      background: var(--accent-teal);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro-btn);
      color: #111;
      font-weight: 700;
    }
    .nav-item svg { width: 16px; height: 16px; flex-shrink: 0; fill: none; stroke: currentColor; stroke-width: 2; }

    .sidebar-spacer { flex: 1; }

    .upgrade-box {
      background: var(--accent-yellow);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro-btn);
      padding: 0.85rem;
      margin-bottom: 0.65rem;
    }
    .upgrade-box button {
      width: 100%;
      background: var(--accent-blue);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro-btn);
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 0.85rem;
      padding: 0.5rem;
      cursor: pointer;
      color: #111;
    }
    .upgrade-box button:hover { transform: translate(-1px,-1px); box-shadow: var(--shadow-retro); }

    /* ── MAIN ── */
    .main { display: flex; flex-direction: column; min-height: 100vh; }

    /* ── TOPBAR ── */
    .topbar {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.85rem 1.5rem;
      border-bottom: var(--border-thick);
      background: var(--bg);
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .topbar h2 { font-size: 1.3rem; font-weight: 800; }

    .search-wrap {
      position: relative;
      flex: 1;
      max-width: 260px;
    }
    .search-wrap svg {
      position: absolute; left: 0.65rem; top: 50%;
      transform: translateY(-50%);
      width: 14px; height: 14px; stroke: #aaa; fill: none;
    }
    .search-input {
      width: 100%;
      padding: 0.5rem 0.75rem 0.5rem 2rem;
      border: var(--border-thick);
      background: var(--card-bg);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.85rem;
      outline: none;
      color: var(--text);
    }
    .search-input:focus { box-shadow: var(--shadow-retro-btn); }
    .search-input::placeholder { color: #bbb; }

    .topbar-actions { display: flex; align-items: center; gap: 0.65rem; margin-left: auto; }

    .icon-btn {
      width: 2.2rem; height: 2.2rem;
      display: grid; place-items: center;
      border: var(--border-thick);
      background: var(--card-bg);
      cursor: pointer;
      box-shadow: var(--shadow-retro-btn);
      color: var(--text);
    }
    .icon-btn svg { width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 2; }
    .icon-btn:hover { transform: translate(-1px,-1px); box-shadow: var(--shadow-retro); }

    .export-btn {
      padding: 0.5rem 1.1rem;
      background: var(--accent-teal);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro-btn);
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 0.875rem;
      cursor: pointer;
      color: #111;
      transition: all 0.15s ease;
    }
    .export-btn:hover { transform: translate(-2px,-2px); box-shadow: var(--shadow-retro); }
    .export-btn:active { transform: translate(1px,1px); box-shadow: 1px 1px 0 #111; }

    /* ── CONTENT ── */
    .content { padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; }

    /* ── STAT CARDS ROW ── */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      border: var(--border-thick);
      box-shadow: var(--shadow-retro);
    }

    .stat-card {
      padding: 1rem 1.25rem;
      border-right: var(--border-thick);
      background: var(--card-bg);
      position: relative;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .stat-card:last-child { border-right: none; }
    .stat-card:hover { background: #f9f9f9; }

    .stat-card.yellow { background: var(--accent-yellow); }
    .stat-card.blue   { background: var(--accent-blue); }

    .stat-tag {
      position: absolute;
      top: 0.6rem; right: 0.6rem;
      font-size: 0.6rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      background: #111;
      color: #fff;
      padding: 0.15rem 0.4rem;
    }

    .stat-label {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted-2);
      margin-bottom: 0.5rem;
    }
    .stat-card.yellow .stat-label,
    .stat-card.blue .stat-label { color: #333; }

    .stat-value {
      font-size: 2.4rem;
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.03em;
      color: var(--text);
    }

    .stat-delta {
      font-size: 0.72rem;
      font-weight: 700;
      margin-left: 0.3rem;
      vertical-align: super;
    }
    .delta-up   { color: var(--success); }
    .delta-down { color: var(--accent-red); }

    /* ── MID SECTION ── */
    .mid-section {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 1.25rem;
    }

    /* Engagement chart panel */
    .chart-panel {
      background: var(--card-bg);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .chart-panel-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
    }

    .chart-panel h2 { font-size: 1.4rem; font-weight: 800; line-height: 1.2; }
    .chart-panel p  { font-size: 0.8rem; color: var(--muted-2); margin-top: 0.25rem; }

    .period-tabs {
      display: flex;
      border: var(--border-thick);
    }
    .period-tab {
      padding: 0.3rem 0.65rem;
      font-size: 0.78rem;
      font-weight: 700;
      border: none;
      border-right: var(--border-thick);
      background: var(--card-bg);
      cursor: pointer;
      font-family: 'Space Grotesk', sans-serif;
      color: var(--text);
    }
    .period-tab:last-child { border-right: none; }
    .period-tab.active { background: #111; color: #fff; }
    .period-tab:hover:not(.active) { background: var(--bg); }

    .chart-wrap { height: 260px; position: relative; }

    /* Top Modules panel */
    .modules-panel {
      background: var(--accent-blue);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro);
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .modules-panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .modules-panel h2 { font-size: 1.1rem; font-weight: 800; color: #111; }
    .modules-trend {
      background: #111;
      color: #fff;
      padding: 0.2rem 0.5rem;
      font-size: 0.75rem;
      font-weight: 700;
    }

    .module-row { display: flex; flex-direction: column; gap: 0.25rem; }
    .module-label-row {
      display: flex;
      justify-content: space-between;
      font-size: 0.78rem;
      font-weight: 600;
      color: #222;
    }
    .module-bar-bg {
      height: 8px;
      background: rgba(255,255,255,0.4);
      border: 1px solid #111;
    }
    .module-bar {
      height: 100%;
      background: var(--accent-teal);
      border-right: 1px solid #111;
    }

    .view-full-btn {
      width: 100%;
      padding: 0.65rem;
      background: var(--card-bg);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro-btn);
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 0.8rem;
      cursor: pointer;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-top: auto;
      transition: all 0.15s ease;
    }
    .view-full-btn:hover { transform: translate(-1px,-1px); box-shadow: var(--shadow-retro); }

    /* ── GLOBAL REACH ── */
    .reach-panel {
      background: var(--card-bg);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro);
      display: grid;
      grid-template-columns: 1fr 1.4fr;
    }

    .reach-left { padding: 1.5rem; border-right: var(--border-thick); }
    .reach-left h2 { font-size: 1.4rem; font-weight: 800; margin-bottom: 0.25rem; }
    .reach-left p  { font-size: 0.8rem; color: var(--muted-2); margin-bottom: 1.25rem; }

    .country-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.6rem 0;
      border-bottom: 1px solid #e2ddd6;
      font-size: 0.875rem;
    }
    .country-row:last-child { border-bottom: none; }

    .country-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      margin-right: 0.5rem;
      flex-shrink: 0;
    }
    .country-name { display: flex; align-items: center; font-weight: 600; }
    .country-pct  { font-weight: 800; color: var(--accent-teal); }

    .reach-map {
      position: relative;
      background: #f0ebe3;
      border-left: none;
      overflow: hidden;
      min-height: 260px;
    }
    .reach-map img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.6;
      filter: grayscale(30%);
    }
    .map-placeholder {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.8rem; color: var(--muted-2);
      flex-direction: column; gap: 0.5rem;
    }

    .map-dot {
      position: absolute;
      border-radius: 50%;
      border: 2px solid #111;
      transform: translate(-50%, -50%);
    }

    .map-controls {
      position: absolute;
      bottom: 0.75rem;
      right: 0.75rem;
      display: flex;
      flex-direction: column;
      border: var(--border-thick);
      background: var(--card-bg);
    }
    .map-ctrl-btn {
      width: 1.8rem; height: 1.8rem;
      display: grid; place-items: center;
      border: none; border-bottom: var(--border-thick);
      background: var(--card-bg);
      cursor: pointer;
      font-size: 1rem; font-weight: 700;
    }
    .map-ctrl-btn:last-child { border-bottom: none; }
    .map-ctrl-btn:hover { background: var(--bg); }

    /* ── REAL-TIME INSIGHTS ── */
    .insights-panel {
      background: var(--card-bg);
      border: var(--border-thick);
      box-shadow: var(--shadow-retro);
      overflow: hidden;
    }

    .insights-head {
      padding: 1rem 1.5rem;
      border-bottom: var(--border-thick);
      background: var(--bg-secondary);
    }
    .insights-head h2 { font-size: 1.2rem; font-weight: 800; }

    .insights-table {
      width: 100%;
      border-collapse: collapse;
    }
    .insights-table th {
      text-align: left;
      padding: 0.65rem 1.5rem;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted-2);
      border-bottom: var(--border-thick);
      background: var(--bg);
    }
    .insights-table td {
      padding: 0.9rem 1.5rem;
      font-size: 0.875rem;
      border-bottom: 1px solid #e2ddd6;
      color: var(--text);
    }
    .insights-table tr:last-child td { border-bottom: none; }
    .insights-table tbody tr:hover { background: rgba(0,0,0,0.02); }

    .event-link {
      font-weight: 700;
      text-decoration: underline;
      text-underline-offset: 2px;
      color: #111;
    }

    .status-badge {
      display: inline-flex;
      padding: 0.2rem 0.55rem;
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      border: var(--border-thick);
    }
    .badge-success { background: var(--accent-teal); color: #111; }
    .badge-pending { background: var(--accent-yellow); color: #111; }
    .badge-error   { background: var(--accent-red); color: #fff; }
   
  </style>
</head>
<body>
<div class="layout">

  <%- include('partials/layout/sidebar', { activeNav: 'analytics' }) %>

  <!-- MAIN -->
  <div class="main">

    <%- include('partials/layout/topbar', { user: typeof user !== 'undefined' ? user : { initials: 'U', name: 'User' } }) %>

    <!-- CONTENT -->
    <section class="content">

      <!-- STAT CARDS -->
      <div class="stats-row">
        <div class="stat-card">
          <span class="stat-tag">TOTAL_VIEWS</span>
          <div class="stat-label">Total Views</div>
          <div class="stat-value">142.8k</div>
        </div>
        <div class="stat-card">
          <span class="stat-tag">CONV_RATE</span>
          <div class="stat-label">Conversion</div>
          <div class="stat-value">4.2%<span class="stat-delta delta-up">+0.8%</span></div>
        </div>
        <div class="stat-card">
          <span class="stat-tag">AVG_ENGAGEMENT</span>
          <div class="stat-label">Avg Time</div>
          <div class="stat-value">2:45<span class="stat-delta delta-down">-15s</span></div>
        </div>
        <div class="stat-card yellow">
          <span class="stat-tag">CLICK_THRU</span>
          <div class="stat-label">CTR</div>
          <div class="stat-value">18.5%<span class="stat-delta delta-up">+2.1%</span></div>
        </div>
      </div>

      <!-- MID: CHART + MODULES -->
      <div class="mid-section">

        <!-- Engagement Chart -->
        <div class="chart-panel">
          <div class="chart-panel-head">
            <div>
              <h2>Engagement Over<br>Time</h2>
              <p>Daily user interaction across all modules</p>
            </div>
            <div class="period-tabs">
              <button class="period-tab active" onclick="setPeriod(this,'7d')">7D</button>
              <button class="period-tab" onclick="setPeriod(this,'30d')">30D</button>
              <button class="period-tab" onclick="setPeriod(this,'90d')">90D</button>
            </div>
          </div>
          <div class="chart-wrap">
            <canvas id="engagementChart"></canvas>
          </div>
        </div>

        <!-- Top Modules -->
        <div class="modules-panel">
          <div class="modules-panel-head">
            <h2>Top Modules</h2>
            <span class="modules-trend">↗</span>
          </div>

          <div class="module-row">
            <div class="module-label-row"><span>Link Optimizer</span><span>84%</span></div>
            <div class="module-bar-bg"><div class="module-bar" style="width:84%"></div></div>
          </div>
          <div class="module-row">
            <div class="module-label-row"><span>Audience Insights</span><span>62%</span></div>
            <div class="module-bar-bg"><div class="module-bar" style="width:62%"></div></div>
          </div>
          <div class="module-row">
            <div class="module-label-row"><span>Revenue Track</span><span>45%</span></div>
            <div class="module-bar-bg"><div class="module-bar" style="width:45%"></div></div>
          </div>
          <div class="module-row">
            <div class="module-label-row"><span>Bio Builder</span><span>38%</span></div>
            <div class="module-bar-bg"><div class="module-bar" style="width:38%"></div></div>
          </div>

          <button class="view-full-btn">View Full Report</button>
        </div>
      </div>

      <!-- GLOBAL REACH -->
      <div class="reach-panel">
        <div class="reach-left">
          <h2>Global Reach</h2>
          <p>Where your audience is clicking from around the world.</p>

          <div class="country-row">
            <span class="country-name"><span class="country-dot" style="background:#37D6C8;"></span>United States</span>
            <span class="country-pct">42%</span>
          </div>
          <div class="country-row">
            <span class="country-name"><span class="country-dot" style="background:#4fb8c0;"></span>United Kingdom</span>
            <span class="country-pct">18%</span>
          </div>
          <div class="country-row">
            <span class="country-name"><span class="country-dot" style="background:#a8d8db;"></span>Germany</span>
            <span class="country-pct">12%</span>
          </div>
          <div class="country-row">
            <span class="country-name"><span class="country-dot" style="background:#b5882a;"></span>India</span>
            <span class="country-pct">9%</span>
          </div>
        </div>

        <div class="reach-map">
  <div id="map" style="width:100%; height:100%; min-height:280px;"></div>
</div>
          
      </div>

      <!-- REAL-TIME INSIGHTS -->
      <div class="insights-panel">
        <div class="insights-head">
          <h2>Real-Time Insights</h2>
        </div>
        <table class="insights-table">
          <thead>
            <tr>
              <th>Event</th>
              <th>Module</th>
              <th>Origin</th>
              <th>Time</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><span class="event-link">Click: Newsletter_v2</span></td>
              <td>Link Optimizer</td>
              <td>Direct / Mobile</td>
              <td>2m ago</td>
              <td><span class="status-badge badge-success">Success</span></td>
            </tr>
            <tr>
              <td><span class="event-link">View: Instagram_Bio</span></td>
              <td>Bio Builder</td>
              <td>Social / Web</td>
              <td>5m ago</td>
              <td><span class="status-badge badge-success">Success</span></td>
            </tr>
            <tr>
              <td><span class="event-link">Purchase: Pro_Plan</span></td>
              <td>Revenue Track</td>
              <td>Referral / Web</td>
              <td>14m ago</td>
              <td><span class="status-badge badge-pending">Pending</span></td>
            </tr>
          </tbody>
        </table>
      </div>

    </section>
  </div>
</div>

<script nonce="<%= nonce %>">
  // Engagement bar chart
  const ctx = document.getElementById('engagementChart');
  const engagementData = {
    '7d': {
      labels: ['MON','TUE','WED','THU','FRI','SAT','SUN'],
      data: [320, 280, 350, 420, 390, 310, 360]
    },
    '30d': {
      labels: ['W1','W2','W3','W4'],
      data: [1200, 1450, 1300, 1600]
    },
    '90d': {
      labels: ['Jan','Feb','Mar'],
      data: [4200, 5100, 4800]
    }
  };

  let chart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: engagementData['7d'].labels,
      datasets: [{
        data: engagementData['7d'].data,
        backgroundColor: '#37D6C8',
        borderColor: '#111',
        borderWidth: 2,
        borderRadius: 0,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: {
          grid: { color: '#e2ddd6' },
          border: { color: '#111' },
          ticks: { font: { family: 'Space Grotesk', weight: '700' }, color: '#888' }
        },
        y: {
          grid: { color: '#e2ddd6' },
          border: { color: '#111' },
          ticks: { font: { family: 'Space Grotesk', weight: '700' }, color: '#888' }
        }
      }
    }
  });

  function setPeriod(btn, period) {
    document.querySelectorAll('.period-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    chart.data.labels = engagementData[period].labels;
    chart.data.datasets[0].data = engagementData[period].data;
    chart.update();
  }
  // Leaflet Map
const map = L.map('map', {
  zoomControl: false,
  scrollWheelZoom: false
}).setView([20, 0], 2);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution: '© OpenStreetMap'
}).addTo(map);

// Custom teal circle marker
function makeMarker(lat, lng, size, color, label, pct) {
  return L.circleMarker([lat, lng], {
    radius: size,
    fillColor: color,
    color: '#111',
    weight: 2,
    fillOpacity: 0.85
  }).addTo(map).bindPopup(`<b>${label}</b><br>${pct}`);
}

// Hardcoded points — swap with real user data later
makeMarker(37.09,  -95.71, 18, '#37D6C8', 'United States', '42%');
makeMarker(55.37,  -3.43,  12, '#4fb8c0', 'United Kingdom', '18%');
makeMarker(51.16,  10.45,  10, '#a8d8db', 'Germany',        '12%');
makeMarker(20.59,  78.96,   9, '#b5882a', 'India',           '9%');

L.control.zoom({ position: 'bottomright' }).addTo(map);
</script>

