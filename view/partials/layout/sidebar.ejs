<style>
    .skip-link {
        position: absolute;
        top: 1rem;
        left: 1rem;
        z-index: 1000;
        padding: 0.75rem 1rem;
        border: 2px solid var(--border, #111);
        background: var(--card-bg, #fff);
        color: var(--text, #111);
        font-weight: 700;
        text-decoration: none;
        transform: translateY(-180%);
        transition: transform 0.2s ease;
        box-shadow: 2px 2px 0 var(--border, #111);
    }

    .skip-link:focus {
        transform: translateY(0);
        outline: 2px solid currentColor;
        outline-offset: 2px;
    }

    /* Hide the standalone icon when the sidebar is expanded (the full logo already includes it) */
    .dashboard-layout:not(.sidebar-collapsed) .brand-mark {
        display: none !important;
    }

</style>
