<style>



.footer {

  background: #f0ebe0;

  border-top: 2.5px solid #1a1a1a;

  font-family: 'DM Sans', sans-serif;

  color: #1a1a1a;

  overflow: hidden;

}



.footer-ticker {

  background: #1a1a1a;

  padding: 11px 0;

  overflow: hidden;

  border-bottom: 2.5px solid #1a1a1a;

}



.footer-ticker-inner {

  display: flex;

  white-space: nowrap;

  animation: ticker-scroll 20s linear infinite;

}



.footer-ticker-inner span {

  font-size: 11px;

  letter-spacing: 0.18em;

  font-weight: 600;

  color: #f0ebe0;

  padding: 0 28px;

}



.ticker-dot {

  color: #1aba9c !important;

}



@keyframes ticker-scroll {

  0%   { transform: translateX(0); }

  100% { transform: translateX(-50%); }

}



.footer-hero {

  padding: 72px 52px 64px;

  border-bottom: 2.5px solid #1a1a1a;

  display: flex;

  flex-direction: column;

  align-items: center;

  text-align: center;

}



.footer-badge {

  display: inline-flex;

  align-items: center;

  gap: 8px;

  border: 1.5px solid #1aba9c;

  border-radius: 100px;

  padding: 5px 16px;

  font-size: 11px;

  font-weight: 600;

  color: #1aba9c;

  letter-spacing: 0.06em;

  margin-bottom: 22px;

}



.badge-dot {

  width: 6px;

  height: 6px;

  background: #1aba9c;

  border-radius: 50%;

  display: inline-block;

}



.footer-headline {

  font-family: 'Playfair Display', 'Georgia', serif;

  font-size: clamp(38px, 5.5vw, 64px);

  font-weight: 900;

  line-height: 1.05;

  letter-spacing: -1.5px;

  margin: 0 0 36px;

  color: #1a1a1a;

}



.footer-headline em {

  font-style: italic;

  color: #1aba9c;

}



.footer-btns {

  display: flex;

  gap: 14px;

  flex-wrap: wrap;

  justify-content: center;

}



.footer-btn-primary {

  display: inline-flex;

  align-items: center;

  gap: 8px;

  padding: 15px 32px;

  background: #1aba9c;

  color: #fff;

  font-size: 14px;

  font-weight: 600;

  border: 2.5px solid #1a1a1a;

  border-radius: 100px;

  box-shadow: 4px 4px 0 #1a1a1a;

  text-decoration: none;

  transition: transform 0.15s ease, box-shadow 0.15s ease;

}



.footer-btn-primary:hover {

  transform: translate(-2px, -2px);

  box-shadow: 6px 6px 0 #1a1a1a;

}



.footer-btn-secondary {

  display: inline-flex;

  align-items: center;

  gap: 8px;

  padding: 15px 32px;

  background: #f5d76e;

  color: #1a1a1a;

  font-size: 14px;

  font-weight: 600;

  border: 2.5px solid #1a1a1a;

  border-radius: 100px;

  box-shadow: 4px 4px 0 #1a1a1a;

  text-decoration: none;

  transition: transform 0.15s ease, box-shadow 0.15s ease;

}



.footer-btn-secondary:hover {

  transform: translate(-2px, -2px);

  box-shadow: 6px 6px 0 #1a1a1a;

}



.footer-grid {

  display: grid;

  grid-template-columns: 1.6fr 1fr 1fr;

  border-bottom: 2.5px solid #1a1a1a;

}



.footer-col {

  padding: 44px 48px;

  border-right: 2.5px solid #1a1a1a;

  display: flex;

  flex-direction: column;

  align-items: center;

  text-align: center;

}



.footer-col:last-child {

  border-right: none;

}



.footer-col:not(.footer-brand) {

  background: #ece7d8;

}



.footer-col-label {

  font-size: 16px;

  font-weight: 1000;

  letter-spacing: 0.1em;

  text-transform: uppercase;

  color: #1a1a1a;

  margin: 0 0 22px;

  padding-bottom: 10px;

  width: 100%;

}



.footer-logo-wrap {

  display: flex;

  flex-direction: column;

  align-items: center;

  margin-bottom: 20px;

}



.footer-logo {

  display: block;

  height: 46px;

  width: auto;

  max-width: 100%;

}



.footer-tagline {

  font-family: 'Playfair Display', 'Georgia', serif;

  font-style: italic;

  font-size: 17px;

  line-height: 1.55;

  color: #666;

  margin: 0 0 24px;

}



.footer-socials {

  display: flex;

  gap: 10px;

  justify-content: center;

}



.footer-social {

  width: 38px;

  height: 38px;

  border: 2px solid #1a1a1a;

  border-radius: 10px;

  background: #fff;

  display: flex;

  align-items: center;

  justify-content: center;

  font-size: 16px;

  color: #1a1a1a;

  text-decoration: none;

  box-shadow: 2px 2px 0 #1a1a1a;

  transition: background 0.15s ease, color 0.15s ease;

}



.footer-social:hover {

  background: #1aba9c;

  color: #fff;

}

.footer-social svg {

  width: 20px;

  height: 20px;

  display: block;

  fill: currentColor;

}



.footer-link {

  display: flex;

  align-items: center;

  gap: 8px;

  font-size: 16px;

  color: #2a2a2a;

  text-decoration: none;

  margin-bottom: 8px;

  font-weight: 500;

  padding: 9px 14px;

  border-radius: 8px;

  border: 1.5px solid transparent;

  transition: color 0.15s ease, gap 0.15s ease, background 0.15s ease, border-color 0.15s ease;

  width: 100%;

  box-sizing: border-box;

}



.footer-link:hover {

  color: #1aba9c;

  gap: 12px;

  background: #f0ebe0;

  border-color: #1a1a1a;

}



.footer-bottom {

  display: flex;

  align-items: center;

  justify-content: space-between;

  padding: 18px 48px;

  border-top: 1px solid rgba(26, 26, 26, 0.1);

  flex-wrap: wrap;

  gap: 10px;

}



.footer-copy {

  font-size: 12px;

  color: #aaa;

  font-weight: 500;

}



.footer-bottom-links {

  display: flex;

  gap: 20px;

}



.footer-bottom-link {

  font-size: 12px;

  color: #aaa;

  text-decoration: none;

  transition: color 0.15s ease;

}



.footer-bottom-link:hover {

  color: #1a1a1a;

}



@media (max-width: 860px) {

  .footer-hero {

    padding: 52px 28px 44px;

  }



  .footer-grid {

    grid-template-columns: 1fr;

  }



  .footer-col {

    border-right: none;

    border-bottom: 2.5px solid #1a1a1a;

    padding: 36px 28px;

  }



  .footer-col:last-child {

    border-bottom: none;

  }



  .footer-bottom {

    padding: 18px 28px;

    flex-direction: column;

    text-align: center;

  }

}



:root {

  --ink: #f7efe1;

  --ink2: #fff6ea;

  --cyan: #1a3455;

  --cyan2: #9ed2ff;

  --cyan-deep: #2f7fe0;

  --indigo: #8bcf92;

  --text: #0b0b0b;

  --muted: #333333;

  --dim: #5a5a5a;

  --glass: rgba(255,255,255,0.6);

  --border: rgba(0,0,0,0.92);

  --border2: rgba(0,0,0,0.7);

}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

html{scroll-behavior:smooth;height:100%}



body {

  font-family: 'DM Sans', sans-serif;

  background: linear-gradient(180deg, #fbf2e4 0%, #f7ecd8 55%, #f2e4cf 100%);

  color: var(--text);

  overflow-x: hidden;

  cursor: none;

}



body::before {

  content: '';

  position: fixed;

  inset: 0;

  background-image:

    linear-gradient(rgba(163, 150, 255, 0.12) 1px, transparent 1px),

    linear-gradient(90deg, rgba(163, 150, 255, 0.12) 1px, transparent 1px);

  background-size: 42px 42px;

  opacity: 0.28;

  pointer-events: none;

  z-index: 9996;

  mask-image: radial-gradient(circle at center, black 58%, transparent 100%);

}



/* ── CUSTOM CURSOR ── */

#cursor {

  position: fixed; width: 12px; height: 12px;

  background: #111111; border-radius: 50%;

  pointer-events: none; z-index: 9999;

  transform: translate(-50%,-50%);

  transition: width 0.2s, height 0.2s, background 0.2s;

  mix-blend-mode: normal;

}

#cursor-ring {

  position: fixed; width: 36px; height: 36px;

  border: 1px solid rgba(0,0,0,0.45); border-radius: 50%;

  pointer-events: none; z-index: 9998;

  transform: translate(-50%,-50%);

  transition: width 0.4s cubic-bezier(0.23,1,0.32,1),

              height 0.4s cubic-bezier(0.23,1,0.32,1),

              border-color 0.3s, top 0.08s, left 0.08s;

}

body:hover #cursor { opacity: 1; }



/* ── NOISE GRAIN OVERLAY ── */

body::after {

  content: '';

  position: fixed; inset: 0;

  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");

  opacity: 0.04; pointer-events: none; z-index: 9997;

}



/* ── CANVAS PARTICLES ── */

#particles { position: fixed; inset: 0; z-index: 0; pointer-events: none; }



/* ── SCROLLBAR ── */

::-webkit-scrollbar { width: 3px; }

::-webkit-scrollbar-track { background: #f3ead9; }

::-webkit-scrollbar-thumb { background: #111111; border-radius: 2px; }



/* ── LAYOUT ── */

.page { position: relative; z-index: 1; }

.container { width: min(1200px,100%); margin: 0 auto; padding: 0 2.5rem; }

/* site-wide 3D canvas sits behind content */

#site-3d { position: fixed; inset: 0; z-index: 0; pointer-events: none; }

/* ensure page content floats above */

.page { z-index: 2; position: relative; }



/* ══════════════════════════════════

   NAVBAR

══════════════════════════════════ */

nav {

  position: fixed;

  top: 20px; left: 50%;

  transform: translateX(-50%);

  width: min(1100px, calc(100% - 3rem));

  z-index: 1200; padding: 0.5rem 0.75rem;

  transition: background 0.35s, transform 0.25s;

  border-radius: 14px;

  background: #fbf2e4;

  box-shadow: 6px 6px 0 #000;

  backdrop-filter: none;

  border: 4px solid #000;

}

/* upgraded navbar styles */

.nav-inner { align-items: center; gap: 1rem; }

.nav-left { display:flex; align-items:center; gap:0.85rem; }

.nav-actions { display:flex; align-items:center; gap:1rem; }

.nav-3d-toggle {

  display:inline-flex; align-items:center; gap:0.5rem; padding:0.45rem 0.75rem; border-radius:999px;

  background: #ffd24a; border:3px solid #000;

  color:#000; font-weight:700; cursor:pointer; transition: all 0.2s;

}

.nav-3d-toggle[aria-pressed="true"]{ background: #18d7a3; color:#000; box-shadow:4px 4px 0 #000; }

.nav-toggle { display:none; background:transparent; border:0; color:var(--text); font-size:1.1rem; cursor:pointer; }

.mobile-menu { display:none; position:fixed; inset:64px 20px auto 20px; background: #fbf2e4; border:4px solid #000; padding:1rem 1.25rem; border-radius:12px; box-shadow:6px 6px 0 #000; }

.mobile-menu.open{ display:block; }

/* navbar scroll trace (blue progress bar) */

.nav-trace { position: absolute; left: 8px; right: 8px; bottom: -4px; height: 3px; pointer-events: none; overflow: visible; }

.nav-trace-fill {

  position: absolute; left: 0; top: 50%; transform-origin: left center; transform: translateY(-50%) scaleX(0);

  height: 3px; border-radius: 6px; width: 100%;

  background: linear-gradient(90deg, #18d7a3, #6aaeff);

  box-shadow: none;

  transition: transform 0.14s linear;

}

nav.scrolled {

  transform: translateX(-50%) translateY(-2px);

  background: #fbf2e4;

  box-shadow: 6px 6px 0 #000;

}

.nav-inner {

  display: flex; align-items: center; justify-content: space-between;

}

.brand {

  display: flex; align-items: center; gap: 0.7rem;

  text-decoration: none; color: var(--text);

}

.nav-brand-mark {

  width: 46px;

  height: 46px;

  border-radius: 12px;

  overflow: hidden;

  flex: 0 0 auto;

  display: block;

}

.nav-brand-icon {

  display: block;

  width: 100%;

  height: 100%;

  object-fit: cover;

}

.nav-brand-copy {

  display: flex;

  flex-direction: column;

  justify-content: center;

  align-items: flex-start;

  min-width: 0;

}

.nav-brand-title {

  font-family: 'Fraunces', serif;

  font-size: 1.08rem;

  font-weight: 900;

  line-height: 1.02;

  max-width: 100%;

  color: #000;

}

.nav-brand-subtitle {

  display: block;

  margin-top: 0.2rem;

  font-size: 0.68rem;

  line-height: 1.05;

  color: #444;

  letter-spacing: 0.14em;

  text-transform: uppercase;

  font-weight: 500;

}

.nav-links { display: flex; align-items: center; gap: 2.5rem; }

.nav-links a {

  color: #000; text-decoration: none;

  font-size: 0.85rem; font-weight: 800;

  transition: color 0.2s; letter-spacing: 0.02em;

}

.nav-links a:hover { color: #2f7fe0; }

.nav-cta {

  padding: 0.6rem 1.4rem;

  border: 3px solid #000;

  border-radius: 0;

  background: #ffd24a;

  color: #000; font-size: 0.82rem; font-weight: 800;

  text-decoration: none;

  transition: all 0.25s;

  letter-spacing: 0.04em;

}

.nav-cta:hover {

  background: #ffb84d;

  box-shadow: 4px 4px 0 #000;

}



/* ══════════════════════════════════

   HERO

══════════════════════════════════ */

.hero {

  min-height: 100vh;

  display: flex; align-items: center;

  position: relative;

  padding: 8rem 0 6rem;

  overflow: hidden;

}



/* massive decorative ring */

.hero-ring {

  position: absolute;

  top: 50%; left: 50%;

  transform: translate(-50%, -50%);

  width: 900px; height: 900px;

  border-radius: 50%;

  border: 1px solid rgba(0,0,0,0.08);

  animation: ringRotate 40s linear infinite;

  pointer-events: none;

}

.hero-ring::before {

  content: '';

  position: absolute;

  top: -2px; left: 50%;

  width: 4px; height: 4px;

  background: #000;

  border-radius: 50%;

  box-shadow: 0 0 12px rgba(0,0,0,0.35);

  transform: translateX(-50%);

}

.hero-ring-2 {

  position: absolute;

  top: 50%; left: 50%;

  transform: translate(-50%, -50%);

  width: 600px; height: 600px;

  border-radius: 50%;

  border: 1px solid rgba(0,0,0,0.08);

  animation: ringRotate 28s linear infinite reverse;

  pointer-events: none;

}

.hero-ring-2::before {

  content: '';

  position: absolute;

  bottom: -2px; left: 30%;

  width: 3px; height: 3px;

  background: #2f7fe0;

  border-radius: 50%;

  box-shadow: 0 0 10px rgba(47,127,224,0.35), 0 0 20px rgba(47,127,224,0.25);

}

@keyframes ringRotate { to { transform: translate(-50%,-50%) rotate(360deg); } }



/* radial gradient */

.hero-glow {

  position: absolute;

  top: -10%; left: 50%;

  transform: translateX(-50%);

  width: 800px; height: 600px;

  background: radial-gradient(ellipse, rgba(106,174,255,0.28) 0%, rgba(24,215,163,0.12) 34%, transparent 68%);

  pointer-events: none;

}



.hero-content {

  position: relative; z-index: 2;

  display: grid;

  grid-template-columns: 1fr 1fr;

  gap: 4rem; align-items: center;

}



.hero-left { max-width: 560px; }



.hero-kicker {

  display: inline-flex; align-items: center; gap: 0.65rem;

  padding: 0.4rem 1rem;

  background: #7db8ff;

  border: 3px solid #000;

  border-radius: 0;

  margin-bottom: 2.5rem;

  font-family: 'JetBrains Mono', monospace;

  font-size: 0.72rem; color: #000;

  letter-spacing: 0.08em;

  opacity: 0; animation: riseIn 0.8s 0.2s cubic-bezier(0.23,1,0.32,1) forwards;

}

.hero-kicker-dot {

  width: 6px; height: 6px; border-radius: 50%; background: var(--cyan);

  box-shadow: 0 0 0 transparent;

  animation: pulse-dot 1.5s ease-in-out infinite;

}

@keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.7)} }



h1 {

  font-family: 'Fraunces', serif;

  font-size: clamp(3rem, 5vw, 4.5rem);

  font-weight: 900;

  line-height: 1.0;

  letter-spacing: -0.04em;

  color: #000;

  margin-bottom: 1.5rem;

  opacity: 0; animation: riseIn 1s 0.35s cubic-bezier(0.23,1,0.32,1) forwards;

}

h1 em {

  font-style: italic; font-weight: 300;

  background: linear-gradient(135deg, #6aaeff 0%, #18d7a3 50%, #ffd24a 100%);

  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;

}

.hero-sub {

  font-size: 1.35rem; color: #202020; line-height: 1.8;

  font-weight: 300; max-width: 44ch;

  margin-bottom: 3rem;

  opacity: 0; animation: riseIn 1s 0.5s cubic-bezier(0.23,1,0.32,1) forwards;

}

.hero-sub strong { color: #000; font-weight: 700; }



.hero-actions {

  display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;

  opacity: 0; animation: riseIn 1s 0.65s cubic-bezier(0.23,1,0.32,1) forwards;

}

.btn-primary {

  display: inline-flex; align-items: center; gap: 0.6rem;

  padding: 1rem 2rem; border-radius: 0;

  background: #18d7a3;

  color: #000; font-weight: 800; font-size: 0.92rem;

  text-decoration: none;

  box-shadow: 4px 4px 0 #000;

  transition: all 0.35s cubic-bezier(0.23,1,0.32,1);

  position: relative; overflow: hidden;

}

.btn-primary::before {

  content: ''; position: absolute; inset: 0;

  background: linear-gradient(135deg, rgba(255,255,255,0.3), transparent);

  opacity: 0; transition: opacity 0.3s;

}

.btn-primary:hover { transform: translateY(-2px); box-shadow: 6px 6px 0 #000; }

.btn-primary:hover::before { opacity: 1; }

.btn-ghost {

  display: inline-flex; align-items: center; gap: 0.5rem;

  padding: 1rem 1.8rem; border-radius: 999px;

  border: 3px solid #000;

  background: #f4d064;

  color: #000; font-size: 0.9rem; font-weight: 800;

  text-decoration: none;

  transition: all 0.3s;

}

.btn-ghost:hover { color: #000; transform: translateY(-2px); box-shadow: 4px 4px 0 #000; }



/* hero right — 3D device mockup */

.hero-right {

  opacity: 0; animation: riseIn 1.2s 0.5s cubic-bezier(0.23,1,0.32,1) forwards;

  perspective: 1200px;

}

.device-frame {

  position: relative;

  transform: rotateY(-18deg) rotateX(8deg) rotateZ(2deg);

  transform-style: preserve-3d;

  transition: transform 0.8s cubic-bezier(0.23,1,0.32,1);

}

.device-frame:hover { transform: rotateY(-4deg) rotateX(2deg) rotateZ(0deg); }

.device-screen {

  border-radius: 24px;

  background: linear-gradient(160deg, #7ab4f5, #68a3ea);

  border: 4px solid #000;

  padding: 2rem;

  box-shadow:

    6px 6px 0 #000;

  overflow: hidden;

  position: relative;

}

.device-screen::before {

  content: ''; position: absolute;

  top: -1px; left: 15%; right: 15%; height: 1px;

  background: linear-gradient(90deg, transparent, rgba(0,0,0,0.45), transparent);

}

/* mini dashboard inside device */

.dash-header {

  display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;

}

.dash-dot { width: 8px; height: 8px; border-radius: 50%; }

.dash-dot-r { background: #ef4444; }

.dash-dot-y { background: #f59e0b; }

.dash-dot-g { background: #10b981; }

.dash-title {

  font-family: 'JetBrains Mono', monospace;

  font-size: 0.7rem; color: #42526b; margin-left: auto;

  letter-spacing: 0.05em;

}

.dash-stat-row {

  display: grid; grid-template-columns: repeat(3,1fr); gap: 0.75rem; margin-bottom: 1.25rem;

}

.dash-stat {

  background: rgba(255,255,255,0.18);

  border: 3px solid #000;

  border-radius: 0; padding: 0.9rem; text-align: center;

}

.dash-stat-num {

  font-family: 'Fraunces', serif;

  font-size: 1.5rem; font-weight: 900; color: #1e2b44;

  line-height: 1;

}

.dash-stat-lbl { font-size: 0.75rem;font-weight:700; color: #34435c; margin-top: 0.3rem; letter-spacing: 0.06em; text-transform: uppercase; }

.dash-bar-row { margin-bottom: 1rem; }

.dash-bar-label { font-size: 0.65rem; color: #31435f; margin-bottom: 0.4rem; display: flex; justify-content: space-between; }

.dash-bar-track { height: 4px; background: rgba(0,0,0,0.15); border-radius: 0; overflow: hidden; border: 2px solid #000; }

.dash-bar-fill {

  height: 100%; border-radius: 2px;

  background: linear-gradient(90deg, #18d7a3, #ffd24a);

  animation: barGrow 1.8s cubic-bezier(0.23,1,0.32,1) forwards;

  transform-origin: left;

}

@keyframes barGrow { from{width:0} }

.dash-modules { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }

.dash-module {

  background: rgba(255,255,255,0.22); border: 3px solid #000;

  border-radius: 0; padding: 0.75rem;

  display: flex; align-items: center; gap: 0.6rem;

}

.dash-module-icon {

  width: 28px; height: 28px; border-radius: 8px;

  display: grid; place-items: center;

  font-size: 0.75rem;

}

.dash-module-icon.live { background: rgba(34,211,238,0.1); color: var(--cyan); }

.dash-module-icon.live { background: rgba(255,255,255,0.4); color: #000; border: 2px solid #000; }

.dash-module-icon.soon { background: rgba(255,255,255,0.45); color: #000; border: 2px solid #000; }

.dash-module-name { font-size: 0.9rem; font-weight: 700; color: #102033; }

.dash-module-tag { font-size: 0.55rem; color: #4b6a8d; }



@keyframes riseIn {

  from { opacity:0; transform: translateY(24px); }

  to   { opacity:1; transform: translateY(0); }

}



/* ══════════════════════════════════

   MARQUEE STRIP

══════════════════════════════════ */

.marquee-strip {

  overflow: hidden;

  border-top: 4px solid #000;

  border-bottom: 4px solid #000;

  padding: 1.1rem 0;

  background: #000;

}

.marquee-inner {

  display: flex; gap: 4rem; white-space: nowrap;

  animation: marquee 25s linear infinite;

}

.marquee-inner span {

  font-family: 'JetBrains Mono', monospace;

  font-size: 0.75rem; color: #fff;

  letter-spacing: 0.08em; text-transform: uppercase;

  display: inline-flex; align-items: center; gap: 1rem;

  flex-shrink: 0;

}

.marquee-inner span::before {

  content: '◆';

  color: #ffd24a; font-size: 0.5rem;

}

@keyframes marquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }



/* ══════════════════════════════════

   SERVICES — ALTERNATING TIMELINE

══════════════════════════════════ */

.services-section {

  padding: 8rem 0;

  position: relative;

  background: #f7f0e4;

  --timeline-spine-start: 25rem;

}



.services-intro {

  text-align: center; max-width: 600px; margin: 0 auto 6rem;

}

.section-label {

  display: inline-flex; align-items: center; gap: 0.6rem;

  font-family: 'JetBrains Mono', monospace;

  font-size: 0.7rem; color: #000; letter-spacing: 0.12em;

  text-transform: uppercase; margin-bottom: 1.25rem;

  background: #7ab4f5;

  border: 3px solid #000;

  padding: 0.35rem 0.7rem;

}

.section-label-line {

  width: 32px; height: 1px; background: #000; opacity: 1;

}

.services-intro h2 {

  font-family: 'Fraunces', serif;

  font-size: clamp(2.2rem, 4vw, 3.2rem);

  font-weight: 900; letter-spacing: -0.04em; color: #000;

  line-height: 1.05; margin-bottom: 1rem;

}

.services-intro h2 em {

  font-style: italic; font-weight: 300;

  color: #2f7fe0;

  -webkit-text-fill-color: #2f7fe0;

}

.services-intro p {

  color: #2d2d2d; font-size: 1rem; line-height: 1.7; font-weight: 300;

}



/* center spine */

.timeline-spine {

  position: absolute;

  left: 50%; top: var(--timeline-spine-start); bottom: 0;

  width: 1px;

  background: linear-gradient(180deg, transparent, #000 15%, #000 85%, transparent);

  transform: translateX(-50%);

}

.timeline-spine::before {

  content: '';

  position: absolute;

  left: 50%; top: 0; bottom: 0;

  width: 1px;

  background: linear-gradient(180deg, transparent, #000 15%, #000 85%, transparent);

  transform: translateX(-50%) scaleY(0);

  transform-origin: top;

  transition: transform 0.8s ease;

  animation: spineGrow 1.5s 0.5s forwards;

}

@keyframes spineGrow { to{transform:translateX(-50%) scaleY(1)} }



.service-item {

  display: grid;

  grid-template-columns: 1fr 80px 1fr;

  align-items: center;

  margin-bottom: 5rem;

  opacity: 0;

  transition: opacity 0.7s cubic-bezier(0.23,1,0.32,1), transform 0.7s cubic-bezier(0.23,1,0.32,1);

}

.service-item.left-item { transform: translateX(-60px); }

.service-item.right-item { transform: translateX(60px); }

.service-item.visible { opacity: 1; transform: translateX(0); }



/* the spine node */

.spine-node {

  display: flex; flex-direction: column; align-items: center; gap: 0;

  position: relative; z-index: 2;

}

.spine-orb {

  width: 48px; height: 48px; border-radius: 50%;

  display: grid; place-items: center;

  position: relative;

  transition: transform 0.4s;

}

.service-item:hover .spine-orb { transform: scale(1.15); }

.spine-orb.live-orb {

  background: #7ab4f5;

  border: 3px solid #000;

  box-shadow: 4px 4px 0 #000;

  animation: orbRing 2.5s ease-out infinite;

}

.spine-orb.soon-orb {

  background: #f4d064;

  border: 3px solid #000;

}

@keyframes orbRing {

  0% { box-shadow: 0 0 0 0 rgba(34,211,238,0.5); }

  70% { box-shadow: 0 0 0 14px rgba(34,211,238,0); }

  100% { box-shadow: 0 0 0 0 rgba(34,211,238,0); }

}

.spine-orb svg { width: 22px; height: 22px; }

.spine-connector {

  width: 1px; flex: 1;

  background: linear-gradient(180deg, #000, transparent);

  min-height: 30px;

}



/* service card */

.svc-card {

  border-radius: 24px;

  padding: 2.25rem;

  position: relative; overflow: hidden;

  transition: transform 0.5s cubic-bezier(0.23,1,0.32,1), box-shadow 0.5s, border-color 0.4s;

  transform-style: preserve-3d;

}

.svc-card.live-card {

  background: linear-gradient(150deg, #7ab4f5, #6aa4ee);

  border: 4px solid #000;

  box-shadow: 6px 6px 0 #000;

}

.svc-card.soon-card {

  background: linear-gradient(150deg, #f9eab7, #f4d96d);

  border: 4px solid #000;

  box-shadow: 6px 6px 0 #000;

  opacity: 0.75;

}

.svc-card.live-card:hover {

  transform: translateY(-6px) rotateX(1deg);

  box-shadow: 8px 8px 0 #000;

  opacity: 1;

}

.svc-card.soon-card:hover { transform: translateY(-4px); opacity: 0.92; box-shadow: 8px 8px 0 #000; }



/* card top glow line */

.svc-card.live-card::before {

  content: '';

  position: absolute; top: 0; left: 8%; right: 8%; height: 1px;

  background: linear-gradient(90deg, transparent, rgba(0,0,0,0.7), transparent);

}

/* corner radial */

.svc-card.live-card::after {

  content: '';

  position: absolute; top: 0; right: 0;

  width: 120px; height: 120px;

  background: radial-gradient(circle at top right, rgba(255,255,255,0.18), transparent 65%);

}



/* left card points right, right card points left */

.service-item.left-item .svc-card { margin-right: 0; }

.service-item.right-item .svc-card { margin-left: 0; }

.service-item.left-item .svc-empty { grid-column: 3; }

.service-item.right-item .svc-card-wrapper { grid-column: 3; }

.service-item.right-item .svc-empty { grid-column: 1; }



/* connector arrow from spine to card */

.spine-line {

  position: absolute; top: 50%; height: 1px;

  background: linear-gradient(90deg, #000, transparent);

  width: 40px;

}

.service-item.left-item .spine-line {

  right: 100%; background: linear-gradient(270deg, #000, transparent);

}

.service-item.right-item .spine-line {

  left: 100%; background: linear-gradient(90deg, #000, transparent);

}



.svc-card-header {

  display: flex; justify-content: space-between; align-items: flex-start;

  margin-bottom: 1.25rem;

}

.svc-icon-box {

  width: 52px; height: 52px; border-radius: 15px;

  display: grid; place-items: center;

  transition: transform 0.4s cubic-bezier(0.23,1,0.32,1);

}

.svc-card:hover .svc-icon-box { transform: scale(1.08) rotate(5deg); }

.svc-icon-box.live-icon {

  background: #18d7a3; border: 3px solid #000;

  color: #000; box-shadow: 3px 3px 0 #000;

}

.svc-icon-box.soon-icon {

  background: #f4d064; border: 3px solid #000;

  color: #000;

}

.svc-icon-box svg { width: 24px; height: 24px; }



.svc-badge {

  display: inline-flex; align-items: center; gap: 5px;

  padding: 0.3rem 0.9rem; border-radius: 999px;

  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;

}

.svc-badge.live-badge {

  background: #18d7a3; border: 3px solid #000;

  color: #000;

}

.svc-badge.live-badge::before {

  content: ''; width: 5px; height: 5px; border-radius: 50%;

  background: #000; animation: pulse-dot 1.5s ease-in-out infinite;

}

.svc-badge.soon-badge {

  background: #ffd24a; border: 3px solid #000;

  color: #000;

}



.svc-card h3 {

  font-family: 'Fraunces', serif;

  font-size: 1.55rem; font-weight: 700;

  letter-spacing: -0.03em; color: #000;

  margin-bottom: 0.75rem; line-height: 1.15;

}

.svc-card p {

  color: #1e1e1e; font-size: 1.2rem; line-height: 1.8; font-weight: 400;

  margin-bottom: 1.8rem;

}



/* feature bullets */

.svc-features {

  display: grid; gap: 0.5rem; margin-bottom: 1.75rem;

}

.svc-feature {

  display: flex; align-items: flex-start; gap: 0.6rem;

  font-size: 0.83rem; color: #232323; line-height: 1.5;

}

.svc-feature::before {

  content: '';

  width: 4px; height: 4px; border-radius: 50%;

  background: #000; margin-top: 0.45rem; flex-shrink: 0;

}

.svc-card.soon-card .svc-feature::before { background: #000; }



.launch-btn {

  display: inline-flex; align-items: center; gap: 0.55rem;

  padding: 0.8rem 1.6rem; border-radius: 0;

  background: #18d7a3;

  color: #000; font-weight: 800; font-size: 0.87rem;

  text-decoration: none;

  box-shadow: 4px 4px 0 #000;

  transition: all 0.3s cubic-bezier(0.23,1,0.32,1);

}

.launch-btn:hover { transform: translateY(-2px); box-shadow: 6px 6px 0 #000; filter: brightness(1.03); }

.launch-btn svg { width: 15px; height: 15px; transition: transform 0.25s; }

.launch-btn:hover svg { transform: translateX(3px); }

.locked-badge {

  display: inline-flex; align-items: center; gap: 0.55rem;

  color: #333; font-size: 0.8rem; font-weight: 700;

  letter-spacing: 0.06em; text-transform: uppercase;

  padding: 0.7rem 0;

}

.locked-badge svg { width: 13px; height: 13px; }



/* ══════════════════════════════════

   STATS

══════════════════════════════════ */

.stats-section {

  padding: 5rem 0;

  border-top: 4px solid #000;

  border-bottom: 4px solid #000;

  background: #f7dfe5;

}

.stats-grid {

  display: grid; grid-template-columns: repeat(3,1fr); gap: 2px;

}

.stat-block {

  text-align: center; padding: 3rem 2rem;

  position: relative;

}

.stat-block::after {

  content: '';

  position: absolute; right: 0; top: 20%; bottom: 20%;

  width: 1px; background: #000;

}

.stat-block:last-child::after { display: none; }

.stat-num {

  font-family: 'Fraunces', serif;

  font-size: 4rem; font-weight: 900; line-height: 1;

  background: linear-gradient(135deg, #6aaeff, #18d7a3);

  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;

  margin-bottom: 0.5rem;

}

.stat-label { color: #2b2b2b; font-size: 1rem;font-weight:600; letter-spacing: 0.06em; text-transform: uppercase; }



/* ══════════════════════════════════

   FOOTER

══════════════════════════════════ */

footer {

  padding: 3rem 0; text-align: center;

  border-top: 1px solid var(--border);

}

footer p { color: var(--dim); font-size: 0.8rem; letter-spacing: 0.04em; }

footer span { color: var(--cyan); }



/* ══════════════════════════════════

   RESPONSIVE

══════════════════════════════════ */

@media (max-width: 900px) {

  .hero-content { grid-template-columns: 1fr; text-align: center; }

  .hero-left { max-width: 100%; }

  .hero-sub { max-width: 100%; }

  .hero-actions { justify-content: center; }

  .hero-right { display: none; }

  /* mobile: make navbar full-width while keeping glass look */

  nav { left: 12px; right: 12px; transform: none; width: auto; top: 12px; border-radius: 10px; }

  .brand { gap: 0.68rem; }

  .nav-brand-mark { width: 44px; height: 44px; }

  .nav-brand-title { font-size: 1rem; }

  .nav-brand-subtitle { font-size: 0.64rem; }

  .nav-links { display:none; }

  .nav-toggle { display:inline-flex; }

  .nav-3d-toggle { padding:0.5rem; }

  .service-item {

    grid-template-columns: 1fr;

    margin-bottom: 2rem;

  }

  .spine-node { display: none; }

  .timeline-spine { display: none; }

  .svc-card { margin: 0; }

  .service-item.left-item { transform: translateX(-30px); }

  .service-item.right-item { transform: translateX(30px); }

  .stats-grid { grid-template-columns: 1fr; }

  .stat-block::after { display: none; }

}

@media (max-width: 600px) {

  h1 { font-size: 2.5rem; }

  .brand { gap: 0.62rem; }

  .nav-brand-mark { width: 40px; height: 40px; border-radius: 10px; }

  .nav-brand-title { font-size: 0.94rem; }

  .nav-brand-subtitle { font-size: 0.58rem; letter-spacing: 0.1em; }

  .nav-links { display: none; }

  .service-item { transform: translateY(30px) !important; }

  .service-item.visible { transform: translateY(0) !important; }

}

</style>

</head>

