<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CreatorOS Service Hub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #06101f;
            --bg-2: #0b1730;
            --panel: rgba(13, 24, 49, 0.68);
            --border: rgba(148, 163, 184, 0.16);
            --text: #f8fafc;
            --muted: #cbd5e1;
            --accent: #22d3ee;
            --accent-2: #38bdf8;
            --available: #22c55e;
            --soon: #f59e0b;
        }

        * { box-sizing: border-box; }

        html {
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Poppins', sans-serif;
            color: var(--text);
            background:
                radial-gradient(900px 320px at 50% -80px, rgba(56, 189, 248, 0.24), transparent 70%),
                radial-gradient(720px 260px at 85% 0%, rgba(34, 211, 238, 0.18), transparent 70%),
                linear-gradient(180deg, var(--bg-2), var(--bg));
            overflow-x: hidden;
        }

        .page-shell {
            position: relative;
            isolation: isolate;
            min-height: 100vh;
        }

        .page-shell::before,
        .page-shell::after {
            content: '';
            position: fixed;
            border-radius: 999px;
            filter: blur(20px);
            opacity: 0.18;
            pointer-events: none;
            z-index: -1;
            animation: drift 11s ease-in-out infinite;
        }

        .page-shell::before {
            top: 8rem;
            left: -4rem;
            width: 16rem;
            height: 16rem;
            background: #0ea5e9;
        }

        .page-shell::after {
            top: 20rem;
            right: -5rem;
            width: 18rem;
            height: 18rem;
            background: #22d3ee;
            animation-delay: 2.4s;
        }

        .container {
            width: min(1180px, 100%);
            margin: 0 auto;
            padding: 0 1rem;
        }

        .glass-card {
            background: var(--panel);
            border: 1px solid var(--border);
            backdrop-filter: blur(18px);
            box-shadow: 0 24px 50px rgba(0, 0, 0, 0.28);
        }

        .topbar {
            padding: 1.25rem 0 0;
        }

        .topbar-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.95rem 1.2rem;
            border-radius: 999px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            text-decoration: none;
            color: var(--text);
        }

        .brand-mark {
            width: 2.4rem;
            height: 2.4rem;
            border-radius: 0.9rem;
            background: linear-gradient(135deg, #67e8f9, var(--accent-2));
            box-shadow: 0 10px 30px rgba(34, 211, 238, 0.28);
            display: grid;
            place-items: center;
            color: #082f49;
            font-weight: 800;
        }

        .brand-copy {
            line-height: 1.05;
        }

        .brand-copy strong {
            display: block;
            font-size: 1rem;
        }

        .brand-copy span {
            display: block;
            margin-top: 0.2rem;
            font-size: 0.8rem;
            color: var(--muted);
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 1.4rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .nav-links a {
            color: var(--muted);
            text-decoration: none;
            font-size: 0.95rem;
            transition: color 0.2s ease, transform 0.2s ease;
        }

        .nav-links a:hover {
            color: #fff;
            transform: translateY(-1px);
        }

        .hero {
            position: relative;
            padding: 4.5rem 0 3rem;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
            gap: 1.25rem;
            align-items: stretch;
        }

        .hero-panel,
        .stats-panel {
            border-radius: 28px;
        }

        .hero-panel {
            position: relative;
            overflow: hidden;
            padding: clamp(1.5rem, 3vw, 2.5rem);
        }

        .hero-panel::before {
            content: '';
            position: absolute;
            inset: 1.2rem;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            pointer-events: none;
        }

        .hero-kicker {
            display: inline-flex;
            align-items: center;
            gap: 0.55rem;
            padding: 0.45rem 0.8rem;
            border-radius: 999px;
            background: rgba(34, 211, 238, 0.1);
            color: #c9f7ff;
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.02em;
            margin-bottom: 1rem;
        }

        .hero-kicker-dot {
            width: 0.5rem;
            height: 0.5rem;
            border-radius: 999px;
            background: #67e8f9;
            box-shadow: 0 0 0 6px rgba(103, 232, 249, 0.14);
        }

        .hero h1 {
            margin: 0;
            font-size: clamp(2.6rem, 6vw, 4.6rem);
            line-height: 0.98;
            letter-spacing: -0.04em;
            max-width: 12ch;
        }

        .hero h1 span {
            color: #67e8f9;
        }

        .hero p {
            margin: 1.1rem 0 0;
            max-width: 58ch;
            color: var(--muted);
            font-size: 1.04rem;
            line-height: 1.7;
        }

        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.8rem;
            margin-top: 1.5rem;
        }

        .action-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            border-radius: 999px;
            padding: 0.9rem 1.2rem;
            text-decoration: none;
            font-weight: 700;
            transition: transform 0.2s ease, filter 0.2s ease, border-color 0.2s ease;
        }

        .action-btn.primary {
            color: #042f3e;
            background: linear-gradient(135deg, #67e8f9, var(--accent-2));
            box-shadow: 0 16px 32px rgba(34, 211, 238, 0.2);
        }

        .action-btn.secondary {
            color: var(--text);
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(255, 255, 255, 0.04);
        }

        .action-btn:hover {
            transform: translateY(-2px);
            filter: brightness(1.02);
        }

        .stats-panel {
            padding: 1.2rem;
            display: grid;
            gap: 1rem;
            align-content: center;
        }

        .stats-panel .mini-card {
            border-radius: 22px;
            padding: 1rem 1rem 1.05rem;
            background: linear-gradient(180deg, rgba(15, 26, 51, 0.9), rgba(8, 15, 31, 0.85));
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .mini-label {
            margin: 0;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.16em;
            color: #7dd3fc;
        }

        .mini-value {
            margin: 0.45rem 0 0;
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .mini-note {
            margin: 0.45rem 0 0;
            color: var(--muted);
            font-size: 0.92rem;
            line-height: 1.5;
        }

        .section {
            padding: 1rem 0 4rem;
        }

        .section-heading {
            margin: 0 0 1.2rem;
        }

        .section-heading h2 {
            margin: 0;
            font-size: clamp(2rem, 4vw, 3rem);
            letter-spacing: -0.03em;
        }

        .section-heading p {
            margin: 0.55rem 0 0;
            color: var(--muted);
            max-width: 100ch;
            line-height: 1.7;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1rem;
        }

        .service-card {
            position: relative;
            overflow: hidden;
            border-radius: 24px;
            padding: 1.15rem;
            min-height: 230px;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            opacity: 1;
            transform: none;
        }

        .service-card::after {
            content: '';
            position: absolute;
            inset: auto -20% -45% auto;
            width: 10rem;
            height: 10rem;
            border-radius: 999px;
            background: radial-gradient(circle, rgba(103, 232, 249, 0.18), transparent 68%);
            pointer-events: none;
        }

        .service-card:hover {
            border-color: rgba(103, 232, 249, 0.34);
        }

        .service-card.available {
            background: linear-gradient(180deg, rgba(8, 24, 41, 0.94), rgba(9, 16, 34, 0.9));
        }

        .service-card.coming_soon {
            background: linear-gradient(180deg, rgba(10, 18, 38, 0.9), rgba(8, 14, 29, 0.88));
        }

        .badge {
            align-self: flex-start;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            border-radius: 999px;
            padding: 0.32rem 0.72rem;
            font-size: 0.74rem;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .badge::before {
            content: '';
            width: 0.42rem;
            height: 0.42rem;
            border-radius: 999px;
            background: currentColor;
            box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.08);
        }

        .badge.available {
            color: #052e16;
            background: linear-gradient(135deg, #86efac, var(--available));
        }

        .badge.coming_soon {
            color: #451a03;
            background: linear-gradient(135deg, #fcd34d, var(--soon));
        }

        .service-card h3 {
            margin: 0;
            font-size: 1.35rem;
            line-height: 1.15;
        }

        .service-card p {
            margin: 0;
            color: var(--muted);
            line-height: 1.65;
            flex: 1;
        }

        .service-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.45rem;
            border-radius: 999px;
            padding: 0.76rem 0.95rem;
            text-decoration: none;
            font-weight: 700;
            transition: transform 0.2s ease, filter 0.2s ease;
            flex-shrink: 0;
        }

        .service-link.available {
            color: #042f3e;
            background: linear-gradient(135deg, #67e8f9, var(--accent-2));
        }

        .service-link.coming_soon {
            color: #fef3c7;
            border: 1px dashed rgba(251, 191, 36, 0.55);
            background: rgba(245, 158, 11, 0.08);
        }

        .service-link:hover {
            transform: translateY(-2px);
            filter: brightness(1.02);
        }

        .footer {
            padding: 0 0 2rem;
            color: var(--muted);
            text-align: center;
            font-size: 0.95rem;
        }

        @keyframes drift {
            0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
            50% { transform: translate3d(0, -18px, 0) scale(1.05); }
        }

        @keyframes floatSoft {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        @media (prefers-reduced-motion: reduce) {
            html { scroll-behavior: auto; }

            .page-shell::before,
            .page-shell::after {
                animation: none;
            }

            .service-card {
                opacity: 1;
                transform: none;
            }
        }

        @media (max-width: 900px) {
            .hero-grid {
                grid-template-columns: 1fr;
            }

            .stats-panel {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 720px) {
            .topbar-inner {
                border-radius: 28px;
                padding: 1rem;
                flex-direction: column;
                align-items: flex-start;
            }

            .nav-links {
                justify-content: flex-start;
                gap: 1rem;
            }

            .hero {
                padding-top: 2.8rem;
            }

            .hero-panel,
            .stats-panel {
                border-radius: 24px;
            }

            .stats-panel {
                grid-template-columns: 1fr;
            }

            .service-card {
                min-height: 210px;
            }
        }
    </style>
</head>
<body>
    <div class="page-shell">
        <header class="topbar">
            <div class="container">
                <div class="topbar-inner glass-card">
                    <a class="brand" href="/">
                        <div class="brand-mark">C</div>
                        <div class="brand-copy">
                            <strong>CreatorOS</strong>
                            <span>Service hub</span>
                        </div>
                    </a>

                    <nav class="nav-links">
                        <a href="#status">Status</a>
                        <a href="#services">Services</a>
                    </nav>
                </div>
            </div>
        </header>

        <main>
            <section class="hero">
                <div class="container">
                    <div class="hero-grid">
                        <div class="hero-panel glass-card">
                            <div class="hero-kicker"><span class="hero-kicker-dot"></span> Creator tools, one place</div>
                            <h1>Shortcuts for creators, wrapped in a sharper <span>hub</span>.</h1>
                            <p>
                                Explore the live URL shortener and the rest of the CreatorOS modules
                            </p>

                            <div class="hero-actions">
                                <a class="action-btn secondary" href="#services">Browse services</a>
                            </div>
                        </div>

                        <aside class="stats-panel glass-card" id="status">
                            <div class="mini-card" style="animation: floatSoft 6s ease-in-out infinite;">
                                <p class="mini-label">Live module</p>
                                <p class="mini-value">1</p>
                                <p class="mini-note">The URL shortener is available now.</p>
                            </div>
                            <div class="mini-card" style="animation: floatSoft 6s ease-in-out infinite; animation-delay: 1.5s;">
                                <p class="mini-label">Coming soon</p>
                                <p class="mini-value">5</p>
                                <p class="mini-note">Analytics, DM automation, CRM, Content OS and more.</p>
                            </div>
                        </aside>
                    </div>
                </div>
            </section>

            <section class="section" id="services">
                <div class="container">
                    <div class="section-heading">
                        <h2>Services</h2>
                        <p>
                            The Service Hub is the gateway to all CreatorOS modules. Each service is designed to integrate seamlessly with the others, creating a powerful ecosystem for creators.  
                        </p>
                    </div>

                    <div class="grid">
                        <% services.forEach((service, index) => { %>
                            <article class="service-card glass-card <%= service.status %>" data-index="<%= index %>">
                                <span class="badge <%= service.status %>">
                                    <%= service.status === 'available' ? 'Available now' : 'Coming soon' %>
                                </span>
                                <h3><%= service.name %></h3>
                                <p><%= service.description %></p>
                                <a class="service-link <%= service.status %>" href="<%= service.route %>">
                                    <%= service.status === 'available' ? 'Open service' : 'View placeholder' %>
                                </a>
                            </article>
                        <% }) %>
                    </div>
                </div>
            </section>
        </main>

        <footer class="footer">
            <p>&copy; 2026 CreatorOS. All Rights Reserved.</p>
        </footer>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script>
        const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

        tl.from('.topbar-inner', { opacity: 0, y: -24, duration: 0.7 })
          .from('.hero-kicker', { opacity: 0, y: 16, duration: 0.5 }, '-=0.25')
          .from('.hero h1', { opacity: 0, y: 44, duration: 0.9 }, '-=0.1')
          .from('.hero p', { opacity: 0, y: 26, duration: 0.75 }, '-=0.55')
          .from('.hero-actions > a', { opacity: 0, y: 18, duration: 0.55, stagger: 0.12 }, '-=0.45')
          .from('.stats-panel .mini-card', { opacity: 0, y: 30, duration: 0.65, stagger: 0.12 }, '-=0.55');
    </script>
</body>
</html>
