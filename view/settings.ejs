<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>System Preferences | CreatorOS</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/settings.css">
</head>
<body class="settings-page density-<%= user.preferences.interfaceDensity %> appearance-<%= user.preferences.appearanceMode %><%= user.preferences.motionEffects ? '' : ' no-motion' %>"
    data-user='<%- JSON.stringify({
        name: user.name,
        alias: user.alias,
        bio: user.bio,
        initials: user.initials,
        twoFactorEnabled: user.twoFactorEnabled,
        preferences: user.preferences,
        passwordAgeDays: user.passwordAgeDays,
        billing: user.billing,
        isGuestContributor: isGuestContributor
    }) %>'>

    <div class="settings-layout">
        <aside class="settings-sidebar" aria-label="Main navigation">
            <a class="settings-brand" href="/dashboard">
                <h1>CreatorOS</h1>
                <span>v2.0 BETA</span>
            </a>

            <nav class="settings-nav">
                <a href="/dashboard">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                        <rect x="3" y="3" width="7" height="7"></rect>
                        <rect x="14" y="3" width="7" height="7"></rect>
                        <rect x="14" y="14" width="7" height="7"></rect>
                        <rect x="3" y="14" width="7" height="7"></rect>
                    </svg>
                    Dashboard
                </a>
                <a href="/my-links">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                        <path d="M10 13a5 5 0 0 0 7.07 0l2.83-2.83a5 5 0 0 0-7.07-7.07L11 4.9"></path>
                        <path d="M14 11a5 5 0 0 0-7.07 0L4.1 13.83a5 5 0 0 0 7.07 7.07L13 19.1"></path>
                    </svg>
                    My Links
                </a>
                <a href="/dashboard#analytics">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                        <path d="M4 19V5"></path>
                        <path d="M9 19V9"></path>
                        <path d="M14 19V3"></path>
                        <path d="M19 19v-7"></path>
                    </svg>
                    Analytics
                </a>
                <a href="/services/creator-crm">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                    CRM
                </a>
                <a href="/settings" class="active" aria-current="page">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                        <path d="M12 15.5A3.5 3.5 0 1 0 12 8a3.5 3.5 0 0 0 0 7.5Z"></path>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06A1.65 1.65 0 0 0 15 19.4a1.65 1.65 0 0 0-1 .6V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 20.4a1.65 1.65 0 0 0-1.82-.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-.6-1 1.65 1.65 0 0 0-1.82-.33H2a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 3.6 9c.14-.66-.07-1.35-.6-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6c.66-.14 1.35.07 1.82.6V5a2 2 0 0 1 4 0v.09A1.65 1.65 0 0 0 15 3.6c.66.14 1.35-.07 1.82-.6l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9c.14.66.07 1.35-.6 1.82H20a2 2 0 0 1 0 4h-.09A1.65 1.65 0 0 0 19.4 15Z"></path>
                    </svg>
                    Settings
                </a>
            </nav>

            <div class="settings-sidebar-footer">
                <a href="#" class="btn-upgrade" id="upgrade-plan-btn">Upgrade Plan</a>
                <a href="mailto:support@creatoros.app" id="support-link">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                        <line x1="12" y1="17" x2="12.01" y2="17"></line>
                    </svg>
                    Support
                </a>
                <a href="/logout">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <path d="m16 17 5-5-5-5"></path>
                        <path d="M21 12H9"></path>
                    </svg>
                    Log Out
                </a>
            </div>
        </aside>

        <main class="settings-main">
            <% if (isGuestContributor) { %>
                <div class="guest-banner">Contributor accounts can view preferences but cannot change profile or security settings.</div>
            <% } %>

            <header class="settings-header">
                <div>
                    <h1>System Preferences</h1>
                    <p>Manage your workspace identity, security, and billing cycles.</p>
                </div>
                <a href="/profile" class="user-badge" id="header-user-badge" aria-label="View profile">
                    <div class="user-avatar" id="header-avatar"><%= user.initials %></div>
                    <div class="user-info">
                        <span class="user-name" id="header-user-name"><%= user.name %></span>
                        <span class="user-role">Pro Member</span>
                    </div>
                </a>
            </header>

            <div class="content-layout">
                <nav class="sub-nav" aria-label="Settings sections">
                    <a href="#profile" class="sub-nav-item active">Profile Information</a>
                    <a href="#security" class="sub-nav-item">Security &amp; Access</a>
                    <a href="#billing" class="sub-nav-item">Billing &amp; Usage</a>
                    <a href="#global" class="sub-nav-item">Global Preferences</a>
                </nav>

                <div class="settings-sections">
                    <section id="profile" class="section-card">
                        <div class="section-header">
                            <h2 class="section-title">Profile Information</h2>
                            <span class="badge-yellow">IDENTITY_MOD</span>
                        </div>
                        <form id="profile-form">
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label" for="profile-name">Full Name</label>
                                    <input type="text" class="form-input" id="profile-name" name="name" value="<%= user.name %>" <%= isGuestContributor ? 'disabled' : '' %>>
                                </div>
                                <div class="form-group">
                                    <label class="form-label" for="profile-alias">Creator Alias</label>
                                    <input type="text" class="form-input" id="profile-alias" name="alias" value="<%= user.alias %>" placeholder="@your_alias" <%= isGuestContributor ? 'disabled' : '' %>>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="profile-bio">Bio / Description</label>
                                <textarea class="form-textarea" id="profile-bio" name="bio" <%= isGuestContributor ? 'disabled' : '' %>><%= user.bio %></textarea>
                            </div>
                            <div class="divider"></div>
                            <button type="submit" class="btn-action btn-action-right" id="profile-submit" <%= isGuestContributor ? 'disabled' : '' %>>Update Profile</button>
                            <div style="clear:both"></div>
                        </form>
                    </section>

                    <section id="security" class="section-card">
                        <div class="section-header">
                            <h2 class="section-title">Security &amp; Access</h2>
                            <span class="badge-blue">ENCRYPTION_V3</span>
                        </div>
                        <div class="setting-row">
                            <div class="setting-info">
                                <h4>Two-Factor Authentication</h4>
                                <p>Add an extra layer of security to your account.</p>
                            </div>
                            <div class="toggle-switch <%= user.twoFactorEnabled ? '' : 'off' %>" id="tfa-toggle" role="switch" aria-checked="<%= user.twoFactorEnabled %>" tabindex="0" <%= isGuestContributor ? 'aria-disabled=true' : '' %>></div>
                        </div>
                        <div class="setting-row">
                            <div class="setting-info">
                                <h4>Password Management</h4>
                                <p id="pwd-age-text"><% if (user.passwordAgeDays !== null) { %>Last updated <%= user.passwordAgeDays %> day<%= user.passwordAgeDays === 1 ? '' : 's' %> ago<% } else { %>Change your account password.<% } %></p>
                            </div>
                            <button type="button" class="btn-secondary" id="change-pwd-btn" <%= isGuestContributor ? 'disabled' : '' %>>Change Key</button>
                        </div>
                        <div class="pwd-panel" id="pwd-form">
                            <div class="form-group" style="margin-bottom:1rem">
                                <label class="form-label" for="old-pwd">Old Password</label>
                                <input type="password" id="old-pwd" class="form-input" autocomplete="current-password">
                            </div>
                            <div class="form-group" style="margin-bottom:1rem">
                                <label class="form-label" for="new-pwd">New Password</label>
                                <input type="password" id="new-pwd" class="form-input" autocomplete="new-password" minlength="8">
                            </div>
                            <button type="button" class="btn-action" id="save-pwd-btn">Save Password</button>
                        </div>
                        <div class="danger-zone">
                            <h4 class="danger-title">Danger Zone</h4>
                            <p class="danger-text">Deleting your account is permanent and cannot be undone.</p>
                            <button type="button" class="btn-danger" id="deactivate-btn" <%= isGuestContributor ? 'disabled' : '' %>>Deactivate Creator Instance</button>
                        </div>
                    </section>

                    <section id="billing">
                        <div class="billing-grid">
                            <div class="billing-card active-plan">
                                <div class="billing-label">ACTIVE PLAN</div>
                                <div class="plan-name" id="plan-name"><%= user.billing.planName %></div>
                                <div class="plan-price">$<span id="plan-price"><%= user.billing.priceMonthly %></span><span>/mo</span></div>
                                <button type="button" class="btn-black" id="manage-subscription-btn">Manage Subscription</button>
                            </div>
                            <div class="billing-card">
                                <div class="billing-label">NEXT INVOICE</div>
                                <div class="invoice-date" id="next-invoice-date"><%= user.billing.nextInvoiceLabel %></div>
                                <div class="invoice-est" id="invoice-est">Estimated: <%= user.billing.estimatedTotal %></div>
                                <div class="card-info">
                                    <svg width="24" height="16" viewBox="0 0 24 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="2" width="22" height="12" rx="2"></rect><line x1="1" y1="7" x2="23" y2="7"></line></svg>
                                    <span id="card-info-text"><%= user.billing.cardBrand %> ending in <%= user.billing.cardLast4 %></span>
                                </div>
                            </div>
                        </div>
                        <table class="invoices-table" id="invoices-table">
                            <thead>
                                <tr>
                                    <th>DATE</th>
                                    <th>INVOICE ID</th>
                                    <th>AMOUNT</th>
                                    <th>STATUS</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% user.billing.invoices.forEach(function(inv) { %>
                                    <tr data-invoice-id="<%= inv.invoiceId %>">
                                        <td><%= inv.date %></td>
                                        <td><%= inv.invoiceId %></td>
                                        <td><%= inv.amount %></td>
                                        <td><span class="badge-paid"><%= inv.status %></span></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </section>

                    <section id="global" class="section-card">
                        <div class="section-header">
                            <h2 class="section-title">Global Preferences</h2>
                        </div>
                        <div class="pref-grid">
                            <div>
                                <div class="pref-group">
                                    <div class="pref-label">Appearance Mode</div>
                                    <div class="radio-group" id="appearance-group">
                                        <button type="button" class="radio-btn <%= user.preferences.appearanceMode === 'light' ? 'active' : '' %>" data-val="light">Light</button>
                                        <button type="button" class="radio-btn <%= user.preferences.appearanceMode === 'dark' ? 'active' : '' %>" data-val="dark">Dark</button>
                                        <button type="button" class="radio-btn <%= user.preferences.appearanceMode === 'system' ? 'active' : '' %>" data-val="system">System</button>
                                    </div>
                                </div>
                                <div class="pref-group">
                                    <div class="pref-label">Interface Density</div>
                                    <div class="radio-group" id="density-group">
                                        <button type="button" class="radio-btn <%= user.preferences.interfaceDensity === 'compact' ? 'active' : '' %>" data-val="compact">Compact</button>
                                        <button type="button" class="radio-btn <%= user.preferences.interfaceDensity === 'tactile' ? 'active' : '' %>" data-val="tactile">Tactile</button>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <div class="pref-row">
                                    <span class="pref-row-label">Motion Effects</span>
                                    <div class="toggle-switch-small pref-toggle <%= user.preferences.motionEffects ? '' : 'off' %>" data-key="motionEffects" role="switch" aria-checked="<%= user.preferences.motionEffects %>" tabindex="0"></div>
                                </div>
                                <div class="pref-row">
                                    <span class="pref-row-label">Sound Cues</span>
                                    <div class="toggle-switch-small pref-toggle <%= user.preferences.soundCues ? '' : 'off' %>" data-key="soundCues" role="switch" aria-checked="<%= user.preferences.soundCues %>" tabindex="0"></div>
                                </div>
                                <div class="pref-row">
                                    <span class="pref-row-label">Auto-Save Links</span>
                                    <div class="toggle-switch-small pref-toggle <%= user.preferences.autoSaveLinks ? '' : 'off' %>" data-key="autoSaveLinks" role="switch" aria-checked="<%= user.preferences.autoSaveLinks %>" tabindex="0"></div>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </main>
    </div>

    <div class="toast" id="toast" role="status" aria-live="polite"></div>

    <div class="modal-overlay" id="billing-modal" aria-hidden="true">
        <div class="modal-card" role="dialog" aria-labelledby="billing-modal-title">
            <h3 id="billing-modal-title">Manage Subscription</h3>
            <p id="billing-modal-body">Your Pro Individual plan renews automatically each month.</p>
            <div class="modal-actions">
                <button type="button" class="btn-secondary" id="billing-modal-close">Close</button>
                <a href="mailto:billing@creatoros.app" class="btn-action" style="text-decoration:none;display:inline-flex;align-items:center">Contact Billing</a>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="invoice-modal" aria-hidden="true">
        <div class="modal-card" role="dialog" aria-labelledby="invoice-modal-title">
            <h3 id="invoice-modal-title">Invoice Details</h3>
            <p id="invoice-modal-body"></p>
            <div class="modal-actions">
                <button type="button" class="btn-action" id="invoice-download-btn">Download PDF</button>
                <button type="button" class="btn-secondary" id="invoice-modal-close">Close</button>
            </div>
        </div>
    </div>

    <script src="/js/pages/settings.js"></script>
</body>
</html>
