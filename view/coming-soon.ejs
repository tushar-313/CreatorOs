<!DOCTYPE html>
<html lang="en">
<head>

    <!-- SEO meta tags -->
    <%- include('./partials/_seo', {
        title: service.name + ' - Coming Soon',
        description: 'This feature is currently under development and will be available soon on CreatorOS.',
        canonical: 'https://creatoros.com/coming-soon',
        robots: 'noindex,nofollow'
    }) %>
    
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('./partials/_brand_head') %>
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
            background: #0f172a;
            color: #e5e7eb;
            padding: 1rem;
        }

        .card {
            width: min(560px, 100%);
            background: #111827;
            border: 1px solid #1f2937;
            border-radius: 14px;
            padding: 1.5rem;
            text-align: center;
        }

        .badge {
            display: inline-block;
            background: #f59e0b;
            color: #451a03;
            font-weight: 700;
            border-radius: 999px;
            padding: 0.25rem 0.6rem;
            margin-bottom: 0.8rem;
            font-size: 0.8rem;
        }

        h1 { margin: 0.2rem 0 0.6rem; }

        p {
            margin: 0;
            color: #9ca3af;
            line-height: 1.5;
        }

        a {
            margin-top: 1rem;
            display: inline-block;
            text-decoration: none;
            background: #22d3ee;
            color: #052e16;
            font-weight: 700;
            border-radius: 10px;
            padding: 0.65rem 0.9rem;
        }
    </style>
</head>
<body>
    <main class="card">
        <span class="badge">COMING SOON</span>
        <h1><%= service.name %></h1>
        <p><%= service.description %></p>
        <a href="/">Back to service hub</a>
    </main>
</body>
</html>
