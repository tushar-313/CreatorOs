<!DOCTYPE html>
<html lang="en">
<head>

  <!-- SEO meta tags -->
  <%- include('./partials/_seo', {
    title: profile.name,
    description: profile.bio || (profile.name + '\'s CreatorOS profile'),
    canonical: 'https://creatoros.com/' + profile.username
  }) %>
  
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <%- include('./partials/_brand_head') %>
  <meta name="description" content="<%= profile.bio %>" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── THEME TOKENS ── */
    :root {
      --bg: #F5F1EA;
      --surface: #FFFFFF;
      --text: #111111;
      --text-muted: #666666;
      --border: #111111;
      --accent: #37D6C8;
      --accent-2: #E4C13B;
      --shadow: 3px 3px 0px #111111;
      --shadow-hover: 5px 5px 0px #111111;
      --radius: 0px;
    }

    [data-theme="dark"] {
      --bg: #111111;
      --surface: #1E1E1E;
      --text: #F5F1EA;
      --text-muted: #999999;
      --border: #F5F1EA;
      --shadow: 3px 3px 0px #F5F1EA;
      --shadow-hover: 5px 5px 0px #F5F1EA;
    }

    [data-theme="neon"] {
      --bg: #0A0A0F;
      --surface: #13131A;
      --text: #EEEEFF;
      --text-muted: #8888AA;
      --border: #6C63FF;
      --accent: #00FFD1;
      --accent-2: #FF6BFF;
      --shadow: 3px 3px 0px #6C63FF;
      --shadow-hover: 5px 5px 0px #6C63FF;
    }

    [data-theme="gradient"] {
      --bg: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      --surface: rgba(255,255,255,0.12);
      --text: #FFFFFF;
      --text-muted: rgba(255,255,255,0.65);
      --border: rgba(255,255,255,0.4);
      --shadow: 3px 3px 0px rgba(255,255,255,0.3);
      --shadow-hover: 5px 5px 0px rgba(255,255,255,0.4);
    }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 2rem 1rem 4rem;
      transition: background 0.3s ease, color 0.3s ease;
    }

    [data-theme="gradient"] body,
    body[data-theme="gradient"] {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .page-wrap {
      width: 100%;
      max-width: 480px;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      animation: fadeUp 0.5s ease both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── PROFILE CARD ── */
    .profile-card {
      background: var(--surface);
      border: 2px solid var(--border);
      box-shadow: var(--shadow);
      padding: 2rem 1.5rem 1.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      text-align: center;
      position: relative;
    }

    .avatar-wrap {
      position: relative;
      width: 80px;
      height: 80px;
    }

    .avatar {
      width: 80px;
      height: 80px;
      border: 2px solid var(--border);
      box-shadow: var(--shadow);
      object-fit: cover;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--accent);
      font-size: 1.8rem;
      font-weight: 800;
      color: #111;
      overflow: hidden;
    }

    .avatar-status {
      position: absolute;
      bottom: 2px;
      right: 2px;
      width: 14px;
      height: 14px;
      background: #22c55e;
      border: 2px solid var(--border);
      border-radius: 50%;
    }

    .profile-name {
      font-size: 1.4rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.1;
    }

    .profile-handle {
      font-family: 'DM Mono', monospace;
      font-size: 0.8rem;
      color: var(--accent);
      font-weight: 500;
    }

    .profile-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      justify-content: center;
    }

    .profile-tag {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.2rem 0.6rem;
      border: 1.5px solid var(--border);
      background: var(--accent);
      color: #111;
    }

    .profile-bio {
      font-size: 0.88rem;
      color: var(--text-muted);
      line-height: 1.6;
      max-width: 340px;
    }

    .profile-stats {
      display: flex;
      gap: 1.5rem;
      padding-top: 0.5rem;
      border-top: 1.5px dashed var(--border);
      width: 100%;
      justify-content: center;
    }

    .stat-item { text-align: center; }
    .stat-num  { font-size: 1.1rem; font-weight: 800; line-height: 1; }
    .stat-lbl  { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); }

    /* ── THEME SWITCHER ── */
    .theme-switcher {
      display: flex;
      gap: 0.4rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .theme-btn {
      padding: 0.3rem 0.75rem;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      border: 1.5px solid var(--border);
      background: var(--surface);
      color: var(--text);
      cursor: pointer;
      transition: all 0.15s;
    }
    .theme-btn:hover, .theme-btn.active {
      background: var(--text);
      color: var(--bg);
    }

    /* ── LAYOUT SWITCHER ── */
    .layout-switcher {
      display: flex;
      gap: 0.4rem;
      justify-content: center;
    }

    .layout-btn {
      padding: 0.3rem 0.75rem;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      border: 1.5px solid var(--border);
      background: var(--surface);
      color: var(--text);
      cursor: pointer;
      transition: all 0.15s;
    }
    .layout-btn:hover, .layout-btn.active {
      background: var(--accent);
      color: #111;
      border-color: var(--border);
    }

    /* ── LINKS ── */
    .links-section {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }

    /* LIST layout */
    .links-section.layout-list { flex-direction: column; }

    /* GRID layout */
    .links-section.layout-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.65rem;
    }

    /* CARDS layout */
    .links-section.layout-cards { flex-direction: column; gap: 0.85rem; }

    .link-btn {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.85rem 1rem;
      background: var(--surface);
      border: 2px solid var(--border);
      box-shadow: var(--shadow);
      color: var(--text);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
      position: relative;
      overflow: hidden;
    }

    .link-btn:hover {
      transform: translate(-2px, -2px);
      box-shadow: var(--shadow-hover);
    }

    .link-btn:active {
      transform: translate(1px, 1px);
      box-shadow: 1px 1px 0px var(--border);
    }

    .link-btn::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 4px;
      background: var(--accent);
    }

    .link-icon {
      width: 2rem;
      height: 2rem;
      border: 1.5px solid var(--border);
      display: grid;
      place-items: center;
      flex-shrink: 0;
      font-size: 1rem;
      background: var(--bg);
    }

    .link-label { flex: 1; }

    .link-arrow {
      width: 1.1rem;
      height: 1.1rem;
      flex-shrink: 0;
      fill: none;
      stroke: currentColor;
      stroke-width: 2.5;
      opacity: 0.4;
      transition: opacity 0.15s, transform 0.15s;
    }
    .link-btn:hover .link-arrow {
      opacity: 1;
      transform: translateX(3px);
    }

    /* Grid layout adjustments */
    .layout-grid .link-btn {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      padding: 1rem 0.75rem;
      text-align: center;
      font-size: 0.8rem;
    }
    .layout-grid .link-btn::before { width: 100%; height: 3px; bottom: auto; }
    .layout-grid .link-icon { width: 2.2rem; height: 2.2rem; font-size: 1.1rem; }
    .layout-grid .link-arrow { display: none; }

    /* Cards layout */
    .layout-cards .link-btn {
      padding: 1rem 1.25rem;
      border-radius: 0;
    }

    /* ── SECTION DIVIDER ── */
    .section-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.25rem 0;
    }
    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
      opacity: 0.3;
    }

    /* ── FOOTER ── */
    .bio-footer {
      text-align: center;
      padding-top: 1rem;
    }

    .powered-by {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 0.85rem;
      border: 1.5px solid var(--border);
      background: var(--surface);
      box-shadow: var(--shadow);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      color: var(--text-muted);
      text-decoration: none;
      transition: all 0.15s;
    }
    .powered-by span { color: var(--accent); font-weight: 800; }
    .powered-by:hover { transform: translate(-1px,-1px); box-shadow: var(--shadow-hover); color: var(--text); }

    /* ── COPY TOAST ── */
    .toast {
      position: fixed;
      bottom: 1.5rem;
      left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: #111;
      color: #fff;
      padding: 0.6rem 1.25rem;
      font-size: 0.82rem;
      font-weight: 600;
      border: 2px solid #fff;
      box-shadow: 3px 3px 0px #fff;
      opacity: 0;
      transition: all 0.25s ease;
      white-space: nowrap;
      z-index: 100;
    }
    .toast.show {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }

    /* ── LINK COLORS ── */
    .link-instagram .link-icon { background: #fce4ec; }
    .link-youtube   .link-icon { background: #ffebee; }
    .link-github    .link-icon { background: #f3f0ff; }
    .link-linkedin  .link-icon { background: #e3f2fd; }
    .link-portfolio .link-icon { background: #e8f5e9; }
    .link-email     .link-icon { background: #fff8e1; }
    .link-whatsapp  .link-icon { background: #e8f5e9; }
    .link-resume    .link-icon { background: #fce4ec; }

    /* ── RESPONSIVE ── */
    @media (max-width: 520px) {
      body { padding: 1.25rem 0.75rem 3rem; }
      .profile-card { padding: 1.5rem 1rem 1rem; }
      .profile-name { font-size: 1.2rem; }
      .layout-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { transition: none !important; animation: none !important; }
    }
  </style>
</head>
<body>

<div class="page-wrap">

  <!-- PROFILE CARD -->
  <div class="profile-card">
    <div class="avatar-wrap">
      <div class="avatar">
        <% if (profile.avatarUrl) { %>
          <img src="<%= profile.avatarUrl %>" alt="<%= profile.name %>" />
        <% } else { %>
          <%= profile.initials || profile.name.charAt(0).toUpperCase() %>
        <% } %>
      </div>
      <div class="avatar-status"></div>
    </div>

    <div class="profile-name"><%= profile.name %></div>
    <div class="profile-handle">@<%= profile.handle %></div>

    <div class="profile-tags">
      <% (profile.tags || []).forEach(tag => { %>
        <span class="profile-tag"><%= tag %></span>
      <% }) %>
    </div>

    <p class="profile-bio"><%= profile.bio %></p>

    <div class="profile-stats">
      <div class="stat-item">
        <div class="stat-num"><%= profile.stats?.links || links.length %></div>
        <div class="stat-lbl">Links</div>
      </div>
      <div class="stat-item">
        <div class="stat-num"><%= profile.stats?.views || '—' %></div>
        <div class="stat-lbl">Views</div>
      </div>
      <div class="stat-item">
        <div class="stat-num"><%= profile.stats?.clicks || '—' %></div>
        <div class="stat-lbl">Clicks</div>
      </div>
    </div>
  </div>

  <!-- THEME SWITCHER -->
  <div class="theme-switcher">
    <button class="theme-btn active" onclick="setTheme('light', this)">☀ Light</button>
    <button class="theme-btn" onclick="setTheme('dark', this)">● Dark</button>
    <button class="theme-btn" onclick="setTheme('neon', this)">⚡ Neon</button>
    <button class="theme-btn" onclick="setTheme('gradient', this)">◈ Gradient</button>
  </div>

  <!-- LAYOUT SWITCHER -->
  <div class="layout-switcher">
    <button class="layout-btn active" onclick="setLayout('list', this)">≡ List</button>
    <button class="layout-btn" onclick="setLayout('grid', this)">⊞ Grid</button>
    <button class="layout-btn" onclick="setLayout('cards', this)">▤ Cards</button>
  </div>

  <!-- LINKS -->
  <% const socialLinks = links.filter(l => l.category === 'social'); %>
  <% const workLinks   = links.filter(l => l.category === 'work'); %>
  <% const otherLinks  = links.filter(l => l.category !== 'social' && l.category !== 'work'); %>

  <% if (socialLinks.length) { %>
    <div class="section-label">Social</div>
    <div class="links-section layout-list" id="linksContainer">
      <% socialLinks.forEach(link => { %>
        <a href="<%= link.url %>" target="_blank" rel="noopener"
           class="link-btn link-<%= link.type %>"
           onclick="trackClick('<%= link.id %>')">
          <span class="link-icon"><%= link.icon %></span>
          <span class="link-label"><%= link.label %></span>
          <svg class="link-arrow" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      <% }) %>
    </div>
  <% } %>

  <% if (workLinks.length) { %>
    <div class="section-label">Work</div>
    <div class="links-section layout-list" id="workLinksContainer">
      <% workLinks.forEach(link => { %>
        <a href="<%= link.url %>" target="_blank" rel="noopener"
           class="link-btn link-<%= link.type %>"
           onclick="trackClick('<%= link.id %>')">
          <span class="link-icon"><%= link.icon %></span>
          <span class="link-label"><%= link.label %></span>
          <svg class="link-arrow" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      <% }) %>
    </div>
  <% } %>

  <% if (otherLinks.length) { %>
    <div class="section-label">More</div>
    <div class="links-section layout-list" id="otherLinksContainer">
      <% otherLinks.forEach(link => { %>
        <a href="<%= link.url %>" target="_blank" rel="noopener"
           class="link-btn link-<%= link.type %>"
           onclick="trackClick('<%= link.id %>')">
          <span class="link-icon"><%= link.icon %></span>
          <span class="link-label"><%= link.label %></span>
          <svg class="link-arrow" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      <% }) %>
    </div>
  <% } %>

  <!-- FOOTER -->
  <div class="bio-footer">
    <a href="/" class="powered-by">
      Powered by <span>CreatorOS</span>
    </a>
  </div>

</div>

<!-- TOAST -->
<div class="toast" id="toast">Link opened!</div>

<script nonce="<%= nonce %>">
  // Theme
  function setTheme(theme, btn) {
    document.documentElement.setAttribute('data-theme', theme);
    document.querySelectorAll('.theme-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    localStorage.setItem('bio-theme', theme);
  }

  // Layout
  function setLayout(layout, btn) {
    document.querySelectorAll('.links-section').forEach(s => {
      s.className = `links-section layout-${layout}`;
    });
    document.querySelectorAll('.layout-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  }

  // Track click + toast
  function trackClick(id) {
    fetch(`/bio/track/${id}`, { method: 'POST' }).catch(() => {});
  }

  // Restore saved theme
  const saved = localStorage.getItem('bio-theme');
  if (saved) {
    document.documentElement.setAttribute('data-theme', saved);
    document.querySelectorAll('.theme-btn').forEach(b => {
      b.classList.toggle('active', b.textContent.toLowerCase().includes(saved));
    });
  }

  // Stagger link animations
  document.querySelectorAll('.link-btn').forEach((btn, i) => {
    btn.style.animationDelay = `${i * 0.06}s`;
    btn.style.animation = 'fadeUp 0.4s ease both';
  });
</script>
</body>
</html>
