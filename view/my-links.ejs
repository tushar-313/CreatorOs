<%- include('partials/layout/header', { 
    activeNav: 'my-links', 
    title: 'My Links', 
    bodyClass: 'workspace-page links-page', 
    bodyAttributes: "data-user='" + JSON.stringify({ name: typeof user !== 'undefined' ? user.name : 'User', initials: typeof user !== 'undefined' ? user.initials : 'U', isGuestContributor: typeof isGuestContributor !== 'undefined' ? isGuestContributor : false }) + "' data-domain='" + (typeof domain !== 'undefined' ? domain : 'creatoros.com') + "'",
    extraHead: '<link rel="stylesheet" href="/css/my-links.css">'
}) %>
            <section class="content">
                <!-- Dashboard Head -->
                <div class="dashboard-head">
                    <div>
                        <h1>Titli URL Shortener</h1>
                        <p>Shorten your long URLs with style and track their performance.</p>
                    </div>
                    <div class="topbar-actions">
                        <button type="button" class="primary-action-btn" id="scroll-shorten-btn" style="padding: 0.55rem 1.1rem; font-size: 0.9rem;">+ New Link</button>
                    </div>
                </div>

                <% if (isGuestContributor) { %>
                    <div class="message-box message-error" style="margin-bottom: 1.5rem;">
                        Contributor accounts can view links but cannot create new ones.
                    </div>
                <% } %>

           <div class="analytics-grid">
                    <!-- Main Links Feed -->
                    <div style="display:flex; flex-direction:column; gap:1.5rem;">
                        
                        <!-- Shorten Form -->
                        <section class="panel-retro accent-blue" id="shorten-section">
                            <div class="panel-retro-title-row">
                                <h2>Create Link</h2>
                                <span class="badge-retro">Fast</span>
                            </div>
                            
                            <form id="shorten-form" style="display:flex; flex-direction:column; gap:1rem;">
                                <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                                    <input type="url" id="redirect-url" placeholder="Paste your long link here... https://" required <%= isGuestContributor ? 'disabled' : '' %> style="flex:1; border:2px solid var(--border); padding:0.75rem; font-size:0.9rem; outline:none; background:var(--card-bg); color:var(--text); box-shadow:inset 2px 2px 0px rgba(0,0,0,0.05);" />
                                    <button type="submit" id="shorten-btn" <%= isGuestContributor ? 'disabled' : '' %> style="background:var(--accent-yellow); border:2px solid var(--border); padding:0.75rem 1.5rem; font-weight:700; cursor:pointer; box-shadow:2px 2px 0px var(--border);">SHORTEN NOW</button>
                                </div>
                                
                                <div style="display:flex; justify-content:space-between; align-items:center; font-size:0.8rem;">
                                    <span>Default domain: <strong id="domain-label" style="font-weight:700;"><%= domain %>/</strong></span>
                                    <button type="button" id="slug-toggle" style="background:none; border:none; text-decoration:underline; cursor:pointer; font-weight:700; color:var(--text);">Edit slug & tag</button>
                                </div>

                                <div id="slug-panel" style="display:none; flex-direction:column; gap:1rem; padding:1rem; border:2px solid var(--border); background:var(--bg-secondary); margin-top:0.5rem;">
                                    <div style="display:flex; flex-direction:column; gap:0.25rem;">
                                        <label for="custom-slug" style="font-size:0.75rem; font-weight:700; text-transform:uppercase;">Custom slug (optional)</label>
                                        <input type="text" id="custom-slug" placeholder="summer24" pattern="[a-zA-Z0-9-_]{3,32}" maxlength="32" style="border:2px solid var(--border); padding:0.5rem; background:var(--card-bg); color:var(--text);">
                                    </div>
                                    <div style="display:flex; flex-direction:column; gap:0.25rem;">
                                        <label for="link-title" style="font-size:0.75rem; font-weight:700; text-transform:uppercase;">Title (optional)</label>
                                        <input type="text" id="link-title" placeholder="Summer Campaign 2024" style="border:2px solid var(--border); padding:0.5rem; background:var(--card-bg); color:var(--text);">
                                    </div>
                                    <div style="display:flex; flex-direction:column; gap:0.25rem;">
                                        <label for="link-tag" style="font-size:0.75rem; font-weight:700; text-transform:uppercase;">Tag</label>
                                        <select id="link-tag" style="border:2px solid var(--border); padding:0.5rem; background:var(--card-bg); color:var(--text);">
                                            <option value="active">Active</option>
                                            <option value="social">Social</option>
                                            <option value="campaign">Campaign</option>
                                            <option value="general">General</option>
                                        </select>
                                    </div>
                                </div>
                                
                                    

                                <div id="result-banner" style="display:none; justify-content:space-between; align-items:center; background:var(--success); color:var(--text); padding:0.75rem 1rem; border:2px solid var(--border); box-shadow:2px 2px 0px var(--border); font-weight:700; margin-top:0.5rem;">
                                    <span id="result-text"></span>
                                    <button type="button" id="copy-result-btn" style="background:var(--card-bg); color:var(--text); border:2px solid var(--border); padding:0.35rem 0.75rem; cursor:pointer; font-weight:700; font-size:0.8rem;">Copy</button>
                                </div>
                            </form>
                        </section>

                        <!-- Recent Links -->
                        <section class="panel-retro">
                            <div class="panel-retro-title-row">
                                <h2>Recent Shortlinks</h2>
                                <div style="display:flex; gap:0.5rem;">
                                    <button type="button" id="sort-date" class="badge-retro" style="cursor:pointer;" title="Sort by date">Date</button>
                                    <button type="button" id="sort-clicks" class="badge-retro" style="cursor:pointer; background:var(--bg-secondary);" title="Sort by clicks">Clicks</button>
                                </div>
                            </div>
                            
                            <div id="links-feed" style="display:flex; flex-direction:column; gap:1rem;">
                              <div class="empty-state" id="empty-state">
                                    <h4 style="font-family:'Space Grotesk',sans-serif; font-size:1.1rem; margin-bottom:0.5rem;">No links yet</h4>
                                    <p style="font-size:0.85rem;">Paste a URL above and hit SHORTEN NOW to create your first link.</p>
                                </div>
                            </div>
                        </section>
                    
                    </div>

                    <!-- Sidebar Widgets -->
                    <aside style="display:flex; flex-direction:column; gap:1.5rem;">
                        <article class="stat-card-retro">
                            <span class="card-id">WIDGET_01</span>
                            <span class="label">Link Vault</span>
                            <span class="value" id="stat-total-links">0</span>
                            <span class="subtext">Total shortlinks created</span>
                            <button type="button" id="widget-new-btn" style="margin-top:1rem; width:100%; background:var(--accent-teal); border:2px solid var(--border); padding:0.5rem; font-weight:700; cursor:pointer; box-shadow:2px 2px 0px var(--border); color:var(--text);">Create Link</button>
                        </article>

                        <article class="stat-card-retro accent-blue">
                            <span class="card-id">WIDGET_02</span>
                            <span class="label">Traffic Pulse</span>
                            <span class="value"><span id="stat-total-clicks">0</span></span>
                            <span class="subtext">Total Clicks</span>
                            
                            <div style="margin-top:1rem; border-top:2px solid #333; padding-top:0.75rem; font-size:0.8rem; color:#333;">
                                <p style="margin-bottom:0.5rem; font-weight:600;">Top Performer:</p>
                                <p id="stat-top-link" style="font-weight:700; word-break:break-all;">—</p>
                            </div>
                            
                           
                        </article>
              </aside>

</div>





<footer style="margin-top:3rem; padding-top:1.5rem; border-top:var(--border-thick); display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem; font-size:0.8rem; color:var(--muted-2);">
                    <span>© <%= new Date().getFullYear() %> CreatorOS Ecosystem · Titli Module v1.2.4</span>
                    <div style="display:flex; gap:1.5rem;">
                        <a href="/services/url-shortener" style="font-weight:700;">API Docs</a>
                        <a href="/settings" style="font-weight:700;">Webhooks</a>
                        <a href="/" style="font-weight:700;">Terms</a>
                    </div>
                </footer>
            
        


    
    <div class="toast" id="toast" role="status" aria-live="polite" style="display:none; position:fixed; bottom:20px; right:20px; background:var(--card-bg); border:var(--border-thick); padding:1rem; box-shadow:var(--shadow-retro); z-index:1000; font-weight:700;"></div>

    <script src="/js/pages/my-links.js"></script>
    <script nonce="<%= nonce %>">
        const sidebarToggle = document.getElementById('sidebarToggle');
        const dashboardLayout = document.getElementById('dashboardLayout');
        const themeToggle = document.getElementById('theme-toggle');

        if (sidebarToggle && dashboardLayout) {
            sidebarToggle.addEventListener('click', () => {
                dashboardLayout.classList.toggle('sidebar-collapsed');
            });
        }

        if (themeToggle) {
            themeToggle.addEventListener('click', () => {
                document.body.classList.toggle('dark-mode');
            });
        }
        
        // Setup Search functionality
        const searchInput = document.getElementById('search-links-input');
        const oldSearch = document.getElementById('link-search'); // used by my-links.js
        if(searchInput) {
            searchInput.id = 'link-search'; // give it the ID expected by the JS
        }
    </script>
<%- include('partials/layout/footer') %>
