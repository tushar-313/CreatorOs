<%- include('partials/layout/header', {
    activeNav: 'creator-crm',
    title: 'Creator CRM',
    
    
    extraHead: '<link rel="stylesheet" href="/css/crm.css">'
}) %>

    <!-- CONTENT -->
    <div class="content">

      <!-- PIPELINE -->
      <div class="pipeline">

        <!-- LEADS -->
        <div class="pipeline-col">
          <div class="col-header">
            <span class="col-title">Leads (4)</span>
            <button type="button" class="col-header-action">
              <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
            </button>
          </div>
  
          <div class="col-body">
            <!-- Card 1 -->
            <div class="deal-card">
              <div class="deal-top">
                <span class="category-tag tag-tech">TECH</span>
                <span class="deal-amount">$5,000</span>
              </div>
              <div class="deal-name">Adobe Creative Cloud</div>
              <div class="deal-sub">Summer Campaign Intro</div>
              <div class="deal-footer">
                <div class="contact-row">
                  <div class="contact-avatar">SK</div>
                  <span class="contact-name">Sarah Miller</span>
                </div>
              </div>
            </div>

            <!-- Card 2 -->
            <div class="deal-card">
              <div class="deal-top">
                <span class="category-tag tag-gaming">GAMING</span>
                <span class="deal-amount">$2,200</span>
              </div>
              <div class="deal-name">Razer Global</div>
              <div class="deal-sub">BlackShark V2 Pro Review</div>
              <div class="deal-footer">
                <div class="contact-row">
                  <div class="contact-avatar" style="background: linear-gradient(135deg,#1e1e1e,#444); color:#fff;">JC</div>
                  <span class="contact-name">James Chen</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- OUTREACH -->
        <div class="pipeline-col">
          <div class="col-header">
            <span class="col-title">Outreach (2)</span>
            <button type="button" class="col-header-action">
              <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
          </div>
          <div class="col-body">
            <!-- Card 3 -->
            <div class="deal-card" style="position:relative;">
              <span class="emailed-badge">Emailed</span>
              <div class="deal-top">
                <span class="category-tag tag-fintech">FINTECH</span>
                <span class="deal-amount" style="visibility:hidden;">$0</span>
              </div>
              <div class="deal-name">Revolut Business</div>
              <div class="deal-sub">Tax Season Partnership</div>
              <div class="deal-footer">
                <div class="contact-row">
                  <div class="contact-avatar" style="background: linear-gradient(135deg,#6ee7b7,#059669); color:#fff;">ER</div>
                  <span class="contact-name">Elena Ross</span>
                </div>
                <button type="button" class="deal-icon-btn">
                  <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- NEGOTIATION -->
        <div class="pipeline-col">
          <div class="col-header">
            <span class="col-title">Negotiation (1)</span>
          </div>
          <div class="col-body">
            <!-- Card 4 - highlighted -->
            <div class="deal-card">
              <div class="deal-top">
                <span class="category-tag tag-lifestyle">LIFESTYLE</span>
                <span class="deal-amount">$8,500</span>
              </div>
              <div class="deal-name">Nespresso</div>
              <div class="deal-sub">Vertuo Pop Showcase · 3 Reels</div>
              <div class="deal-status-row">
                <div class="deal-status-tag">
                  <span class="check">
                    <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                  Counter-offer sent
                </div>
              </div>
              <div class="deal-footer">
                <div class="contact-row">
                  <div class="contact-avatar" style="background: linear-gradient(135deg,#c4b5fd,#7c3aed); color:#fff;">MT</div>
                  <span class="contact-name">Marcus Thorne</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div><!-- /pipeline -->

      <!-- BOTTOM STRIP -->
      <div class="bottom-strip">

        <!-- RECENT BRAND CONTACTS -->
        <div class="contacts-panel">
          <div class="panel-header">
            <span class="panel-title">Recent Brand Contacts</span>
            <a href="/services/creator-crm/all" class="view-all-link">View All CRM</a>
          </div>
          <table class="contacts-table">
            <thead>
              <tr>
                <th>Company</th>
                <th>Primary Contact</th>
                <th>Last Activity</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof contacts !== 'undefined' && contacts.length > 0) { %>
                <% contacts.forEach(function(c) { %>
                  <tr>
                    <td class="contact-company"><%= c.company %></td>
                    <td><%= c.contact %></td>
                    <td><%= c.lastActivity %></td>
                    <td><span class="status-chip chip-<%= c.statusClass %>"><%= c.status %></span></td>
                    <td><span class="action-icon"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td class="contact-company">SquareSpace</td>
                  <td>David Hoffman</td>
                  <td>2 days ago</td>
                  <td><span class="status-chip chip-partner">Partner</span></td>
                  <td><span class="action-icon"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span></td>
                </tr>
                <tr>
                  <td class="contact-company">HelloFresh</td>
                  <td>Clara Vance</td>
                  <td>Yesterday</td>
                  <td><span class="status-chip chip-negotiating">Negotiating</span></td>
                  <td><span class="action-icon"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span></td>
                </tr>
                <tr>
                  <td class="contact-company">MasterClass</td>
                  <td>Benny G.</td>
                  <td>14h ago</td>
                  <td><span class="status-chip chip-active">Active</span></td>
                  <td><span class="action-icon"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span></td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- INVOICED & UNPAID -->
        <div class="invoiced-panel">
          <div class="invoiced-header">
            <span class="panel-title">Invoiced &amp; Unpaid</span>
          </div>
          <div class="invoiced-body">
            <div class="invoiced-amount">
              <span class="big-num">$<%= typeof totalUnpaid !== 'undefined' ? totalUnpaid.toLocaleString() : '32,450' %></span>
              <span class="pending-label">Pending</span>
            </div>
            <div class="invoice-list">
              <% if (typeof invoices !== 'undefined' && invoices.length > 0) { %>
                <% invoices.forEach(function(inv) { %>
                  <div class="invoice-item">
                    <div class="invoice-info">
                      <div class="invoice-name"><%= inv.name %></div>
                      <div class="invoice-due <%= inv.overdue ? 'overdue' : 'due-in' %>">
                        <%= inv.overdue ? 'OVERDUE ' + inv.dueLabel : 'DUE IN ' + inv.dueLabel %>
                      </div>
                    </div>
                    <div class="invoice-amount">$<%= inv.amount.toLocaleString() %></div>
                  </div>
                <% }) %>
              <% } else { %>
                <div class="invoice-item">
                  <div class="invoice-info">
                    <div class="invoice-name">Skillshare · Annual</div>
                    <div class="invoice-due overdue">OVERDUE 4D</div>
                  </div>
                  <div class="invoice-amount">$12,000</div>
                </div>
                <div class="invoice-item">
                  <div class="invoice-info">
                    <div class="invoice-name">NordVPN · Mar</div>
                    <div class="invoice-due due-in">DUE IN 12D</div>
                  </div>
                  <div class="invoice-amount"></div>
                </div>
              <% } %>
            </div>
            <button type="button" class="add-invoice-btn">+</button>
          </div>
        </div>

      </div><!-- /bottom-strip -->

    </div><!-- /content -->
  </div><!-- /main -->

</div><!-- /layout -->
    


<%- include('partials/layout/footer') %>
