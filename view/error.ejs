<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - CreatorOS</title>
    <link href="/css/style.css" rel="stylesheet">
    <style>
        body { font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; background-color: #f9fafb; margin: 0; }
        .error-container { text-align: center; background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); max-width: 400px; width: 100%; }
        h1 { color: #ef4444; margin-bottom: 1rem; }
        p { color: #4b5563; margin-bottom: 1.5rem; line-height: 1.5; }
        a { display: inline-block; background-color: #3b82f6; color: white; padding: 0.5rem 1rem; border-radius: 4px; text-decoration: none; font-weight: 500; transition: background-color 0.2s; }
        a:hover { background-color: #2563eb; }
    </style>
</head>
<body>
    <div class="error-container">
        <h1>Oops! Something went wrong.</h1>
        <p><%= error || 'An unexpected error occurred. Please try again later.' %></p>
        <a href="/">Return to Home</a>
    </div>
</body>
</html>