    <!-- QR Code Library - using a more reliable CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    
    <script>
        // QR Code state
        var qrState = {
            url: '<%= locals.shortUrl || "" %>',
            fgColor: '#1a1a1a',
            bgColor: '#ffffff'
        };
        var qrCodeInstance = null;

        // Generate QR Code using qrcodejs library
        function generateQR() {
            if (!qrState.url) {
                console.log('No URL provided for QR code');
                return;
            }
            
            var container = document.getElementById('qr-canvas');
            if (!container) {
                console.log('QR container element not found');
                return;
            }
            // Clear previous QR code
            container.innerHTML = '';
            
            try {
                // Create new QR code
                qrCodeInstance = new QRCode(container, {
                    text: qrState.url,
                    width: 180,
                    height: 180,
                    colorDark: qrState.fgColor,
                    colorLight: qrState.bgColor,
                    correctLevel: QRCode.CorrectLevel.H
                });
                
                console.log('QR code generated successfully');
                
                // Update download links after a small delay to ensure rendering is complete
                setTimeout(updateDownloadLinks, 150);
            } catch (err) {
                console.error('QR Code generation error:', err);
            }
        }

        // Update download links
        function updateDownloadLinks() {
            var container = document.getElementById('qr-canvas');
            if (!container) return;
            var canvas = container.querySelector('canvas');
            var img = container.querySelector('img');
            
            var dataUrl = null;
            
            if (canvas) {
                dataUrl = canvas.toDataURL('image/png');
            } else if (img) {
                // Create a canvas to get the data URL from the image
                var tempCanvas = document.createElement('canvas');
                tempCanvas.width = 180;
                tempCanvas.height = 180;
                var ctx = tempCanvas.getContext('2d');
                ctx.drawImage(img, 0, 0, 180, 180);
                dataUrl = tempCanvas.toDataURL('image/png');
            }

            if (dataUrl) {
                var pngLink = document.getElementById('download-png');
                var mainLink = document.getElementById('download-main');
                
                if (pngLink) pngLink.href = dataUrl;
                if (mainLink) mainLink.href = dataUrl;
            }

            // Generate SVG for download
            var svgLink = document.getElementById('download-svg');
            if (svgLink && qrState.url) {
                var svgString = generateSVGQR(qrState.url, qrState.fgColor, qrState.bgColor);
                var svgBlob = new Blob([svgString], { type: 'image/svg+xml' });
                var svgUrl = URL.createObjectURL(svgBlob);
                svgLink.href = svgUrl;
            }
        }

        // Simple SVG QR generator fallback/display
        function generateSVGQR(text, fgColor, bgColor) {
            // A crisp fallback outline SVG vector 
            return '<svg xmlns="http://www.w3.org/2000/svg" width="180" height="180" viewBox="0 0 180 180"><rect width="180" height="180" fill="' + bgColor + '"/><text x="90" y="95" font-family="system-ui, sans-serif" font-size="12" font-weight="bold" text-anchor="middle" fill="' + fgColor + '">QR Asset: ' + text.substring(0,20) + '...</text></svg>';
        }

        // Update QR color
        function updateQRColor(type, color) {
            if (type === 'fg') {
                qrState.fgColor = color;
                var fgPicker = document.getElementById('fg-color-picker');
                if (fgPicker) fgPicker.value = color;
            } else {
                qrState.bgColor = color;
                var bgPicker = document.getElementById('bg-color-picker');
                if (bgPicker) bgPicker.value = color;
            }
            generateQR();
        }

        // Select color swatch
        function selectColor(el, type) {
            // Remove selection class from neighbors in the same group and add to current
            var siblings = el.closest('.color-palette').querySelectorAll('.color-swatch');
            siblings.forEach(function(s) { s.classList.remove('selected'); });
            el.classList.add('selected');

            var color = el.getAttribute('data-color');
            updateQRColor(type, color);
        }

        // Apply preset colors
        function applyPreset(fg, bg) {
            qrState.fgColor = fg;
            qrState.bgColor = bg;
            var fgPicker = document.getElementById('fg-color-picker');
            var bgPicker = document.getElementById('bg-color-picker');
            if (fgPicker) fgPicker.value = fg;
            if (bgPicker) bgPicker.value = bg;
            generateQR();
        }

        // Copy matching link to clipboard
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function() {
                var btn = document.querySelector('.btn-copy');
                if (btn) {
                    btn.textContent = 'Copied!';
                    btn.classList.add('copied');
                    setTimeout(function() {
                        btn.textContent = 'Copy';
                        btn.classList.remove('copied');
                    }, 2000);
                }
            });
        }

        // Initialize EJS-rendered QR Code 
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM loaded, shortUrl:', qrState.url);
            <% if (locals.shortUrl) { %>
            setTimeout(function() {
                if (typeof QRCode !== 'undefined') {
                    generateQR();
                } else {
                    console.error('QRCode library not loaded in time');
                }
            }, 150);
            <% } %>
        });

        // Fail-safe load listener
        window.addEventListener('load', function() {
            <% if (locals.shortUrl) { %>
            if (typeof QRCode !== 'undefined' && !qrCodeInstance) {
                generateQR();
            }
            <% } %>
        });
    </script>
</body>
