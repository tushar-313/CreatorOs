<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>Titli - Link Shortener | CreatorOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;0,9..144,900;1,9..144,300;1,9..144,700&family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        /* ══════════════════════════════════
           CSS VARIABLES - CreatorOS Theme
        ══════════════════════════════════ */
        :root {
            --cream: #f5f0e1;
            --cream-dark: #ece7d8;
            --teal: #3ecfb2;
            --teal-hover: #2bb89d;
            --ink: #1a1a1a;
            --ink-light: #4a4a4a;
            --white: #ffffff;
            --red: #ef4444;
            --border-width: 3px;
            --shadow-offset: 4px;
        }
        /* ══════════════════════════════════
           RESET & BASE
        ══════════════════════════════════ */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--ink);
            min-height: 100vh;
            line-height: 1.6;
        }
        /* Grid pattern */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(0, 0, 0, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 0, 0, 0.02) 1px, transparent 1px);
            background-size: 24px 24px;
            pointer-events: none;
            z-index: 0;
        }
        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0,0,0,0);
            border: 0;
        }
        /* ══════════════════════════════════
           LAYOUT
        ══════════════════════════════════ */
        .page {
            position: relative;
            z-index: 1;
        }
        .container {
            width: min(1100px, 100%);
            margin: 0 auto;
            padding: 0 1.5rem;
        }
        /* ══════════════════════════════════
           HEADER
        ══════════════════════════════════ */
        header {
            position: fixed;
            top: 16px;
            left: 50%;
            transform: translateX(-50%);
            width: min(1100px, calc(100% - 2rem));
            z-index: 1000;
            padding: 0.6rem 1.25rem;
            background: var(--cream);
            border: var(--border-width) solid var(--ink);
            box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--ink);
        }
        header nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            color: var(--ink);
        }
        .logo-icon {
            width: 36px;
            height: 36px;
            background: var(--teal);
            border: 2px solid var(--ink);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Fraunces', serif;
            font-weight: 900;
            font-size: 1rem;
            color: var(--ink);
        }
        .logo-text {
            font-family: 'Fraunces', serif;
            font-weight: 900;
            font-size: 1.1rem;
        }
        .logo-version {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.6rem;
            color: var(--ink-light);
        }
        .nav-links {
            display: flex;
            align-items: center;
            gap: 2rem;
        }
        .nav-links a {
            color: var(--ink);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            transition: color 0.2s;
        }
        .nav-links a:hover {
            color: var(--teal);
        }
        /* ══════════════════════════════════
           HERO SECTION
        ══════════════════════════════════ */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 7rem 1.5rem 3rem;
        }
        .hero-content {
            text-align: center;
            max-width: 900px;
            width: 100%;
        }
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.35rem 0.9rem;
            background: var(--white);
            border: 2px solid var(--ink);
            margin-bottom: 1.5rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }
        .hero-badge-dot {
            width: 6px;
            height: 6px;
            background: var(--teal);
            border-radius: 50%;
        }
        .hero-title {
            font-family: 'Fraunces', Georgia, serif;
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 1rem;
            color: var(--ink);
        }
        .hero-title em {
            font-style: italic;
            font-weight: 300;
            color: var(--teal);
        }
        .hero-subtitle {
            font-size: 1rem;
            color: var(--ink-light);
            max-width: 50ch;
            margin: 0 auto 2rem;
        }
        /* ══════════════════════════════════
           URL INPUT CARD
        ══════════════════════════════════ */
        .url-card {
            background: var(--white);
            border: var(--border-width) solid var(--ink);
            box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--ink);
            padding: 1.75rem;
            max-width: 650px;
            margin: 0 auto 1.5rem;
            position: relative;
        }
        .card-label {
            position: absolute;
            top: -11px;
            right: 16px;
            background: var(--cream);
            padding: 0.15rem 0.5rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            border: 2px solid var(--ink);
        }
        .card-label.ready {
            background: var(--teal);
            color: var(--ink);
        }
        .url-form {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }
        .input-group {
            display: flex;
            align-items: stretch;
        }
        .input-label {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 1rem;
            background: var(--cream-dark);
            border: var(--border-width) solid var(--ink);
            border-right: none;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            white-space: nowrap;
        }
        .url-input {
            flex: 1;
            padding: 0.9rem 1rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            border: var(--border-width) solid var(--ink);
            border-right: none;
            background: var(--white);
            color: var(--ink);
            outline: none;
        }
        .url-input::placeholder {
            color: #999;
        }
        .url-input:focus {
            box-shadow: inset 0 0 0 2px var(--teal);
        }
        .btn-primary {
            padding: 0.9rem 1.75rem;
            background: var(--teal);
            color: var(--ink);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            font-weight: 700;
            border: var(--border-width) solid var(--ink);
            cursor: pointer;
            transition: all 0.15s;
        }
        .btn-primary:hover {
            background: var(--teal-hover);
            box-shadow: 2px 2px 0 var(--ink);
            transform: translate(-1px, -1px);
        }
        /* ══════════════════════════════════
           RESULT SECTION
        ══════════════════════════════════ */
        .result-section {
            display: grid;
            grid-template-columns: 1fr 280px;
            gap: 1.5rem;
            max-width: 800px;
            margin: 0 auto 2rem;
        }
        .result-card {
            background: var(--white);
            border: var(--border-width) solid var(--ink);
            box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--ink);
            padding: 1.5rem;
            position: relative;
        }
        .result-url-row {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.25rem;
        }
        .result-url {
            flex: 1;
            padding: 0.65rem 0.9rem;
            background: var(--cream);
            border: 2px solid var(--ink);
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            color: var(--teal);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .result-url a {
            color: var(--teal);
            text-decoration: none;
        }
        .result-url a:hover {
            text-decoration: underline;
        }
        .btn-copy {
            padding: 0.65rem 1.25rem;
            background: var(--cream-dark);
            color: var(--ink);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.8rem;
            font-weight: 700;
            border: 2px solid var(--ink);
            cursor: pointer;
            transition: all 0.15s;
        }
        .btn-copy:hover {
            box-shadow: 2px 2px 0 var(--ink);
            transform: translate(-1px, -1px);
        }
        .btn-copy.copied {
            background: var(--teal);
        }
        /* ══════════════════════════════════
           CUSTOMIZATION SECTION
        ══════════════════════════════════ */
        .section-label {
            font-family: 'Fraunces', serif;
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: var(--ink);
        }
        .customization-row {
            display: flex;
            gap: 2rem;
            margin-bottom: 1rem;
        }
        .customization-group {
            flex: 1;
        }
        .customization-group label {
            display: block;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
            color: var(--ink-light);
        }
        .color-palette {
            display: flex;
            gap: 0.5rem;
        }
        .color-swatch {
            width: 40px;
            height: 40px;
            border: 2px solid var(--ink);
            cursor: pointer;
            position: relative;
            transition: all 0.15s;
        }
        .color-swatch:hover {
            transform: scale(1.05);
        }
        .color-swatch.selected::after {
            content: '';
            position: absolute;
            inset: -6px;
            border: 2px solid var(--teal);
            pointer-events: none;
        }
        .color-swatch-label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.55rem;
            text-transform: uppercase;
            text-align: center;
            margin-top: 0.25rem;
            color: var(--ink-light);
        }
        /* ══════════════════════════════════
           QR CODE PREVIEW
        ══════════════════════════════════ */
        .qr-card {
            background: var(--white);
            border: var(--border-width) solid var(--ink);
            box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--teal);
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
        }
        .qr-preview-border {
            border: 3px solid var(--teal);
            padding: 0.75rem;
            background: var(--white);
            position: relative;
        }
        .qr-dots-top, .qr-dots-bottom {
            position: absolute;
            left: 0;
            right: 0;
            display: flex;
            justify-content: space-around;
            padding: 0 0.5rem;
        }
        .qr-dots-top {
            top: -8px;
        }
        .qr-dots-bottom {
            bottom: -8px;
        }
        .qr-dot {
            width: 4px;
            height: 4px;
            background: var(--teal);
            border-radius: 50%;
        }
        .qr-wrapper {
            background: var(--white);
            display: flex;
            align-items: center;
            justify-content: center;
            min-width: 180px;
            min-height: 180px;
        }
        #qr-canvas {
            display: block;
        }
        .qr-label {
            font-family: 'Fraunces', serif;
            font-weight: 900;
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--ink);
            margin-top: 1rem;
            text-align: center;
        }
        /* ══════════════════════════════════
           EXPORT SECTION
        ══════════════════════════════════ */
        .export-card {
            background: var(--white);
            border: var(--border-width) solid var(--ink);
            box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--ink);
            padding: 1.25rem;
            position: relative;
            margin-top: 1.5rem;
        }
        .export-label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 0.75rem;
            color: var(--ink);
        }
        .export-buttons {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }
        .btn-export {
            flex: 1;
            padding: 0.6rem 0.75rem;
            background: var(--white);
            color: var(--ink);
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            font-weight: 600;
            border: 2px solid var(--ink);
            cursor: pointer;
            transition: all 0.15s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            text-decoration: none;
        }
        .btn-export:hover {
            background: var(--cream);
        }
        .btn-export.active {
            background: var(--ink);
            color: var(--white);
        }
        .btn-save {
            width: 100%;
            padding: 0.9rem;
            background: var(--ink);
            color: var(--white);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            font-weight: 700;
            border: 2px solid var(--ink);
            cursor: pointer;
            transition: all 0.15s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            text-decoration: none;
        }
        .btn-save:hover {
            background: var(--teal);
            color: var(--ink);
        }
        /* ══════════════════════════════════
           ERROR CARD
        ══════════════════════════════════ */
        .error-card {
            background: var(--white);
            border: var(--border-width) solid var(--red);
            box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--red);
            padding: 1.25rem;
            max-width: 650px;
            margin: 0 auto 1.5rem;
            color: var(--red);
            font-weight: 600;
        }
        /* ══════════════════════════════════
           FEATURES SECTION
        ══════════════════════════════════ */
        .features {
            padding: 4rem 1.5rem;
            background: var(--cream-dark);
            border-top: var(--border-width) solid var(--ink);
        }
        .section-header {
            text-align: center;
            margin-bottom: 3rem;
        }
        .section-title {
            font-family: 'Fraunces', Georgia, serif;
            font-size: clamp(1.75rem, 3.5vw, 2.25rem);
            font-weight: 900;
            margin-bottom: 0.5rem;
            color: var(--ink);
        }
        .section-subtitle {
            font-size: 0.95rem;
            color: var(--ink-light);
        }
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1.25rem;
            max-width: 900px;
            margin: 0 auto;
        }
        .feature-card {
            background: var(--white);
            border: var(--border-width) solid var(--ink);
            box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--ink);
            padding: 1.5rem;
            transition: all 0.15s;
        }
        .feature-card:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0 var(--ink);
        }
        .feature-icon {
            width: 44px;
            height: 44px;
            background: var(--teal);
            border: 2px solid var(--ink);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
        }
        .feature-title {
            font-family: 'Fraunces', serif;
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 0.4rem;
            color: var(--ink);
        }
        .feature-desc {
            font-size: 0.85rem;
            color: var(--ink-light);
            line-height: 1.5;
        }
        /* ══════════════════════════════════
           HOW IT WORKS
        ══════════════════════════════════ */
        .how-it-works {
            padding: 4rem 1.5rem;
            border-top: var(--border-width) solid var(--ink);
        }
        .steps {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 2rem;
            max-width: 800px;
            margin: 0 auto;
        }
        .step {
            text-align: center;
            max-width: 200px;
        }
        .step-number {
            width: 64px;
            height: 64px;
            background: var(--white);
            border: var(--border-width) solid var(--ink);
            box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--teal);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Fraunces', serif;
            font-size: 1.5rem;
            font-weight: 900;
            margin: 0 auto 1rem;
        }
        .step-title {
            font-family: 'Fraunces', serif;
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 0.35rem;
            color: var(--ink);
        }
        .step-desc {
            font-size: 0.8rem;
            color: var(--ink-light);
        }
        /* ══════════════════════════════════
           FOOTER
        ══════════════════════════════════ */
        footer {
            padding: 1.5rem;
            border-top: var(--border-width) solid var(--ink);
            background: var(--cream-dark);
            text-align: center;
        }
        footer p {
            font-size: 0.8rem;
            color: var(--ink-light);
        }
        /* ══════════════════════════════════
           RESPONSIVE
        ══════════════════════════════════ */
        @media (max-width: 768px) {
            header {
                top: 10px;
                width: calc(100% - 1rem);
            }
            .nav-links {
                display: none;
            }
            .input-group {
                flex-direction: column;
            }
            .input-label {
                border-right: var(--border-width) solid var(--ink);
                border-bottom: none;
                padding: 0.6rem;
            }
            .url-input {
                border-right: var(--border-width) solid var(--ink);
                border-bottom: none;
            }
            .btn-primary {
                width: 100%;
            }
            .result-section {
                grid-template-columns: 1fr;
            }
            .customization-row {
                flex-direction: column;
                gap: 1rem;
            }
            .result-url-row {
                flex-direction: column;
            }
            .result-url, .btn-copy {
                width: 100%;
            }
            .export-buttons {
                flex-wrap: wrap;
            }
        }
    </style>
</head>
<body>
    <div class="page">
        <!-- Header -->
        <header>
            <nav>
                <a href="/" class="logo">
                    <div class="logo-icon">C</div>
                    <div>
                        <div class="logo-text">CreatorOS</div>
                        <div class="logo-version">v2.0 Beta</div>
                    </div>
                </a>
                <div class="nav-links">
                    <a href="/">Service Hub</a>
                    <a href="#features">Features</a>
                    <a href="#how-it-works">How It Works</a>
                </div>
            </nav>
        </header>
        <main>
            <!-- Hero Section -->
            <section class="hero">
                <div class="hero-content">
                    <div class="hero-badge">
                        <span class="hero-badge-dot"></span>
                        Titli Link Shortener
                    </div>
                    
                    <h1 class="hero-title">Shorten Links,<br><em>Let Your Ideas Fly.</em></h1>
                    <p class="hero-subtitle">Transform long links into memorable short ones with custom QR codes.</p>
                    <!-- URL Input Card -->
                    <div class="url-card">
                        <span class="card-label">Shorten URL</span>
                        <form action="/services/url-shortener/shorten" method="POST" class="url-form">
                            <div class="input-group">
                                <span class="input-label">URL to Shorten</span>
                                <label for="url-shortener-input" class="sr-only">URL to Shorten</label>
                                <input 
                                    id="url-shortener-input"
                                    type="url" 
                                    name="redirectUrl"
                                    placeholder="https://your-super-long-link.com/to-shorten" 
                                    class="url-input"
                                    required
                                >
                                <button type="submit" class="btn-primary">Shorten</button>
                            </div>
                        </form>
                    </div>
                    <% if (locals.shortUrl) { %>
                    <!-- Result Section -->
                    <div class="result-section">
                        <!-- Left: Link & Customization -->
                        <div>
                            <div class="result-card">
                                <span class="card-label ready">Ready</span>
                                
                                <div class="result-url-row">
                                    <div class="result-url">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.1-1.1m-.758-4.9a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                                        </svg>
                                        <a href="<%= shortUrl %>" target="_blank"><%= shortUrl %></a>
                                    </div>
                                    <button type="button" class="btn-copy" onclick="copyToClipboard('<%= shortUrl %>')">Copy</button>
                                </div>
                                <!-- Customization -->
                                <div class="section-label">Customization</div>
                                
                                <div class="customization-row">
                                    <div class="customization-group">
                                        <label>Color Palette</label>
                                        <div class="color-palette">
                                            <div>
                                                <div class="color-swatch selected" data-type="fg" data-color="#1a1a1a" style="background: #1a1a1a;" onclick="selectColor(this, 'fg')"></div>
