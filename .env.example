# ----------------------------------------------------
# CreatorOS - Environment Variables Template
# ----------------------------------------------------

# --- REQUIRED VARIABLES ---
# The application will fail to start fully or operate core features without these.

# MongoDB Connection String (e.g. mongodb+srv://...)
MONGODB_URI=

# Secret key for JWT signing
JWT_SECRET=

# Secret key for Express Sessions
SESSION_SECRET=

# Default Port (Fallback is 3000)
PORT=3000

# Server Environment (development, production)
NODE_ENV=development

# --- OPTIONAL VARIABLES (Graceful Degradation Supported) ---
# The application will still start and run without these, disabling specific features.

# Base URL for the application (e.g., https://creatoros.com)
APP_URL=
BASE_URL=

# OpenAI API Key (For AI content suggestions)
# If missing, AI features will gracefully return 503 errors.
OPENAI_API_KEY=

# Redis Connection String (For BullMQ and Caching)
# If missing, background workers and queues may be disabled gracefully.
REDIS_URI=

# Stripe Configuration (For Billing and Subscriptions)
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Google OAuth Credentials (For "Continue with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Instagram Graph API Config
INSTAGRAM_APP_SECRET=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=creatoros-verify-token
INSTAGRAM_LOOKUP_COOLDOWN_SECONDS=30

# Dev-only cookie security override
COOKIE_SECURE_DEV=false
